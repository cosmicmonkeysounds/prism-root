{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prism Studio",
  "version": "0.1.0",
  "identifier": "com.prism.studio",
  "build": {
    "beforeBuildCommand": "cargo build -p prism-shell --release"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Prism Studio",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
