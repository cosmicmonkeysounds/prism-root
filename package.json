{
  "name": "prism",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "description": "Prism Framework monorepo. Mid-Clay-migration: the Rust half (packages/prism-daemon, prism-core, prism-builder, prism-shell, prism-studio, prism-cli) is driven by the top-level Cargo.toml workspace. The JS half is now limited to prism-relay (Hono JSX SSR, pending its own rewrite) and this root, which keeps pnpm around as the umbrella runner.",
  "scripts": {
    "prism": "cargo run -q -p prism-cli --",
    "dev": "cargo run -q -p prism-cli -- dev shell",
    "dev:web": "cargo run -q -p prism-cli -- dev web",
    "dev:studio": "cargo run -q -p prism-cli -- dev studio",
    "dev:relay": "cargo run -q -p prism-cli -- dev relay",
    "dev:all": "cargo run -q -p prism-cli -- dev all",
    "build": "cargo run -q -p prism-cli -- build",
    "build:web": "cargo run -q -p prism-cli -- build --target web",
    "build:relay": "cargo run -q -p prism-cli -- build --target relay",
    "test": "cargo run -q -p prism-cli -- test",
    "test:all": "cargo run -q -p prism-cli -- test --all",
    "test:rust": "cargo run -q -p prism-cli -- test --rust",
    "test:ts": "cargo run -q -p prism-cli -- test --ts",
    "test:e2e": "cargo run -q -p prism-cli -- test --e2e",
    "lint": "cargo run -q -p prism-cli -- lint",
    "format": "cargo run -q -p prism-cli -- fmt",
    "format:check": "cargo run -q -p prism-cli -- fmt --check"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "*.rs": ["cargo fmt --"],
    "*.{json,md,yaml,yml}": ["prettier --write"]
  }
}
