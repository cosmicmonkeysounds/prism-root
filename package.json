{
  "name": "prism",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "description": "Prism Framework monorepo. Mid-Clay-migration: the Rust half (packages/prism-daemon, prism-core, prism-builder, prism-shell, prism-studio/src-tauri) is driven by the top-level Cargo.toml workspace. The JS half is now limited to prism-relay (Next.js, out of scope for the migration) and this root, which keeps pnpm + turbo around as the umbrella runner.",
  "scripts": {
    "dev": "cargo run -p prism-shell",
    "dev:web": "trunk serve --config packages/prism-shell/Trunk.toml",
    "dev:studio": "cargo tauri dev",
    "dev:relay": "pnpm --filter @prism/relay dev",
    "build": "cargo build --workspace --release && pnpm --filter @prism/relay build",
    "build:web": "trunk build --release --config packages/prism-shell/Trunk.toml",
    "test": "cargo test --workspace",
    "test:e2e": "pnpm --filter @prism/relay run test:e2e",
    "lint": "cargo clippy --workspace --all-targets -- -D warnings",
    "format": "cargo fmt --all"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "*.rs": ["cargo fmt --"],
    "*.{json,md,yaml,yml}": ["prettier --write"]
  }
}
