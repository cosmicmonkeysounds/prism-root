import { Button, LineEdit, TextEdit, Switch, ComboBox, ListView, ScrollView,
         VerticalBox, HorizontalBox, GroupBox, Palette, TabWidget } from "std-widgets.slint";

// ── Data structs ───────────────────────────────────────────────────

struct ButtonSpec {
    label: string,
}

struct FieldRow {
    key: string,
    label: string,
    kind: string,
    value: string,
    required: bool,
}

struct TabItem {
    id: int,
    title: string,
    active: bool,
}

struct CommandItem {
    label: string,
    shortcut: string,
    category: string,
}

struct ToastItem {
    id: int,
    title: string,
    body: string,
    kind: string,
}

struct InspectorNode {
    id: string,
    component-id: string,
    depth: int,
    selected: bool,
}

struct SearchResultItem {
    node-id: string,
    component-type: string,
    field: string,
    snippet: string,
}

struct ComponentPaletteItem {
    component-type: string,
    label: string,
    description: string,
}

struct BuilderNode {
    id: string,
    component-type: string,
    selected: bool,
    depth: int,
    text: string,
    level: int,
    href: string,
    alt: string,
    placeholder: string,
    label: string,
    disabled: bool,
}

struct HelpTooltipData {
    visible: bool,
    title: string,
    summary: string,
    has-docs: bool,
    tip-x: length,
    tip-y: length,
}

struct BreadcrumbItem {
    id: string,
    label: string,
    has-separator: bool,
}

struct DocsPanelData {
    visible: bool,
    help-id: string,
    title: string,
    summary: string,
    body: string,
}

// ── Icon button ───────────────────────────────────────────────────

component IconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    in property <string> tooltip-text: "";
    in property <string> help-id: "";
    callback clicked;
    callback hover-start(string, length, length);
    callback hover-end();

    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: touch.has-hover && root.enabled ? Palette.control-background : transparent;

    Image {
        source: root.icon;
        width: 16px;
        height: 16px;
        colorize: root.enabled
            ? (touch.has-hover ? Palette.foreground : Palette.foreground.transparentize(20%))
            : Palette.foreground.transparentize(70%);
    }

    touch := TouchArea {
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if root.enabled { root.clicked(); }
        }
        changed has-hover => {
            if (self.has-hover && root.help-id != "") {
                root.hover-start(root.help-id,
                    root.absolute-position.x + root.width + 8px,
                    root.absolute-position.y);
            }
            if (!self.has-hover && root.help-id != "") {
                root.hover-end();
            }
        }
    }
}

component ToolbarSeparator inherits Rectangle {
    width: 1px;
    height: 20px;
    background: Palette.foreground.transparentize(80%);
}

// ── Builder block components ──────────────────────────────────────

component BuilderBlock inherits Rectangle {
    in property <string> node-id;
    in property <string> component-type;
    in property <bool> selected;
    in property <int> depth;
    in property <string> text;
    in property <int> level;
    in property <string> href;
    in property <string> alt;
    in property <string> placeholder;
    in property <string> label;
    in property <bool> disabled;
    callback clicked(string);
    callback text-edited(string, string);
    callback delete-clicked(string);

    border-radius: 6px;
    border-width: root.selected ? 2px : 0px;
    border-color: Palette.accent-background;
    background: root.selected ? Palette.accent-background.transparentize(90%) : transparent;

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 1;
            padding-left: root.depth * 16px + 12px;
            padding-right: 8px;
            padding-top: 6px;
            padding-bottom: 6px;

            if root.component-type == "heading" && !root.selected : Text {
                text: root.text;
                color: Palette.foreground;
                font-size: root.level <= 1 ? 32px :
                           root.level == 2 ? 26px :
                           root.level == 3 ? 22px :
                           root.level == 4 ? 18px :
                           root.level == 5 ? 16px : 14px;
                font-weight: 700;
                wrap: word-wrap;
            }
            if root.component-type == "heading" && root.selected : LineEdit {
                height: root.level <= 1 ? 40px :
                        root.level == 2 ? 34px :
                        root.level == 3 ? 30px : 28px;
                text: root.text;
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            if root.component-type == "text" && !root.selected : Text {
                text: root.text;
                color: Palette.foreground;
                font-size: 14px;
                wrap: word-wrap;
            }
            if root.component-type == "text" && root.selected : LineEdit {
                height: 28px;
                text: root.text;
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            if root.component-type == "link" && !root.selected : HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Image {
                    source: @image-url("icons/link.svg");
                    width: 14px; height: 14px;
                    colorize: Palette.accent-background;
                    y: 2px;
                }
                Text {
                    text: root.text != "" ? root.text : root.href;
                    color: Palette.accent-foreground;
                    font-size: 14px;
                }
            }
            if root.component-type == "link" && root.selected : VerticalLayout {
                spacing: 4px;
                LineEdit {
                    height: 28px;
                    text: root.text;
                    placeholder-text: "Link text";
                    accepted(val) => { root.text-edited(root.node-id, val); }
                }
            }

            if root.component-type == "image" : Rectangle {
                min-height: 80px;
                background: Palette.control-background;
                border-radius: 6px;
                HorizontalLayout {
                    alignment: center;
                    spacing: 6px;
                    Image {
                        source: @image-url("icons/image.svg");
                        width: 16px; height: 16px;
                        colorize: Palette.foreground.transparentize(40%);
                    }
                    Text {
                        text: root.alt != "" ? root.alt : "Image";
                        color: Palette.foreground.transparentize(40%);
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }

            if root.component-type == "container" : Rectangle { height: 4px; }

            if root.component-type == "form" : HorizontalLayout {
                spacing: 4px; alignment: start;
                Image { source: @image-url("icons/box.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); }
                Text { text: "Form"; color: Palette.foreground.transparentize(40%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
            }

            if root.component-type == "input" : VerticalLayout {
                spacing: 4px;
                if root.label != "" : Text { text: root.label; color: Palette.foreground; font-size: 12px; }
                LineEdit { height: 28px; placeholder-text: root.placeholder != "" ? root.placeholder : root.text; enabled: false; }
            }

            if root.component-type == "button" && !root.selected : HorizontalLayout {
                alignment: start;
                Button { text: root.text != "" ? root.text : "Button"; enabled: !root.disabled; }
            }
            if root.component-type == "button" && root.selected : LineEdit {
                height: 28px;
                text: root.text != "" ? root.text : "Button";
                placeholder-text: "Button text";
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            if root.component-type == "card" : Rectangle {
                border-width: 1px; border-color: Palette.control-background; border-radius: 8px;
                background: Palette.alternate-background; min-height: 48px;
                VerticalLayout {
                    padding: 12px; spacing: 4px;
                    if !root.selected : Text { text: root.text != "" ? root.text : "Card"; color: Palette.foreground; font-size: 16px; font-weight: 600; }
                    if root.selected : LineEdit { height: 28px; text: root.text != "" ? root.text : "Card"; placeholder-text: "Card title"; accepted(val) => { root.text-edited(root.node-id, val); } }
                    if root.label != "" : Text { text: root.label; color: Palette.foreground.transparentize(30%); font-size: 13px; wrap: word-wrap; }
                }
            }

            if root.component-type == "code" : Rectangle {
                background: Palette.control-background; border-radius: 6px; min-height: 36px;
                VerticalLayout {
                    padding: 10px;
                    if !root.selected : Text { text: root.text != "" ? root.text : "// code"; color: Palette.foreground.transparentize(20%); font-size: 13px; font-family: "monospace"; wrap: word-wrap; }
                    if root.selected : LineEdit { height: 28px; text: root.text != "" ? root.text : "// code"; accepted(val) => { root.text-edited(root.node-id, val); } }
                }
            }

            if root.component-type == "divider" : Rectangle { height: 1px; background: Palette.foreground.transparentize(70%); }

            if root.component-type == "spacer" : Rectangle {
                height: root.level > 0 ? root.level * 1px : 24px;
                border-width: 1px; border-color: Palette.foreground.transparentize(85%); border-radius: 2px;
            }

            if root.component-type == "columns" : HorizontalLayout {
                spacing: 6px; alignment: start;
                Image { source: @image-url("icons/columns.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); }
                Text { text: "Columns"; color: Palette.foreground.transparentize(40%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                Text { text: root.level > 0 ? "gap: " + root.level + "px" : "gap: 16px"; color: Palette.foreground.transparentize(60%); font-size: 10px; vertical-alignment: center; }
            }

            if root.component-type == "list" : HorizontalLayout {
                spacing: 6px; alignment: start;
                Image { source: @image-url("icons/list.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); }
                Text { text: root.disabled ? "Ordered List (ol)" : "Unordered List (ul)"; color: Palette.foreground.transparentize(40%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
            }

            if root.component-type == "table" : Rectangle {
                border-width: 1px; border-color: Palette.control-background; border-radius: 4px; min-height: 32px;
                VerticalLayout {
                    padding: 8px; spacing: 4px;
                    if root.label != "" : Text { text: root.label; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                    HorizontalLayout {
                        spacing: 6px; alignment: start;
                        Image { source: @image-url("icons/table.svg"); width: 14px; height: 14px; colorize: Palette.foreground; }
                        Text { text: root.text != "" ? root.text : "Table"; color: Palette.foreground; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                    }
                }
            }

            if root.component-type == "tabs" : HorizontalLayout {
                spacing: 6px; alignment: start;
                Image { source: @image-url("icons/layout.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                Text { text: root.text != "" ? root.text : "Tabs"; color: Palette.foreground.transparentize(30%); font-size: 12px; font-weight: 500; vertical-alignment: center; }
            }

            if root.component-type == "accordion" : Rectangle {
                background: Palette.alternate-background; border-radius: 4px; min-height: 32px;
                HorizontalLayout {
                    padding-left: 8px; padding-right: 8px; spacing: 6px; alignment: start;
                    Image { source: @image-url("icons/chevron-down.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); vertical-alignment: center; }
                    if !root.selected : Text { text: root.text != "" ? root.text : "Accordion"; color: Palette.foreground; font-size: 13px; font-weight: 600; vertical-alignment: center; }
                    if root.selected : LineEdit { height: 28px; text: root.text != "" ? root.text : "Accordion"; placeholder-text: "Section title"; horizontal-stretch: 1; accepted(val) => { root.text-edited(root.node-id, val); } }
                }
            }
        }

        if root.selected : VerticalLayout {
            alignment: start;
            padding-top: 6px;
            padding-right: 4px;
            IconButton {
                icon: @image-url("icons/x.svg");
                clicked => { root.delete-clicked(root.node-id); }
            }
        }
    }

    TouchArea {
        clicked => { root.clicked(root.node-id); }
    }
}

// ── Reusable components ────────────────────────────────────────────

component NavButton inherits Rectangle {
    in property <image> icon;
    in property <bool> selected;
    in property <string> help-id: "";
    callback clicked;
    callback hover-start(string, length, length);
    callback hover-end();

    width: 48px;
    height: 48px;
    background: selected ? Palette.accent-background.transparentize(85%) : transparent;

    Rectangle {
        x: 0px; y: 0px; width: 3px; height: parent.height;
        background: root.selected ? Palette.accent-background : transparent;
        border-radius: 1px;
    }

    Image {
        source: root.icon; width: 20px; height: 20px;
        colorize: root.selected ? Palette.accent-foreground : Palette.foreground.transparentize(30%);
    }

    nav-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
        changed has-hover => {
            if (self.has-hover && root.help-id != "") {
                root.hover-start(root.help-id,
                    root.absolute-position.x + root.width + 8px,
                    root.absolute-position.y);
            }
            if (!self.has-hover && root.help-id != "") {
                root.hover-end();
            }
        }
    }
}

component FieldEditor inherits Rectangle {
    in property <string> key;
    in property <string> label;
    in property <string> kind;
    in property <string> value;
    in property <bool> required;
    callback field-edited(string, string);

    height: 64px;
    background: transparent;

    VerticalLayout {
        spacing: 2px;
        padding-top: 4px;
        padding-bottom: 4px;

        Text {
            text: root.required ? root.label + " *" : root.label;
            color: Palette.foreground;
            font-size: 12px;
        }

        if root.kind == "boolean" : HorizontalLayout {
            alignment: start; height: 24px;
            Switch {
                checked: root.value == "true";
                toggled => { root.field-edited(root.key, self.checked ? "true" : "false"); }
            }
        }

        if root.kind != "boolean" : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => { root.field-edited(root.key, text); }
        }

        Text {
            text: root.kind + " · " + root.key;
            color: Palette.foreground.transparentize(50%);
            font-size: 10px;
        }
    }
}

component InspectorRow inherits Rectangle {
    in property <string> node-id;
    in property <string> component-id;
    in property <int> depth;
    in property <bool> selected;
    callback clicked;
    callback move-up;
    callback move-down;

    height: 30px;
    background: selected ? Palette.accent-background.transparentize(85%) : transparent;
    border-radius: 4px;

    HorizontalLayout {
        padding-left: root.depth * 16px + 12px;
        padding-right: 8px;
        alignment: space-between;

        HorizontalLayout {
            spacing: 6px; alignment: start;
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: root.selected ? Palette.accent-background : Palette.foreground.transparentize(60%); y: 12px; }
            Text { text: root.component-id; color: root.selected ? Palette.accent-foreground : Palette.foreground; font-size: 12px; font-weight: root.selected ? 600 : 400; vertical-alignment: center; }
            Text { text: root.node-id; color: Palette.foreground.transparentize(50%); font-size: 10px; font-family: "monospace"; vertical-alignment: center; }
        }

        if root.selected : HorizontalLayout {
            spacing: 2px; width: 60px; alignment: end;
            IconButton { icon: @image-url("icons/chevron-up.svg"); clicked => { root.move-up(); } }
            IconButton { icon: @image-url("icons/chevron-down.svg"); clicked => { root.move-down(); } }
        }
    }

    TouchArea { clicked => { root.clicked(); } }
}

component Toast inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> kind;
    callback dismissed;

    property <color> kind-color: root.kind == "error" ? #dc3c3c :
                                  root.kind == "warning" ? #dcaa3c :
                                  root.kind == "success" ? #3cdc6e :
                                  Palette.accent-background;

    width: 320px;
    background: Palette.alternate-background;
    border-radius: 8px;
    border-width: 1px;
    border-color: kind-color;
    clip: true;

    VerticalLayout {
        padding: 12px; spacing: 4px;
        HorizontalLayout {
            spacing: 8px;
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: root.kind-color; y: 6px; }
            Text { text: root.title; color: Palette.foreground; font-size: 13px; font-weight: 600; overflow: elide; }
            Rectangle { horizontal-stretch: 1; }
            IconButton { icon: @image-url("icons/x.svg"); clicked => { root.dismissed(); } }
        }
        if root.body != "" : Text { text: root.body; color: Palette.foreground.transparentize(30%); font-size: 12px; wrap: word-wrap; }
    }
}

// ── Docs content (shared between sidebar and full view) ───────────

component DocsContent inherits Rectangle {
    in property <string> doc-title;
    in property <string> doc-summary;
    in property <string> doc-body;
    in property <bool> compact: false;

    VerticalLayout {
        spacing: 0px;

        Text {
            text: root.doc-title;
            color: Palette.foreground;
            font-size: root.compact ? 14px : 22px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Rectangle { height: root.compact ? 8px : 12px; }

        Text {
            text: root.doc-summary;
            color: Palette.foreground.transparentize(20%);
            font-size: root.compact ? 12px : 14px;
            font-weight: 500;
            wrap: word-wrap;
        }

        if root.doc-body != "" : Rectangle { height: root.compact ? 10px : 16px; }

        if root.doc-body != "" : Rectangle {
            height: 1px;
            background: Palette.foreground.transparentize(85%);
        }

        if root.doc-body != "" : Rectangle { height: root.compact ? 10px : 16px; }

        if root.doc-body != "" : Text {
            text: root.doc-body;
            color: Palette.foreground.transparentize(30%);
            font-size: root.compact ? 12px : 13px;
            wrap: word-wrap;
        }
    }
}

// ── Root component ─────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Prism Studio";
    preferred-width: 1280px;
    preferred-height: 800px;

    // Panel navigation (0 = Identity, 1 = Edit, 2 = Code Editor)
    in property <int> active-panel-id: 1;
    callback select-panel(int);

    // Identity panel
    in property <[ButtonSpec]> actions: [];
    callback clicked(int);

    // Builder canvas
    in property <[BuilderNode]> builder-nodes: [];
    in property <int> builder-node-count: 0;
    callback builder-node-clicked(string);
    callback builder-text-edited(string, string);
    callback builder-delete-node(string);
    in property <string> builder-source: "";

    // Component palette
    in property <[ComponentPaletteItem]> component-palette: [];
    callback add-component(string);

    // Layer tree
    in property <string> inspector-tree: "";
    in property <[InspectorNode]> inspector-nodes: [];
    callback node-clicked(string);
    callback node-move-up(string);
    callback node-move-down(string);

    // Properties
    in property <string> selected-component: "";
    in property <[FieldRow]> field-rows: [];
    callback field-edited(string, string);

    // Tabbed MDI
    in property <[TabItem]> tabs: [];
    callback tab-activated(int);
    callback tab-closed(int);

    // Command palette
    in property <bool> command-palette-visible: false;
    in property <[CommandItem]> command-results: [];
    callback toggle-command-palette();
    callback command-palette-input(string);
    callback command-selected(int);

    // Notifications
    in property <[ToastItem]> notifications: [];
    callback dismiss-notification(int);

    // Undo/redo
    in property <bool> can-undo: false;
    in property <bool> can-redo: false;
    in property <string> undo-label: "";
    in property <string> redo-label: "";
    callback undo-clicked;
    callback redo-clicked;

    // Search
    in property <string> search-query: "";
    in property <[SearchResultItem]> search-results: [];
    callback search-input(string);
    callback search-result-clicked(string);

    // Clipboard
    in property <bool> has-selection: false;
    in property <bool> has-clipboard: false;
    callback copy-clicked;
    callback paste-clicked;
    callback cut-clicked;
    callback duplicate-clicked;

    // Keyboard
    callback escape-pressed;
    callback search-focus;
    in property <string> panel-title: "Editor";
    in property <string> panel-hint: "Build your page visually.";

    // Breadcrumbs
    in property <[BreadcrumbItem]> breadcrumbs: [];
    callback breadcrumb-clicked(string);

    // Help tooltip
    in property <HelpTooltipData> help-tooltip: {
        visible: false, title: "", summary: "", has-docs: false,
        tip-x: 0px, tip-y: 0px
    };
    callback help-hover(string, length, length);
    callback help-leave();
    callback help-docs-clicked;
    callback help-entry-clicked;

    // Code editor
    in property <string> editor-text: "";
    callback editor-text-changed(string);

    // Docs panel (sidebar) and docs view (full)
    in property <DocsPanelData> docs-panel: {
        visible: false, help-id: "", title: "", summary: "", body: ""
    };
    in property <DocsPanelData> docs-view: {
        visible: false, help-id: "", title: "", summary: "", body: ""
    };
    callback docs-open-full;
    callback docs-panel-close;
    callback docs-view-close;

    background: Palette.background;

    fs := FocusScope {
        width: 100%;
        height: 100%;

        key-pressed(event) => {
            if (event.modifiers.control && event.modifiers.shift && event.text == "P") { root.toggle-command-palette(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{001a}") { root.undo-clicked(); return accept; }
            if (event.modifiers.control && event.modifiers.shift && event.text == "\u{001a}") { root.redo-clicked(); return accept; }
            if (event.modifiers.control && event.text == "\u{0006}") { root.search-focus(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{0003}") { root.copy-clicked(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{0016}") { root.paste-clicked(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{0018}") { root.cut-clicked(); return accept; }
            if (event.modifiers.control && event.text == "\u{0004}") { root.duplicate-clicked(); return accept; }
            if (event.text == Key.Escape) { root.escape-pressed(); return accept; }
            if (event.text == Key.Delete) { root.builder-delete-node(""); return accept; }
            return reject;
        }

        VerticalLayout {
            HorizontalLayout {
                spacing: 0px;
                vertical-stretch: 1;

                // ── Activity bar ──────────────────────────────────
                Rectangle {
                    width: 48px;
                    background: Palette.alternate-background;
                    VerticalLayout {
                        padding-top: 8px;
                        spacing: 0px;
                        alignment: start;
                        NavButton {
                            icon: @image-url("icons/user.svg");
                            selected: root.active-panel-id == 0;
                            help-id: "shell.panels.identity";
                            clicked => { root.select-panel(0); }
                            hover-start(id, x, y) => { root.help-hover(id, x, y); }
                            hover-end => { root.help-leave(); }
                        }
                        NavButton {
                            icon: @image-url("icons/layout.svg");
                            selected: root.active-panel-id == 1;
                            help-id: "shell.panels.editor";
                            clicked => { root.select-panel(1); }
                            hover-start(id, x, y) => { root.help-hover(id, x, y); }
                            hover-end => { root.help-leave(); }
                        }
                        NavButton {
                            icon: @image-url("icons/code.svg");
                            selected: root.active-panel-id == 2;
                            help-id: "shell.panels.code-editor";
                            clicked => { root.select-panel(2); }
                            hover-start(id, x, y) => { root.help-hover(id, x, y); }
                            hover-end => { root.help-leave(); }
                        }
                    }
                }

                // ── Identity sidebar ─────────────────────────────
                if root.active-panel-id == 0 : Rectangle {
                    width: 220px;
                    background: Palette.alternate-background;
                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }
                    VerticalLayout {
                        padding: 16px; spacing: 8px; alignment: start;
                        Text { text: root.panel-title; color: Palette.foreground; font-size: 14px; font-weight: 700; letter-spacing: 0.3px; }
                        Text { text: root.panel-hint; color: Palette.foreground.transparentize(40%); font-size: 11px; wrap: word-wrap; }
                        if root.actions.length > 0 : VerticalLayout {
                            spacing: 4px; padding-top: 8px;
                            for action[i] in root.actions : Button { text: action.label; clicked => { root.clicked(i); } }
                        }
                    }
                }

                // ── Edit mode: left sidebar ──────────────────────
                if root.active-panel-id == 1 : Rectangle {
                    width: 240px;
                    background: Palette.alternate-background;
                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 6px;

                        // Components
                        HorizontalLayout {
                            spacing: 6px; alignment: start;
                            Image { source: @image-url("icons/plus.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                            Text { text: "Components"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 1px;
                                for comp[i] in root.component-palette : Rectangle {
                                    height: 36px;
                                    background: palette-touch.has-hover ? Palette.control-background : transparent;
                                    border-radius: 4px;
                                    HorizontalLayout {
                                        padding-left: 10px; padding-right: 10px; spacing: 8px; alignment: start;
                                        VerticalLayout {
                                            alignment: center;
                                            if comp.component-type == "heading" || comp.component-type == "text" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "link" : Image { source: @image-url("icons/link.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "image" : Image { source: @image-url("icons/image.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "container" || comp.component-type == "form" || comp.component-type == "button" : Image { source: @image-url("icons/box.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "card" : Image { source: @image-url("icons/box.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "columns" : Image { source: @image-url("icons/columns.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "list" : Image { source: @image-url("icons/list.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "table" : Image { source: @image-url("icons/table.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "tabs" : Image { source: @image-url("icons/layout.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "accordion" : Image { source: @image-url("icons/chevron-down.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "divider" : Image { source: @image-url("icons/minus.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "spacer" : Image { source: @image-url("icons/grip.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "code" : Image { source: @image-url("icons/code.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "input" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Text { text: comp.label; color: Palette.foreground; font-size: 12px; font-weight: 500; }
                                        }
                                    }
                                    palette-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.add-component(comp.component-type); }
                                        changed has-hover => {
                                            if (self.has-hover) {
                                                root.help-hover("builder.components." + comp.component-type, parent.absolute-position.x + parent.width + 8px, parent.absolute-position.y);
                                            }
                                            if (!self.has-hover) { root.help-leave(); }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }

                        // Layers
                        HorizontalLayout {
                            spacing: 6px; alignment: start;
                            Image { source: @image-url("icons/tree.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                            Text { text: "Layers"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 1px;
                                for node[i] in root.inspector-nodes : InspectorRow {
                                    node-id: node.id;
                                    component-id: node.component-id;
                                    depth: node.depth;
                                    selected: node.selected;
                                    clicked => { root.node-clicked(node.id); }
                                    move-up => { root.node-move-up(node.id); }
                                    move-down => { root.node-move-down(node.id); }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }

                        // Search
                        HorizontalLayout {
                            spacing: 6px;
                            Image { source: @image-url("icons/search.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(50%); y: 7px; }
                            LineEdit { height: 28px; horizontal-stretch: 1; text: root.search-query; placeholder-text: "Search nodes..."; edited(text) => { root.search-input(text); } }
                        }

                        if root.search-results.length > 0 : VerticalLayout {
                            spacing: 2px;
                            for result[i] in root.search-results : Rectangle {
                                height: 44px; background: Palette.control-background; border-radius: 4px;
                                VerticalLayout {
                                    padding: 6px; spacing: 2px;
                                    Text { text: result.node-id + " · " + result.field; color: Palette.foreground; font-size: 11px; overflow: elide; }
                                    Text { text: result.snippet; color: Palette.foreground.transparentize(30%); font-size: 10px; overflow: elide; }
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.search-result-clicked(result.node-id); } }
                            }
                        }
                    }
                }

                // ── Docs sidebar (overlays panel sidebar) ──────
                if root.docs-panel.visible : Rectangle {
                    width: 280px;
                    background: Palette.alternate-background;
                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }

                    VerticalLayout {
                        padding: 16px;
                        spacing: 0px;

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;

                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                background: docs-back-touch.has-hover ? Palette.control-background : transparent;
                                Image {
                                    source: @image-url("icons/chevron-left.svg");
                                    width: 16px;
                                    height: 16px;
                                    colorize: docs-back-touch.has-hover ? Palette.foreground : Palette.foreground.transparentize(30%);
                                }
                                docs-back-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.docs-panel-close(); }
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "Documentation";
                                    color: Palette.foreground;
                                    font-size: 14px;
                                    font-weight: 700;
                                }
                            }
                        }

                        Rectangle { height: 12px; }
                        Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                        Rectangle { height: 12px; }

                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 0px;
                                alignment: start;

                                DocsContent {
                                    doc-title: root.docs-panel.title;
                                    doc-summary: root.docs-panel.summary;
                                    doc-body: root.docs-panel.body;
                                    compact: true;
                                }

                                Rectangle { height: 16px; }

                                Rectangle {
                                    height: 36px;
                                    border-radius: 6px;
                                    background: docs-open-touch.has-hover ? Palette.accent-background.transparentize(85%) : transparent;
                                    border-width: 1px;
                                    border-color: Palette.accent-background.transparentize(50%);

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        spacing: 6px;
                                        alignment: start;

                                        Image {
                                            source: @image-url("icons/book.svg");
                                            width: 14px;
                                            height: 14px;
                                            colorize: Palette.accent-background;
                                        }

                                        Text {
                                            text: "Open in Docs";
                                            color: Palette.accent-background;
                                            font-size: 12px;
                                            font-weight: 500;
                                            vertical-alignment: center;
                                        }
                                    }

                                    docs-open-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.docs-open-full(); }
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Main content area ────────────────────────────
                VerticalLayout {
                    horizontal-stretch: 1;

                    // Tab bar
                    if root.tabs.length > 0 : Rectangle {
                        height: 36px;
                        background: Palette.alternate-background;
                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            spacing: 0px; padding-left: 0px; alignment: start;
                            for tab[i] in root.tabs : Rectangle {
                                height: 35px; min-width: 120px; max-width: 200px;
                                background: tab.active ? Palette.background : Palette.alternate-background;
                                Rectangle { x: 0px; y: parent.height - 2px; width: parent.width; height: 2px; background: tab.active ? Palette.accent-background : transparent; }
                                HorizontalLayout {
                                    padding-left: 14px; padding-right: 8px; spacing: 8px; alignment: start;
                                    Text { text: tab.title; color: tab.active ? Palette.foreground : Palette.foreground.transparentize(40%); font-size: 12px; vertical-alignment: center; overflow: elide; }
                                    IconButton { icon: @image-url("icons/x.svg"); clicked => { root.tab-closed(tab.id); } }
                                }
                                tab-touch := TouchArea {
                                    clicked => { root.tab-activated(tab.id); }
                                    changed has-hover => {
                                        if (self.has-hover) {
                                            root.help-hover("shell.tabs", parent.absolute-position.x + parent.width / 2, parent.absolute-position.y + parent.height + 4px);
                                        }
                                        if (!self.has-hover) { root.help-leave(); }
                                    }
                                }
                            }
                        }
                    }

                    // Toolbar (Edit mode)
                    if root.active-panel-id == 1 : Rectangle {
                        height: 40px;
                        background: Palette.background;
                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; spacing: 4px; alignment: start;
                            IconButton { icon: @image-url("icons/undo.svg"); enabled: root.can-undo; help-id: "shell.toolbar.undo"; clicked => { root.undo-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/redo.svg"); enabled: root.can-redo; help-id: "shell.toolbar.redo"; clicked => { root.redo-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            ToolbarSeparator { }
                            IconButton { icon: @image-url("icons/copy.svg"); enabled: root.has-selection; help-id: "shell.toolbar.copy"; clicked => { root.copy-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/scissors.svg"); enabled: root.has-selection; help-id: "shell.toolbar.cut"; clicked => { root.cut-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/paste.svg"); enabled: root.has-clipboard; help-id: "shell.toolbar.paste"; clicked => { root.paste-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/duplicate.svg"); enabled: root.has-selection; help-id: "shell.toolbar.duplicate"; clicked => { root.duplicate-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            ToolbarSeparator { }
                            IconButton { icon: @image-url("icons/chevron-up.svg"); enabled: root.has-selection; help-id: "shell.toolbar.move-up"; clicked => { root.node-move-up(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/chevron-down.svg"); enabled: root.has-selection; help-id: "shell.toolbar.move-down"; clicked => { root.node-move-down(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            ToolbarSeparator { }
                            IconButton { icon: @image-url("icons/trash.svg"); enabled: root.has-selection; help-id: "shell.toolbar.delete"; clicked => { root.builder-delete-node(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            Rectangle { horizontal-stretch: 1; }
                            Text { text: root.builder-node-count + " nodes"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                        }
                    }

                    // Breadcrumbs (Edit mode + selection)
                    if root.active-panel-id == 1 && root.breadcrumbs.length > 0 : Rectangle {
                        height: 28px;
                        background: Palette.background;
                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            padding-left: 16px; padding-right: 16px; spacing: 0px; alignment: start;
                            for bc in root.breadcrumbs : Rectangle {
                                height: 28px;
                                background: transparent;
                                HorizontalLayout {
                                    spacing: 4px; alignment: start;
                                    if bc.has-separator : Text { text: " › "; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                                    Text { text: bc.label; color: bc-touch.has-hover ? Palette.accent-foreground : Palette.foreground.transparentize(30%); font-size: 11px; vertical-alignment: center; }
                                }
                                bc-touch := TouchArea { mouse-cursor: pointer; clicked => { root.breadcrumb-clicked(bc.id); } }
                            }
                        }
                    }

                    // Canvas / content
                    Rectangle {
                        background: Palette.background;
                        vertical-stretch: 1;

                        // ── Docs full view ───────────────────────
                        if root.docs-view.visible : ScrollView {
                            VerticalLayout {
                                padding: 48px;
                                padding-top: 32px;
                                spacing: 0px;
                                alignment: start;

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;

                                    Rectangle {
                                        width: 28px;
                                        height: 28px;
                                        border-radius: 6px;
                                        background: docs-view-back.has-hover ? Palette.control-background : transparent;
                                        Image {
                                            source: @image-url("icons/chevron-left.svg");
                                            width: 16px;
                                            height: 16px;
                                            colorize: docs-view-back.has-hover ? Palette.foreground : Palette.foreground.transparentize(30%);
                                        }
                                        docs-view-back := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.docs-view-close(); }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "Back to editor";
                                            color: Palette.foreground.transparentize(40%);
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Rectangle { height: 24px; }

                                DocsContent {
                                    doc-title: root.docs-view.title;
                                    doc-summary: root.docs-view.summary;
                                    doc-body: root.docs-view.body;
                                    compact: false;
                                }
                            }
                        }

                        // ── Builder canvas ───────────────────────
                        if !root.docs-view.visible : ScrollView {
                            VerticalLayout {
                                padding: 24px; spacing: 4px; alignment: start;

                                if root.active-panel-id == 1 && root.builder-nodes.length > 0 : VerticalLayout {
                                    spacing: 2px;
                                    for bnode[i] in root.builder-nodes : BuilderBlock {
                                        node-id: bnode.id; component-type: bnode.component-type; selected: bnode.selected; depth: bnode.depth;
                                        text: bnode.text; level: bnode.level; href: bnode.href; alt: bnode.alt;
                                        placeholder: bnode.placeholder; label: bnode.label; disabled: bnode.disabled;
                                        clicked(id) => { root.builder-node-clicked(id); }
                                        text-edited(id, val) => { root.builder-text-edited(id, val); }
                                        delete-clicked(id) => { root.builder-delete-node(id); }
                                    }
                                }

                                if root.active-panel-id == 1 && root.builder-nodes.length == 0 : VerticalLayout {
                                    alignment: center; spacing: 8px; padding-top: 80px;
                                    Text { text: "Empty document"; color: Palette.foreground.transparentize(50%); font-size: 16px; horizontal-alignment: center; }
                                    Text { text: "Add a component from the palette to get started."; color: Palette.foreground.transparentize(60%); font-size: 12px; horizontal-alignment: center; }
                                }

                                if root.active-panel-id == 0 : VerticalLayout {
                                    spacing: 12px;
                                    Text { text: "Welcome to Prism Studio"; color: Palette.foreground; font-size: 20px; font-weight: 600; }
                                    Text { text: "Select an action from the sidebar to get started."; color: Palette.foreground.transparentize(40%); font-size: 14px; wrap: word-wrap; }
                                }
                            }
                        }

                        // ── Code editor ─────────────────────────────
                        if root.active-panel-id == 2 && !root.docs-view.visible : Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            background: #1a1e28;

                            HorizontalLayout {
                                spacing: 0px;

                                // Gutter (line numbers)
                                Rectangle {
                                    width: 52px;
                                    background: #151821;
                                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: #ffffff10; }
                                    VerticalLayout {
                                        padding-top: 10px;
                                        padding-right: 12px;
                                        alignment: start;
                                        Text {
                                            text: {
                                                // Generate line numbers from the editor text
                                                @tr("1")
                                            }
                                            color: #ffffff30;
                                            font-size: 13px;
                                            font-family: "monospace";
                                            horizontal-alignment: right;
                                        }
                                    }
                                }

                                // Editor area
                                editor-input := TextEdit {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    text: root.editor-text;
                                    font-size: 13px;
                                    font-family: "monospace";
                                    edited(text) => { root.editor-text-changed(text); }
                                }
                            }
                        }
                    }

                    // Status bar
                    Rectangle {
                        height: 26px;
                        background: Palette.alternate-background;
                        Rectangle { x: 0px; y: 0px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                            Text { text: root.panel-title; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                            if root.has-selection : Text { text: "·"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.has-selection : Text { text: "Selected"; color: Palette.accent-foreground; font-size: 11px; vertical-alignment: center; }
                            Rectangle { horizontal-stretch: 1; }
                            Text { text: "Prism Studio"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                        }
                    }
                }

                // ── Edit mode: right sidebar (properties) ────────
                if root.active-panel-id == 1 : Rectangle {
                    width: 280px;
                    background: Palette.alternate-background;
                    Rectangle { x: 0px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }

                    VerticalLayout {
                        padding: 16px; spacing: 8px; alignment: start;

                        Text { text: "Properties"; color: Palette.foreground; font-size: 14px; font-weight: 700; }

                        if root.has-selection && root.selected-component != "" : VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 6px; alignment: start;
                                Image { source: @image-url("icons/sliders.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); y: 1px; }
                                Text { text: root.selected-component; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                            }
                            ScrollView {
                                vertical-stretch: 1;
                                VerticalLayout {
                                    spacing: 4px;
                                    for field[i] in root.field-rows : FieldEditor {
                                        key: field.key; label: field.label; kind: field.kind; value: field.value; required: field.required;
                                        field-edited(key, val) => { root.field-edited(key, val); }
                                    }
                                }
                            }
                        }

                        if !root.has-selection : VerticalLayout {
                            spacing: 8px; padding-top: 24px;
                            Text { text: "No selection"; color: Palette.foreground.transparentize(40%); font-size: 13px; font-weight: 500; horizontal-alignment: center; }
                            Text { text: "Select an element on the canvas or in the layers panel to edit its properties."; color: Palette.foreground.transparentize(60%); font-size: 11px; wrap: word-wrap; horizontal-alignment: center; }
                        }
                    }
                }
            }
        }
    }

    // ── Command palette ───────────────────────────────────────────
    if root.command-palette-visible : Rectangle { width: 100%; height: 100%; background: #00000060; TouchArea { clicked => { root.toggle-command-palette(); } } }
    if root.command-palette-visible : Rectangle {
        x: (root.width - 500px) / 2; y: 64px; width: 500px;
        height: min(root.command-results.length * 36px + 48px, 420px);
        background: Palette.alternate-background; border-radius: 8px; border-width: 1px; border-color: Palette.accent-background; clip: true;
        VerticalLayout {
            padding: 8px; spacing: 4px;
            HorizontalLayout {
                spacing: 8px;
                Image { source: @image-url("icons/search.svg"); width: 16px; height: 16px; colorize: Palette.foreground.transparentize(40%); y: 8px; }
                LineEdit { height: 32px; horizontal-stretch: 1; placeholder-text: "Type a command..."; edited(text) => { root.command-palette-input(text); } accepted(text) => { if (root.command-results.length > 0) { root.command-selected(0); } } }
            }
            ScrollView {
                VerticalLayout {
                    spacing: 1px;
                    for cmd[i] in root.command-results : Rectangle {
                        height: 32px; background: cmd-touch.has-hover ? Palette.control-background : transparent; border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; alignment: space-between;
                            HorizontalLayout {
                                spacing: 8px;
                                if cmd.category != "" : Text { text: cmd.category; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                                Text { text: cmd.label; color: Palette.foreground; font-size: 13px; vertical-alignment: center; }
                            }
                            if cmd.shortcut != "" : Rectangle {
                                background: Palette.control-background; border-radius: 3px; height: 20px; width: shortcut-text.preferred-width + 12px; y: 6px;
                                shortcut-text := Text { text: cmd.shortcut; color: Palette.foreground.transparentize(30%); font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                        cmd-touch := TouchArea { mouse-cursor: pointer; clicked => { root.command-selected(i); } }
                    }
                }
            }
        }
    }

    // ── Toasts ────────────────────────────────────────────────────
    if root.notifications.length > 0 : VerticalLayout {
        x: root.width - 340px; y: root.height - root.notifications.length * 100px - 20px; width: 320px; spacing: 8px;
        for notif[i] in root.notifications : Toast { title: notif.title; body: notif.body; kind: notif.kind; dismissed => { root.dismiss-notification(notif.id); } }
    }

    // ── Help tooltip ──────────────────────────────────────────────
    if root.help-tooltip.visible : Rectangle {
        x: min(root.help-tooltip.tip-x, root.width - 284px);
        y: min(root.help-tooltip.tip-y, root.height - tooltip-layout.preferred-height - 8px);
        width: 276px;
        height: tooltip-layout.preferred-height;
        border-radius: 10px; border-width: 1px;
        border-color: Palette.foreground.transparentize(85%);
        background: Palette.alternate-background; clip: true;

        // Behind everything: keeps tooltip alive on hover
        help-tip-touch := TouchArea {
            changed has-hover => {
                if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                if (!self.has-hover) { root.help-leave(); }
            }
        }

        tooltip-layout := VerticalLayout {
            Rectangle {
                height: 32px;
                HorizontalLayout {
                    padding: 8px; padding-left: 12px; spacing: 8px; alignment: start;
                    Image { source: @image-url("icons/help-circle.svg"); width: 12px; height: 12px; colorize: tooltip-header-touch.has-hover ? Palette.accent-foreground : Palette.accent-background; y: 2px; }
                    Text { text: root.help-tooltip.title; color: tooltip-header-touch.has-hover ? Palette.accent-foreground : Palette.foreground; font-size: 12px; font-weight: 600; vertical-alignment: center; overflow: elide; }
                }
                tooltip-header-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.help-entry-clicked(); }
                    changed has-hover => {
                        if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                        if (!self.has-hover) { root.help-leave(); }
                    }
                }
            }
            Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
            Rectangle {
                VerticalLayout {
                    padding: 10px; padding-left: 12px; padding-right: 12px;
                    Text { text: root.help-tooltip.summary; color: Palette.foreground.transparentize(30%); font-size: 12px; wrap: word-wrap; }
                }
            }
            if root.help-tooltip.has-docs && !root.docs-panel.visible && !root.docs-view.visible : Rectangle {
                height: 32px;
                Rectangle { y: 0px; height: 1px; width: parent.width; background: Palette.foreground.transparentize(85%); }
                HorizontalLayout {
                    padding: 8px; padding-left: 12px; spacing: 6px; alignment: start;
                    Image { source: @image-url("icons/book.svg"); width: 11px; height: 11px; colorize: Palette.accent-background; }
                    Text { text: "Open in Docs"; color: Palette.accent-background; font-size: 12px; }
                }
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.help-docs-clicked(); }
                    changed has-hover => {
                        if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                        if (!self.has-hover) { root.help-leave(); }
                    }
                }
            }
        }
    }
}
