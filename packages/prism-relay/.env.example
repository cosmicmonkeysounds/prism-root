# Prism Relay — Environment Configuration
# Copy to .env and adjust values for your deployment.

# Deployment mode: server | p2p | dev
PRISM_RELAY_MODE=server

# Bind address (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
PRISM_RELAY_HOST=0.0.0.0

# Listen port
PRISM_RELAY_PORT=4444

# Data directory (identity, state, logs)
# PRISM_RELAY_DATA_DIR=/var/lib/prism-relay

# Public URL — required for federation and sovereign portals
# PRISM_RELAY_PUBLIC_URL=https://relay.example.com

# Log level: debug | info | warn | error
PRISM_RELAY_LOG_LEVEL=info
