{
  "name": "prism",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "description": "Prism Framework monorepo. The Clay migration retired the last JS packages on 2026-04-15 — every crate (daemon, core, builder, shell, studio, cli, relay) now lives in the top-level Cargo workspace. pnpm stays as the umbrella runner + lint-staged host only.",
  "scripts": {
    "prism": "cargo run -q -p prism-cli --",
    "dev": "cargo run -q -p prism-cli -- dev shell",
    "dev:web": "cargo run -q -p prism-cli -- dev web",
    "dev:studio": "cargo run -q -p prism-cli -- dev studio",
    "dev:relay": "cargo run -q -p prism-cli -- dev relay",
    "dev:all": "cargo run -q -p prism-cli -- dev all",
    "build": "cargo run -q -p prism-cli -- build",
    "build:web": "cargo run -q -p prism-cli -- build --target web",
    "build:relay": "cargo run -q -p prism-cli -- build --target relay",
    "test": "cargo run -q -p prism-cli -- test",
    "lint": "cargo run -q -p prism-cli -- lint",
    "format": "cargo run -q -p prism-cli -- fmt",
    "format:check": "cargo run -q -p prism-cli -- fmt --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "*.rs": [
      "cargo fmt --"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
