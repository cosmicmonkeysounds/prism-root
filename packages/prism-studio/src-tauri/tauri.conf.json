{
  "$schema": "https://raw.githubusercontent.com/nicholasgasior/tauri/tauri-v2.0.0/crates/tauri-utils/schema.json",
  "productName": "Prism Studio",
  "version": "0.1.0",
  "identifier": "com.prism.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Prism Studio",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
