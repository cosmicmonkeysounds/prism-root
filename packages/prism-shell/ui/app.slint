import { Button, LineEdit, Switch, ComboBox, ListView, ScrollView,
         VerticalBox, HorizontalBox, GroupBox, Palette, TabWidget } from "std-widgets.slint";

// ── Data structs ───────────────────────────────────────────────────

struct ButtonSpec {
    label: string,
}

struct PanelNavItem {
    id: int,
    label: string,
    selected: bool,
}

struct FieldRow {
    key: string,
    label: string,
    kind: string,
    value: string,
    required: bool,
}

struct TabItem {
    id: int,
    title: string,
    active: bool,
}

struct CommandItem {
    label: string,
    shortcut: string,
    category: string,
}

struct ToastItem {
    id: int,
    title: string,
    body: string,
    kind: string,
}

struct InspectorNode {
    id: string,
    component-id: string,
    depth: int,
    selected: bool,
}

struct SearchResultItem {
    node-id: string,
    component-type: string,
    field: string,
    snippet: string,
}

struct ComponentPaletteItem {
    component-type: string,
    label: string,
    description: string,
}

struct BuilderNode {
    id: string,
    component-type: string,
    selected: bool,
    depth: int,
    // Common content fields
    text: string,
    level: int,
    href: string,
    alt: string,
    placeholder: string,
    label: string,
    disabled: bool,
}

// ── Builder block components ──────────────────────────────────────

component BuilderBlock inherits Rectangle {
    in property <string> node-id;
    in property <string> component-type;
    in property <bool> selected;
    in property <int> depth;
    in property <string> text;
    in property <int> level;
    in property <string> href;
    in property <string> alt;
    in property <string> placeholder;
    in property <string> label;
    in property <bool> disabled;
    callback clicked(string);
    callback text-edited(string, string);
    callback delete-clicked(string);

    border-radius: 4px;
    border-width: root.selected ? 2px : 0px;
    border-color: Palette.accent-background;
    background: root.selected ? Palette.accent-background.transparentize(90%) : transparent;

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 1;
            padding-left: root.depth * 16px + 8px;
            padding-right: 8px;
            padding-top: 4px;
            padding-bottom: 4px;

            // heading — editable when selected
            if root.component-type == "heading" && !root.selected : Text {
                text: root.text;
                color: Palette.foreground;
                font-size: root.level <= 1 ? 32px :
                           root.level == 2 ? 26px :
                           root.level == 3 ? 22px :
                           root.level == 4 ? 18px :
                           root.level == 5 ? 16px : 14px;
                font-weight: 700;
                wrap: word-wrap;
            }
            if root.component-type == "heading" && root.selected : LineEdit {
                height: root.level <= 1 ? 40px :
                        root.level == 2 ? 34px :
                        root.level == 3 ? 30px : 28px;
                text: root.text;
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            // text (paragraph) — editable when selected
            if root.component-type == "text" && !root.selected : Text {
                text: root.text;
                color: Palette.foreground;
                font-size: 14px;
                wrap: word-wrap;
            }
            if root.component-type == "text" && root.selected : LineEdit {
                height: 28px;
                text: root.text;
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            // link
            if root.component-type == "link" : Text {
                text: root.text != "" ? root.text : root.href;
                color: Palette.accent-foreground;
                font-size: 14px;
            }

            // image placeholder
            if root.component-type == "image" : Rectangle {
                min-height: 80px;
                background: Palette.control-background;
                border-radius: 6px;
                Text {
                    text: root.alt != "" ? root.alt : "image";
                    color: Palette.foreground.transparentize(40%);
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // container (shows as a subtle grouping indicator)
            if root.component-type == "container" : Rectangle {
                height: 4px;
            }

            // form
            if root.component-type == "form" : Text {
                text: "Form";
                color: Palette.foreground.transparentize(40%);
                font-size: 11px;
                font-weight: 600;
            }

            // input
            if root.component-type == "input" : VerticalLayout {
                spacing: 4px;
                if root.label != "" : Text {
                    text: root.label;
                    color: Palette.foreground;
                    font-size: 12px;
                }
                LineEdit {
                    height: 28px;
                    placeholder-text: root.placeholder != "" ? root.placeholder : root.text;
                    enabled: false;
                }
            }

            // button
            if root.component-type == "button" : HorizontalLayout {
                alignment: start;
                Button {
                    text: root.text != "" ? root.text : "Button";
                    enabled: !root.disabled;
                }
            }

            // card
            if root.component-type == "card" : Rectangle {
                border-width: 1px;
                border-color: Palette.control-background;
                border-radius: 8px;
                background: Palette.alternate-background;
                min-height: 48px;

                VerticalLayout {
                    padding: 12px;
                    spacing: 4px;
                    Text {
                        text: root.text != "" ? root.text : "Card";
                        color: Palette.foreground;
                        font-size: 16px;
                        font-weight: 600;
                    }
                    if root.label != "" : Text {
                        text: root.label;
                        color: Palette.foreground.transparentize(30%);
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                }
            }

            // code
            if root.component-type == "code" : Rectangle {
                background: Palette.control-background;
                border-radius: 6px;
                min-height: 36px;

                VerticalLayout {
                    padding: 10px;
                    Text {
                        text: root.text != "" ? root.text : "// code";
                        color: Palette.foreground.transparentize(20%);
                        font-size: 13px;
                        font-family: "monospace";
                        wrap: word-wrap;
                    }
                }
            }

            // divider
            if root.component-type == "divider" : Rectangle {
                height: 1px;
                background: Palette.foreground.transparentize(70%);
            }

            // spacer
            if root.component-type == "spacer" : Rectangle {
                height: root.level > 0 ? root.level * 1px : 24px;
                border-width: 1px;
                border-color: Palette.foreground.transparentize(85%);
                border-radius: 2px;
            }

            // columns
            if root.component-type == "columns" : HorizontalLayout {
                spacing: 4px;
                alignment: start;
                Text {
                    text: "Columns";
                    color: Palette.foreground.transparentize(40%);
                    font-size: 11px;
                    font-weight: 600;
                }
                Text {
                    text: root.level > 0 ? "gap: " + root.level + "px" : "gap: 16px";
                    color: Palette.foreground.transparentize(60%);
                    font-size: 10px;
                }
            }

            // list
            if root.component-type == "list" : Text {
                text: root.disabled ? "Ordered List (ol)" : "Unordered List (ul)";
                color: Palette.foreground.transparentize(40%);
                font-size: 11px;
                font-weight: 600;
            }

            // table
            if root.component-type == "table" : Rectangle {
                border-width: 1px;
                border-color: Palette.control-background;
                border-radius: 4px;
                min-height: 32px;

                VerticalLayout {
                    padding: 8px;
                    spacing: 4px;
                    if root.label != "" : Text {
                        text: root.label;
                        color: Palette.foreground.transparentize(40%);
                        font-size: 11px;
                    }
                    Text {
                        text: root.text != "" ? "⊞ " + root.text : "⊞ Table";
                        color: Palette.foreground;
                        font-size: 12px;
                        font-weight: 600;
                    }
                }
            }

            // tabs
            if root.component-type == "tabs" : HorizontalLayout {
                spacing: 4px;
                alignment: start;
                Text {
                    text: root.text != "" ? "⊟ " + root.text : "⊟ Tabs";
                    color: Palette.foreground.transparentize(30%);
                    font-size: 12px;
                    font-weight: 500;
                }
            }

            // accordion
            if root.component-type == "accordion" : Rectangle {
                background: Palette.alternate-background;
                border-radius: 4px;
                min-height: 28px;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    alignment: start;
                    Text {
                        text: "▸";
                        color: Palette.foreground.transparentize(40%);
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.text != "" ? root.text : "Accordion";
                        color: Palette.foreground;
                        font-size: 13px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Delete button on selected nodes
        if root.selected : VerticalLayout {
            alignment: start;
            padding-top: 4px;
            padding-right: 4px;
            Button {
                text: "×";
                clicked => { root.delete-clicked(root.node-id); }
            }
        }
    }

    TouchArea {
        clicked => { root.clicked(root.node-id); }
    }
}

// ── Reusable components ────────────────────────────────────────────

component NavButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked;

    width: 48px;
    height: 48px;
    background: selected ? Palette.accent-background : transparent;

    Rectangle {
        x: 0px;
        y: 0px;
        width: 3px;
        height: parent.height;
        background: root.selected ? Palette.accent-background : transparent;
    }

    Text {
        text: root.label;
        color: root.selected ? Palette.accent-foreground : Palette.foreground;
        font-size: 18px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component FieldEditor inherits Rectangle {
    in property <string> key;
    in property <string> label;
    in property <string> kind;
    in property <string> value;
    in property <bool> required;
    callback field-edited(string, string);

    height: 64px;
    background: transparent;

    VerticalLayout {
        spacing: 2px;
        padding-top: 4px;
        padding-bottom: 4px;

        Text {
            text: root.required ? root.label + " *" : root.label;
            color: Palette.foreground;
            font-size: 12px;
        }

        if root.kind == "boolean" : HorizontalLayout {
            alignment: start;
            height: 24px;
            Switch {
                checked: root.value == "true";
                toggled => {
                    root.field-edited(root.key, self.checked ? "true" : "false");
                }
            }
        }

        if root.kind != "boolean" : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => {
                root.field-edited(root.key, text);
            }
        }

        Text {
            text: root.kind + " · " + root.key;
            color: Palette.foreground.transparentize(50%);
            font-size: 10px;
        }
    }
}

component InspectorRow inherits Rectangle {
    in property <string> node-id;
    in property <string> component-id;
    in property <int> depth;
    in property <bool> selected;
    callback clicked;
    callback move-up;
    callback move-down;

    height: 28px;
    background: selected ? Palette.accent-background : transparent;
    border-radius: 3px;

    HorizontalLayout {
        padding-left: root.depth * 16px + 12px;
        padding-right: 8px;
        alignment: space-between;

        Text {
            text: root.node-id + " · " + root.component-id;
            color: root.selected ? Palette.accent-foreground : Palette.foreground.transparentize(30%);
            font-size: 12px;
            font-family: "monospace";
            vertical-alignment: center;
        }

        if root.selected : HorizontalLayout {
            spacing: 2px;
            width: 56px;
            Button {
                text: "↑";
                clicked => { root.move-up(); }
            }
            Button {
                text: "↓";
                clicked => { root.move-down(); }
            }
        }
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component Toast inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> kind;
    callback dismissed;

    property <color> kind-color: root.kind == "error" ? #dc3c3c :
                                  root.kind == "warning" ? #dcaa3c :
                                  root.kind == "success" ? #3cdc6e :
                                  Palette.accent-background;

    width: 320px;
    background: Palette.alternate-background;
    border-radius: 8px;
    border-width: 1px;
    border-color: kind-color;
    clip: true;

    VerticalLayout {
        padding: 12px;
        spacing: 4px;

        HorizontalLayout {
            spacing: 8px;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: root.kind-color;
                y: 6px;
            }
            Text {
                text: root.title;
                color: Palette.foreground;
                font-size: 13px;
                font-weight: 600;
                overflow: elide;
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                text: "×";
                clicked => { root.dismissed(); }
            }
        }

        if root.body != "" : Text {
            text: root.body;
            color: Palette.foreground.transparentize(30%);
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}

// ── Root component ─────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Prism Shell";
    preferred-width: 1280px;
    preferred-height: 800px;

    // Sidebar navigation
    in property <[PanelNavItem]> nav-items: [];
    callback select-panel(int);

    // Identity panel
    in property <[ButtonSpec]> actions: [];
    callback clicked(int);

    // Builder panel — live preview
    in property <[BuilderNode]> builder-nodes: [];
    in property <int> builder-node-count: 0;
    callback builder-node-clicked(string);
    callback builder-text-edited(string, string);
    callback builder-delete-node(string);
    // Legacy DSL source (kept for debug view)
    in property <string> builder-source: "";

    // Component palette
    in property <[ComponentPaletteItem]> component-palette: [];
    callback add-component(string);

    // Inspector panel
    in property <string> inspector-tree: "";
    in property <[InspectorNode]> inspector-nodes: [];
    callback node-clicked(string);
    callback node-move-up(string);
    callback node-move-down(string);

    // Properties panel
    in property <string> selected-component: "";
    in property <[FieldRow]> field-rows: [];
    callback field-edited(string, string);

    // Tabbed MDI
    in property <[TabItem]> tabs: [];
    callback tab-activated(int);
    callback tab-closed(int);

    // Command palette
    in property <bool> command-palette-visible: false;
    in property <[CommandItem]> command-results: [];
    callback toggle-command-palette();
    callback command-palette-input(string);
    callback command-selected(int);

    // Notifications
    in property <[ToastItem]> notifications: [];
    callback dismiss-notification(int);

    // Undo/redo
    in property <bool> can-undo: false;
    in property <bool> can-redo: false;
    in property <string> undo-label: "";
    in property <string> redo-label: "";
    callback undo-clicked;
    callback redo-clicked;

    // Search
    in property <string> search-query: "";
    in property <[SearchResultItem]> search-results: [];
    callback search-input(string);
    callback search-result-clicked(string);

    // Keyboard
    callback escape-pressed;
    callback search-focus;
    in property <string> panel-title: "Identity";
    in property <string> panel-hint: "Select an action from the sidebar.";

    background: Palette.background;

    // Global keyboard handler
    fs := FocusScope {
        width: 100%;
        height: 100%;

        key-pressed(event) => {
            if (event.modifiers.control && event.modifiers.shift && event.text == "P") {
                root.toggle-command-palette();
                return accept;
            }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{001a}") {
                root.undo-clicked();
                return accept;
            }
            if (event.modifiers.control && event.modifiers.shift && event.text == "\u{001a}") {
                root.redo-clicked();
                return accept;
            }
            if (event.modifiers.control && event.text == "\u{0006}") {
                root.search-focus();
                return accept;
            }
            if (event.text == Key.Escape) {
                root.escape-pressed();
                return accept;
            }
            return reject;
        }

        VerticalLayout {
            // Main content area
            HorizontalLayout {
                spacing: 0px;
                vertical-stretch: 1;

                // Activity bar (leftmost icon strip)
                Rectangle {
                    width: 48px;
                    background: Palette.background;

                    VerticalLayout {
                        padding-top: 8px;
                        spacing: 0px;
                        alignment: start;

                        for nav[i] in root.nav-items : NavButton {
                            label: nav.label;
                            selected: nav.selected;
                            clicked => { root.select-panel(nav.id); }
                        }
                    }
                }

                // Sidebar
                Rectangle {
                    width: 200px;
                    background: Palette.alternate-background;

                    VerticalLayout {
                        padding: 16px;
                        spacing: 8px;
                        alignment: start;

                        Text {
                            text: root.panel-title;
                            color: Palette.foreground;
                            font-size: 16px;
                            font-weight: 600;
                        }

                        Text {
                            text: root.panel-hint;
                            color: Palette.foreground.transparentize(30%);
                            font-size: 11px;
                            wrap: word-wrap;
                        }

                        // Identity panel actions in sidebar
                        if root.actions.length > 0 : VerticalLayout {
                            spacing: 4px;
                            padding-top: 8px;
                            for action[i] in root.actions : Button {
                                text: action.label;
                                clicked => { root.clicked(i); }
                            }
                        }

                        // Component palette in sidebar (builder panel)
                        if root.component-palette.length > 0 : VerticalLayout {
                            spacing: 2px;
                            padding-top: 8px;

                            Text {
                                text: "Add Component";
                                color: Palette.foreground.transparentize(30%);
                                font-size: 11px;
                                font-weight: 600;
                            }

                            for comp[i] in root.component-palette : Rectangle {
                                height: 40px;
                                background: touch-area.has-hover ? Palette.control-background : transparent;
                                border-radius: 4px;

                                VerticalLayout {
                                    padding: 6px;
                                    padding-left: 10px;
                                    spacing: 1px;
                                    Text {
                                        text: comp.label;
                                        color: Palette.foreground;
                                        font-size: 12px;
                                        font-weight: 500;
                                    }
                                    Text {
                                        text: comp.description;
                                        color: Palette.foreground.transparentize(40%);
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }

                                touch-area := TouchArea {
                                    clicked => { root.add-component(comp.component-type); }
                                }
                            }
                        }

                        // Search input
                        LineEdit {
                            height: 28px;
                            text: root.search-query;
                            placeholder-text: "Search…";
                            edited(text) => {
                                root.search-input(text);
                            }
                        }

                        // Search results
                        if root.search-results.length > 0 : VerticalLayout {
                            spacing: 2px;
                            for result[i] in root.search-results : Rectangle {
                                height: 44px;
                                background: Palette.control-background;
                                border-radius: 4px;

                                VerticalLayout {
                                    padding: 6px;
                                    spacing: 2px;
                                    Text {
                                        text: result.node-id + " · " + result.field;
                                        color: Palette.foreground;
                                        font-size: 11px;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: result.snippet;
                                        color: Palette.foreground.transparentize(30%);
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }

                                TouchArea {
                                    clicked => { root.search-result-clicked(result.node-id); }
                                }
                            }
                        }
                    }
                }

                // Main content area
                VerticalLayout {
                    horizontal-stretch: 1;

                    // Tab bar
                    if root.tabs.length > 0 : Rectangle {
                        height: 34px;
                        background: Palette.background;

                        HorizontalLayout {
                            spacing: 1px;
                            padding-left: 0px;
                            alignment: start;

                            for tab[i] in root.tabs : Rectangle {
                                height: 32px;
                                min-width: 120px;
                                max-width: 200px;
                                background: tab.active ? Palette.control-background : Palette.alternate-background;
                                border-radius: 3px;

                                Rectangle {
                                    x: 0px;
                                    y: parent.height - 2px;
                                    width: parent.width;
                                    height: 2px;
                                    background: tab.active ? Palette.accent-background : transparent;
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 4px;
                                    spacing: 4px;
                                    alignment: start;
                                    Text {
                                        text: tab.title;
                                        color: tab.active ? Palette.foreground : Palette.foreground.transparentize(30%);
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Button {
                                        text: "×";
                                        clicked => { root.tab-closed(tab.id); }
                                    }
                                }

                                TouchArea {
                                    clicked => { root.tab-activated(tab.id); }
                                }
                            }
                        }
                    }

                    // Panel content
                    Rectangle {
                        background: Palette.background;
                        vertical-stretch: 1;

                        ScrollView {
                            VerticalLayout {
                                padding: 24px;
                                spacing: 12px;
                                alignment: start;

                                // Builder panel — live preview
                                if root.builder-nodes.length > 0 : VerticalLayout {
                                    spacing: 4px;
                                    for bnode[i] in root.builder-nodes : BuilderBlock {
                                        node-id: bnode.id;
                                        component-type: bnode.component-type;
                                        selected: bnode.selected;
                                        depth: bnode.depth;
                                        text: bnode.text;
                                        level: bnode.level;
                                        href: bnode.href;
                                        alt: bnode.alt;
                                        placeholder: bnode.placeholder;
                                        label: bnode.label;
                                        disabled: bnode.disabled;
                                        clicked(id) => { root.builder-node-clicked(id); }
                                        text-edited(id, val) => { root.builder-text-edited(id, val); }
                                        delete-clicked(id) => { root.builder-delete-node(id); }
                                    }
                                }

                                // Inspector panel surface (structured)
                                if root.inspector-nodes.length > 0 : VerticalLayout {
                                    spacing: 1px;
                                    for node[i] in root.inspector-nodes : InspectorRow {
                                        node-id: node.id;
                                        component-id: node.component-id;
                                        depth: node.depth;
                                        selected: node.selected;
                                        clicked => { root.node-clicked(node.id); }
                                        move-up => { root.node-move-up(node.id); }
                                        move-down => { root.node-move-down(node.id); }
                                    }
                                }

                                // Properties panel surface
                                if root.field-rows.length > 0 : VerticalLayout {
                                    spacing: 4px;
                                    padding-top: 4px;
                                    Text {
                                        text: "Component: " + root.selected-component;
                                        color: Palette.foreground.transparentize(30%);
                                        font-size: 11px;
                                    }
                                    for field[i] in root.field-rows : FieldEditor {
                                        key: field.key;
                                        label: field.label;
                                        kind: field.kind;
                                        value: field.value;
                                        required: field.required;
                                        field-edited(key, val) => { root.field-edited(key, val); }
                                    }
                                }
                            }
                        }
                    }

                    // Status bar
                    Rectangle {
                        height: 28px;
                        background: Palette.alternate-background;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;
                            alignment: start;

                            Button {
                                text: root.undo-label != "" ? "↶ " + root.undo-label : "↶ Undo";
                                enabled: root.can-undo;
                                clicked => { root.undo-clicked(); }
                            }

                            Button {
                                text: root.redo-label != "" ? "↷ " + root.redo-label : "↷ Redo";
                                enabled: root.can-redo;
                                clicked => { root.redo-clicked(); }
                            }

                            Rectangle { horizontal-stretch: 1; }

                            Text {
                                text: "Prism Shell";
                                color: Palette.foreground.transparentize(30%);
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Command palette backdrop + overlay ─────────────────────────
    if root.command-palette-visible : Rectangle {
        width: 100%;
        height: 100%;
        background: #00000060;
        TouchArea {
            clicked => { root.toggle-command-palette(); }
        }
    }

    if root.command-palette-visible : Rectangle {
        x: (root.width - 500px) / 2;
        y: 64px;
        width: 500px;
        height: min(root.command-results.length * 36px + 48px, 420px);
        background: Palette.alternate-background;
        border-radius: 8px;
        border-width: 1px;
        border-color: Palette.accent-background;
        clip: true;

        VerticalLayout {
            padding: 8px;
            spacing: 4px;

            LineEdit {
                height: 32px;
                placeholder-text: "Type a command…";
                edited(text) => { root.command-palette-input(text); }
                accepted(text) => {
                    if (root.command-results.length > 0) {
                        root.command-selected(0);
                    }
                }
            }

            ScrollView {
                VerticalLayout {
                    spacing: 1px;
                    for cmd[i] in root.command-results : Rectangle {
                        height: 32px;
                        background: transparent;
                        border-radius: 4px;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: space-between;

                            HorizontalLayout {
                                spacing: 8px;
                                if cmd.category != "" : Text {
                                    text: cmd.category;
                                    color: Palette.foreground.transparentize(30%);
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: cmd.label;
                                    color: Palette.foreground;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            if cmd.shortcut != "" : Text {
                                text: cmd.shortcut;
                                color: Palette.foreground.transparentize(30%);
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }

                        TouchArea {
                            clicked => { root.command-selected(i); }
                        }
                    }
                }
            }
        }
    }

    // ── Notification toasts ────────────────────────────────────────
    if root.notifications.length > 0 : VerticalLayout {
        x: root.width - 340px;
        y: root.height - root.notifications.length * 100px - 20px;
        width: 320px;
        spacing: 8px;

        for notif[i] in root.notifications : Toast {
            title: notif.title;
            body: notif.body;
            kind: notif.kind;
            dismissed => { root.dismiss-notification(notif.id); }
        }
    }
}
