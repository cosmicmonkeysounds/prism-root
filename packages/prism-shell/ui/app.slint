import { Button, LineEdit, TextEdit, Switch, ComboBox, Slider, ListView, ScrollView,
         VerticalBox, HorizontalBox, GroupBox, Palette, TabWidget } from "std-widgets.slint";

// ── Data structs ───────────────────────────────────────────────────

struct ButtonSpec {
    label: string,
}

struct ColorPreset {
    c: color,
    hex: string,
}

struct FieldRow {
    key: string,
    label: string,
    kind: string,
    value: string,
    required: bool,
    min: float,
    max: float,
    has-bounds: bool,
    options: [string],
    swatch: color,
}

struct TabItem {
    id: int,
    title: string,
    active: bool,
}

struct CommandItem {
    label: string,
    shortcut: string,
    category: string,
}

struct ToastItem {
    id: int,
    title: string,
    body: string,
    kind: string,
}

struct InspectorNode {
    id: string,
    component-id: string,
    depth: int,
    selected: bool,
    kind: string,
}

struct GridEdgeHandle {
    cell-path: string,
    edge: string,
    x: float,
    y: float,
    width: float,
    height: float,
}

struct SearchResultItem {
    node-id: string,
    component-type: string,
    field: string,
    snippet: string,
}

struct ComponentPaletteItem {
    component-type: string,
    label: string,
    description: string,
    category: string,
    is-header: bool,
}

struct PreviewNode {
    id: string,
    component-type: string,
    selected: bool,
    x: float,
    y: float,
    w: float,
    h: float,
    text: string,
    label: string,
    alt: string,
    placeholder: string,
    font-size: float,
    border-radius: float,
    fg: color,
    bg: color,
}

struct HelpTooltipData {
    visible: bool,
    title: string,
    summary: string,
    has-docs: bool,
    tip-x: length,
    tip-y: length,
}

struct BreadcrumbItem {
    id: string,
    label: string,
    has-separator: bool,
}

struct DocsPanelData {
    visible: bool,
    help-id: string,
    title: string,
    summary: string,
    body: string,
}

struct GridCellItem {
    path: string,
    x: float,
    y: float,
    width: float,
    height: float,
    is-empty: bool,
    node-id: string,
    component-type: string,
    selected: bool,
    preview-text: string,
}

struct PageLayoutData {
    page-width: float,
    page-height: float,
    margin-top: float,
    margin-right: float,
    margin-bottom: float,
    margin-left: float,
    column-gap: float,
    row-gap: float,
    cell-count: int,
    show-grid: bool,
    is-responsive: bool,
    page-size-label: string,
}

struct GutterRect {
    offset: float,
    size: float,
}

struct ModifierItem {
    kind: string,
    label: string,
}

struct SignalItem {
    name: string,
    description: string,
}

struct VariantItem {
    key: string,
    label: string,
    selected: string,
    options: [string],
}

struct AppCardItem {
    id: string,
    name: string,
    description: string,
    icon: string,
    accent-color: color,
    page-count: int,
}

struct EditorToken {
    text: string,
    token-color: color,
    col-offset: int,
}

struct EditorIndentGuide {
    depth: int,
    active: bool,
}

struct EditorLine {
    number: int,
    buffer-line: int,
    tokens: [EditorToken],
    indent-guides: [EditorIndentGuide],
    is-current: bool,
    sel-from: int,
    sel-to: int,
    is-foldable: bool,
    is-folded: bool,
    fold-preview: string,
}

struct ExplorerNodeItem {
    id: string,
    label: string,
    kind: string,
    depth: int,
    expanded: bool,
    is-active: bool,
}

struct MenuItem {
    label: string,
    shortcut: string,
    command-id: string,
    enabled: bool,
    is-separator: bool,
}

struct MenuDef {
    label: string,
    items: [MenuItem],
}

// ── Dock system structs ──────────────────────────────────────────

struct DockTabItem {
    panel-id: string,
    label: string,
    active: bool,
}

struct DockPanelRect {
    addr-key: string,
    x: float,
    y: float,
    width: float,
    height: float,
    panel-id: string,
    panel-label: string,
    tabs: [DockTabItem],
}

struct DockDividerRect {
    addr-key: string,
    x: float,
    y: float,
    width: float,
    height: float,
    is-horizontal: bool,
    parent-origin: float,
    parent-size: float,
}

struct DockDropIndicator {
    x: float,
    y: float,
    width: float,
    height: float,
    kind: string,
    visible: bool,
}

struct WorkflowPageItem {
    id: string,
    label: string,
    active: bool,
}

// ── Icon button ───────────────────────────────────────────────────

component IconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    in property <string> tooltip-text: "";
    in property <string> help-id: "";
    callback clicked;
    callback hover-start(string, length, length);
    callback hover-end();

    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: touch.has-hover && root.enabled ? Palette.control-background : transparent;

    Image {
        source: root.icon;
        width: 16px;
        height: 16px;
        colorize: root.enabled
            ? (touch.has-hover ? Palette.foreground : Palette.foreground.transparentize(20%))
            : Palette.foreground.transparentize(70%);
    }

    touch := TouchArea {
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if root.enabled { root.clicked(); }
        }
        changed has-hover => {
            if (self.has-hover && root.help-id != "") {
                root.hover-start(root.help-id,
                    root.absolute-position.x + root.width + 8px,
                    root.absolute-position.y);
            }
            if (!self.has-hover && root.help-id != "") {
                root.hover-end();
            }
        }
    }
}

component ToolbarSeparator inherits Rectangle {
    width: 1px;
    height: 20px;
    background: Palette.foreground.transparentize(80%);
}

// ── Menu bar ─────────────────────────────────────────────────────

component MenuBarRow inherits Rectangle {
    in property <[MenuDef]> menus: [];
    in-out property <int> active-menu: -1;
    in property <string> app-name: "";
    in property <[TabItem]> page-tabs: [];
    in property <bool> show-tabs: false;
    in property <int> menu-count: 0;
    in property <int> tabs-count: 0;
    callback item-clicked(string);
    callback tab-activated(int);
    callback tab-closed(int);
    callback add-page();

    height: 28px;
    background: Palette.alternate-background;

    Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }

    HorizontalLayout {
        padding-left: 8px;
        spacing: 0px;
        alignment: start;

        for menu[idx] in root.menus : Rectangle {
            visible: idx < root.menu-count;
            height: 28px;
            width: menu-label.preferred-width + 20px;
            background: root.active-menu == idx
                ? Palette.accent-background.transparentize(85%)
                : (menu-touch.has-hover ? Palette.control-background.transparentize(40%) : transparent);
            border-radius: 4px;

            menu-label := Text {
                text: menu.label;
                color: Palette.foreground;
                font-size: 12px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            menu-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.active-menu = root.active-menu == idx ? -1 : idx;
                }
                changed has-hover => {
                    if (self.has-hover && root.active-menu >= 0 && root.active-menu != idx) {
                        root.active-menu = idx;
                    }
                }
            }
        }

        if root.show-tabs : Rectangle {
            width: 9px; height: 28px;
            Rectangle { x: 4px; y: 6px; width: 1px; height: 16px; background: Palette.foreground.transparentize(85%); }
        }
        if root.show-tabs && root.app-name != "" : Rectangle {
            height: 28px;
            width: app-name-pill.preferred-width + 16px;
            app-name-pill := Text {
                text: root.app-name;
                color: Palette.accent-background;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        if root.show-tabs : HorizontalLayout {
            spacing: 0px;
            for tab[i] in root.page-tabs : Rectangle {
                visible: i < root.tabs-count;
                height: 28px; min-width: 80px; max-width: 180px;
                background: tab.active ? Palette.background : transparent;
                Rectangle { x: 0px; y: parent.height - 2px; width: parent.width; height: 2px; background: tab.active ? Palette.accent-background : transparent; }
                HorizontalLayout {
                    padding-left: 10px; padding-right: 6px; spacing: 6px; alignment: start;
                    Text { text: tab.title; color: tab.active ? Palette.foreground : Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; overflow: elide; }
                    IconButton { icon: @image-url("icons/x.svg"); clicked => { root.tab-closed(tab.id); } }
                }
                TouchArea { clicked => { root.tab-activated(i); } }
            }
            Rectangle {
                height: 28px; width: 28px;
                background: add-pg-touch.has-hover ? Palette.control-background : transparent;
                Image { source: @image-url("icons/plus.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(50%); }
                add-pg-touch := TouchArea { mouse-cursor: pointer; clicked => { root.add-page(); } }
            }
        }

        Rectangle { horizontal-stretch: 1; }
    }
}

// ── Builder block components ──────────────────────────────────────

// ── Reusable components ────────────────────────────────────────────

component NavButton inherits Rectangle {
    in property <image> icon;
    in property <bool> selected;
    in property <string> help-id: "";
    callback clicked;
    callback hover-start(string, length, length);
    callback hover-end();

    width: 48px;
    height: 48px;
    background: selected ? Palette.accent-background.transparentize(85%) : transparent;

    Rectangle {
        x: 0px; y: 0px; width: 3px; height: parent.height;
        background: root.selected ? Palette.accent-background : transparent;
        border-radius: 1px;
    }

    Image {
        source: root.icon; width: 20px; height: 20px;
        colorize: root.selected ? Palette.accent-foreground : Palette.foreground.transparentize(30%);
    }

    nav-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
        changed has-hover => {
            if (self.has-hover && root.help-id != "") {
                root.hover-start(root.help-id,
                    root.absolute-position.x + root.width + 8px,
                    root.absolute-position.y);
            }
            if (!self.has-hover && root.help-id != "") {
                root.hover-end();
            }
        }
    }
}

component FieldEditor inherits Rectangle {
    in property <string> key;
    in property <string> label;
    in property <string> kind;
    in property <string> value;
    in property <bool> required;
    in property <float> min;
    in property <float> max;
    in property <bool> has-bounds;
    in property <[string]> options;
    in property <color> swatch;
    in property <[ColorPreset]> user-swatches;
    callback field-edited(string, string);
    callback field-edited-number(string, float);
    callback file-browse-requested(string);
    callback save-color-swatch(string);
    callback remove-color-swatch(int);

    property <bool> is-numeric: root.kind == "number" || root.kind == "integer";
    property <bool> color-picker-open: false;
    property <bool> file-url-mode: false;
    property <bool> select-open: false;

    background: transparent;

    VerticalLayout {
        spacing: 2px;
        padding-top: 4px;
        padding-bottom: 4px;

        Text {
            text: root.required ? root.label + " *" : root.label;
            color: Palette.foreground;
            font-size: 12px;
        }

        // Boolean → Switch
        if root.kind == "boolean" : HorizontalLayout {
            alignment: start; height: 24px;
            Switch {
                checked: root.value == "true";
                toggled => { root.field-edited(root.key, self.checked ? "true" : "false"); }
            }
        }

        // Select → inline dropdown (ComboBox popup broken inside ScrollView)
        if root.kind == "select" : VerticalLayout {
            spacing: 0px;
            Rectangle {
                height: 28px;
                border-radius: 4px;
                border-width: 1px;
                border-color: root.select-open ? Palette.accent-background : Palette.foreground.transparentize(75%);
                background: Palette.control-background;
                HorizontalLayout {
                    padding-left: 8px; padding-right: 8px;
                    Text {
                        text: root.value;
                        color: Palette.foreground;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Image {
                        source: root.select-open
                            ? @image-url("icons/chevron-down.svg")
                            : @image-url("icons/chevron-left.svg");
                        width: 10px; height: 10px;
                        colorize: Palette.foreground.transparentize(40%);
                        vertical-alignment: center;
                    }
                }
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.select-open = !root.select-open; }
                }
            }
            if root.select-open : VerticalLayout {
                spacing: 0px;
                Rectangle {
                    height: 1px;
                    background: Palette.foreground.transparentize(85%);
                }
                for opt in root.options : Rectangle {
                    height: 28px;
                    border-radius: 2px;
                    background: opt == root.value
                        ? Palette.accent-background.transparentize(85%)
                        : (opt-touch.has-hover ? Palette.control-background : transparent);
                    HorizontalLayout {
                        padding-left: 8px; padding-right: 8px;
                        Text {
                            text: opt;
                            color: opt == root.value ? Palette.accent-foreground : Palette.foreground;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                    opt-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.field-edited(root.key, opt);
                            root.select-open = false;
                        }
                    }
                }
            }
        }

        // Color → clickable swatch + hex input + expandable picker
        if root.kind == "color" : VerticalLayout {
            spacing: 4px;

            HorizontalLayout {
                spacing: 6px; height: 28px;
                Rectangle {
                    width: 28px; height: 28px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Palette.foreground.transparentize(80%);
                    background: root.swatch;
                    TouchArea {
                        clicked => { root.color-picker-open = !root.color-picker-open; }
                    }
                }
                LineEdit {
                    horizontal-stretch: 1;
                    text: root.value;
                    placeholder-text: "#000000";
                    accepted(text) => {
                        root.field-edited(root.key, text);
                        root.color-picker-open = false;
                    }
                }
            }

            // Expandable color picker panel
            if root.color-picker-open : Rectangle {
                background: Palette.background.darker(5%);
                border-radius: 6px;
                border-width: 1px;
                border-color: Palette.foreground.transparentize(85%);
                VerticalLayout {
                    padding: 8px; spacing: 6px;

                    // Hue strip — 24 pure hues at 15° intervals
                    Text { text: "Hue"; font-size: 10px; color: Palette.foreground.transparentize(50%); }
                    HorizontalLayout {
                        spacing: 0px;
                        for p in [
                            { c: #ff0000, hex: "#ff0000" }, { c: #ff4000, hex: "#ff4000" },
                            { c: #ff8000, hex: "#ff8000" }, { c: #ffbf00, hex: "#ffbf00" },
                            { c: #ffff00, hex: "#ffff00" }, { c: #bfff00, hex: "#bfff00" },
                            { c: #80ff00, hex: "#80ff00" }, { c: #40ff00, hex: "#40ff00" },
                            { c: #00ff00, hex: "#00ff00" }, { c: #00ff40, hex: "#00ff40" },
                            { c: #00ff80, hex: "#00ff80" }, { c: #00ffbf, hex: "#00ffbf" },
                            { c: #00ffff, hex: "#00ffff" }, { c: #00bfff, hex: "#00bfff" },
                            { c: #0080ff, hex: "#0080ff" }, { c: #0040ff, hex: "#0040ff" },
                            { c: #0000ff, hex: "#0000ff" }, { c: #4000ff, hex: "#4000ff" },
                            { c: #8000ff, hex: "#8000ff" }, { c: #bf00ff, hex: "#bf00ff" },
                            { c: #ff00ff, hex: "#ff00ff" }, { c: #ff00bf, hex: "#ff00bf" },
                            { c: #ff0080, hex: "#ff0080" }, { c: #ff0040, hex: "#ff0040" },
                        ] : Rectangle {
                            horizontal-stretch: 1;
                            height: 16px;
                            background: p.c;
                            TouchArea {
                                clicked => {
                                    root.field-edited(root.key, p.hex);
                                }
                            }
                        }
                    }

                    // Preset swatches — core palette
                    Text { text: "Presets"; font-size: 10px; color: Palette.foreground.transparentize(50%); }
                    HorizontalLayout {
                        spacing: 4px;
                        for p in [
                            { c: #000000, hex: "#000000" }, { c: #ffffff, hex: "#ffffff" },
                            { c: #ef4444, hex: "#ef4444" }, { c: #f97316, hex: "#f97316" },
                            { c: #eab308, hex: "#eab308" }, { c: #22c55e, hex: "#22c55e" },
                            { c: #06b6d4, hex: "#06b6d4" }, { c: #3b82f6, hex: "#3b82f6" },
                            { c: #8b5cf6, hex: "#8b5cf6" }, { c: #ec4899, hex: "#ec4899" },
                        ] : Rectangle {
                            width: 20px; height: 20px;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Palette.foreground.transparentize(80%);
                            background: p.c;
                            TouchArea {
                                clicked => {
                                    root.field-edited(root.key, p.hex);
                                    root.color-picker-open = false;
                                }
                            }
                        }
                    }

                    // Lighter tints
                    HorizontalLayout {
                        spacing: 4px;
                        for p in [
                            { c: #1e293b, hex: "#1e293b" }, { c: #475569, hex: "#475569" },
                            { c: #9ca3af, hex: "#9ca3af" }, { c: #fca5a5, hex: "#fca5a5" },
                            { c: #fdba74, hex: "#fdba74" }, { c: #fde047, hex: "#fde047" },
                            { c: #86efac, hex: "#86efac" }, { c: #67e8f9, hex: "#67e8f9" },
                            { c: #93c5fd, hex: "#93c5fd" }, { c: #c4b5fd, hex: "#c4b5fd" },
                        ] : Rectangle {
                            width: 20px; height: 20px;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Palette.foreground.transparentize(80%);
                            background: p.c;
                            TouchArea {
                                clicked => {
                                    root.field-edited(root.key, p.hex);
                                    root.color-picker-open = false;
                                }
                            }
                        }
                    }

                    // User swatches
                    HorizontalLayout {
                        spacing: 4px; alignment: start;
                        Text { text: "Saved"; font-size: 10px; color: Palette.foreground.transparentize(50%); vertical-alignment: center; }
                        // "+" button to save current color
                        Rectangle {
                            width: 20px; height: 20px;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Palette.foreground.transparentize(60%);
                            background: Palette.background.darker(10%);
                            Text { text: "+"; font-size: 14px; color: Palette.foreground.transparentize(40%);
                                   horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                clicked => { root.save-color-swatch(root.value); }
                            }
                        }
                    }
                    if root.user-swatches.length > 0 : HorizontalLayout {
                        spacing: 4px;
                        for us[idx] in root.user-swatches : Rectangle {
                            width: 20px; height: 20px;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Palette.foreground.transparentize(80%);
                            background: us.c;
                            TouchArea {
                                clicked => {
                                    root.field-edited(root.key, us.hex);
                                    root.color-picker-open = false;
                                }
                            }
                        }
                    }
                }
            }
        }

        // File → display + browse button + URL toggle
        if root.kind == "file" : VerticalLayout {
            spacing: 4px;

            // Current file display + browse button
            HorizontalLayout {
                spacing: 4px; height: 28px;
                Rectangle {
                    horizontal-stretch: 1; height: 28px;
                    border-radius: 4px;
                    background: Palette.background.darker(5%);
                    border-width: 1px;
                    border-color: Palette.foreground.transparentize(85%);
                    HorizontalLayout {
                        padding-left: 8px; padding-right: 8px; alignment: start;
                        Text {
                            text: root.value == "" ? "No file selected" : root.value;
                            color: root.value == "" ? Palette.foreground.transparentize(50%) : Palette.foreground;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
                Button {
                    text: "Browse";
                    clicked => { root.file-browse-requested(root.key); }
                }
            }

            // URL input toggle row
            HorizontalLayout {
                spacing: 4px; height: 20px; alignment: start;
                Rectangle {
                    width: self.preferred-width; height: 18px;
                    border-radius: 3px;
                    background: root.file-url-mode ? Palette.accent-background.transparentize(80%) : transparent;
                    HorizontalLayout {
                        padding-left: 6px; padding-right: 6px;
                        Text {
                            text: "URL";
                            color: root.file-url-mode ? Palette.accent-background : Palette.foreground.transparentize(40%);
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea { clicked => { root.file-url-mode = !root.file-url-mode; } }
                }
            }

            // URL input (when toggled)
            if root.file-url-mode : LineEdit {
                height: 28px;
                text: root.value;
                placeholder-text: "https://example.com/image.png";
                accepted(text) => {
                    root.field-edited(root.key, text);
                    root.file-url-mode = false;
                }
            }
        }

        // Number/Integer with bounds → LineEdit + Slider (inline)
        if root.is-numeric && root.has-bounds : HorizontalLayout {
            spacing: 4px;
            height: 28px;
            LineEdit {
                width: 56px;
                height: 28px;
                text: root.value;
                placeholder-text: root.label;
                accepted(text) => { root.field-edited(root.key, text); }
            }
            Slider {
                horizontal-stretch: 1;
                height: 20px;
                minimum: root.min;
                maximum: root.max;
                value: root.value.to-float();
                changed(val) => { root.field-edited-number(root.key, val); }
            }
        }

        // Number/Integer without bounds → plain LineEdit
        if root.is-numeric && !root.has-bounds : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => { root.field-edited(root.key, text); }
        }

        // Textarea → LineEdit (multi-line editing happens inline on canvas)
        if root.kind == "textarea" : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => { root.field-edited(root.key, text); }
        }

        // Text → standard LineEdit
        if root.kind == "text" : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => { root.field-edited(root.key, text); }
        }

        // Kind hint
        Text {
            text: root.kind + " · " + root.key;
            color: Palette.foreground.transparentize(50%);
            font-size: 10px;
        }
    }
}

component InspectorRow inherits Rectangle {
    in property <string> node-id;
    in property <string> component-id;
    in property <int> depth;
    in property <bool> selected;
    in property <string> kind: "node";
    callback clicked;
    callback move-up;
    callback move-down;
    callback delete-track;

    height: 30px;
    background: root.kind == "row"
        ? Palette.foreground.transparentize(96%)
        : (selected ? Palette.accent-background.transparentize(85%) : transparent);
    border-radius: 4px;

    HorizontalLayout {
        padding-left: root.depth * 16px + 12px;
        padding-right: 8px;
        alignment: space-between;

        HorizontalLayout {
            spacing: 6px; alignment: start;
            Rectangle {
                width: 6px; height: 6px; border-radius: root.kind == "row" ? 1px : 3px; y: 12px;
                background: root.kind == "row"
                    ? Palette.foreground.transparentize(40%)
                    : (root.kind == "empty"
                        ? Palette.foreground.transparentize(80%)
                        : (root.selected ? Palette.accent-background : Palette.foreground.transparentize(60%)));
            }
            Text {
                text: root.component-id;
                font-size: root.kind == "row" ? 11px : 12px;
                font-weight: root.kind == "row" ? 600 : (root.selected ? 600 : 400);
                color: root.kind == "row"
                    ? Palette.foreground.transparentize(20%)
                    : (root.kind == "empty"
                        ? Palette.foreground.transparentize(60%)
                        : (root.selected ? Palette.accent-foreground : Palette.foreground));
                vertical-alignment: center;
            }
            Text {
                visible: root.kind == "node";
                text: root.node-id;
                color: Palette.foreground.transparentize(50%);
                font-size: 10px; font-family: "monospace"; vertical-alignment: center;
            }
        }

        if root.selected && root.kind == "node" : HorizontalLayout {
            spacing: 2px; width: 60px; alignment: end;
            IconButton { icon: @image-url("icons/chevron-up.svg"); clicked => { root.move-up(); } }
            IconButton { icon: @image-url("icons/chevron-down.svg"); clicked => { root.move-down(); } }
        }

        if root.kind == "row" && inspector-row-hover.has-hover : HorizontalLayout {
            spacing: 2px; width: 30px; alignment: end;
            IconButton { icon: @image-url("icons/trash.svg"); clicked => { root.delete-track(); } }
        }
    }

    inspector-row-hover := TouchArea { clicked => { root.clicked(); } }
}

component Toast inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> kind;
    callback dismissed;

    property <color> kind-color: root.kind == "error" ? #dc3c3c :
                                  root.kind == "warning" ? #dcaa3c :
                                  root.kind == "success" ? #3cdc6e :
                                  Palette.accent-background;

    width: 320px;
    background: Palette.alternate-background;
    border-radius: 8px;
    border-width: 1px;
    border-color: kind-color;
    clip: true;

    VerticalLayout {
        padding: 12px; spacing: 4px;
        HorizontalLayout {
            spacing: 8px;
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: root.kind-color; y: 6px; }
            Text { text: root.title; color: Palette.foreground; font-size: 13px; font-weight: 600; overflow: elide; }
            Rectangle { horizontal-stretch: 1; }
            IconButton { icon: @image-url("icons/x.svg"); clicked => { root.dismissed(); } }
        }
        if root.body != "" : Text { text: root.body; color: Palette.foreground.transparentize(30%); font-size: 12px; wrap: word-wrap; }
    }
}

// ── Docs content (shared between sidebar and full view) ───────────

component DocsContent inherits Rectangle {
    in property <string> doc-title;
    in property <string> doc-summary;
    in property <string> doc-body;
    in property <bool> compact: false;

    VerticalLayout {
        spacing: 0px;

        Text {
            text: root.doc-title;
            color: Palette.foreground;
            font-size: root.compact ? 14px : 22px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Rectangle { height: root.compact ? 8px : 12px; }

        Text {
            text: root.doc-summary;
            color: Palette.foreground.transparentize(20%);
            font-size: root.compact ? 12px : 14px;
            font-weight: 500;
            wrap: word-wrap;
        }

        if root.doc-body != "" : Rectangle { height: root.compact ? 10px : 16px; }

        if root.doc-body != "" : Rectangle {
            height: 1px;
            background: Palette.foreground.transparentize(85%);
        }

        if root.doc-body != "" : Rectangle { height: root.compact ? 10px : 16px; }

        if root.doc-body != "" : Text {
            text: root.doc-body;
            color: Palette.foreground.transparentize(30%);
            font-size: root.compact ? 12px : 13px;
            wrap: word-wrap;
        }
    }
}

// ── App card (launchpad) ──────────────────────────────────────────

component AppCard inherits Rectangle {
    in property <string> app-id;
    in property <string> name;
    in property <string> description;
    in property <string> icon;
    in property <color> accent-color: Palette.accent-background;
    in property <int> page-count: 1;
    in property <bool> is-create: false;
    callback clicked;

    height: 160px;
    border-radius: 12px;
    border-width: 1px;
    border-color: card-touch.has-hover
        ? root.accent-color.transparentize(40%)
        : Palette.foreground.transparentize(88%);
    background: card-touch.has-hover
        ? Palette.alternate-background
        : Palette.background;
    clip: true;

    // Accent bar at top
    Rectangle {
        x: 0px; y: 0px;
        width: parent.width;
        height: 4px;
        background: root.accent-color;
    }

    VerticalLayout {
        padding: 20px;
        padding-top: 20px;
        spacing: 8px;
        alignment: start;

        if root.is-create : VerticalLayout {
            alignment: center;
            spacing: 8px;
            padding-top: 24px;
            Image {
                source: @image-url("icons/plus.svg");
                width: 32px;
                height: 32px;
                colorize: Palette.foreground.transparentize(40%);
            }
            Text {
                text: "Create App";
                color: Palette.foreground.transparentize(30%);
                font-size: 14px;
                font-weight: 600;
                horizontal-alignment: center;
            }
        }

        if !root.is-create : VerticalLayout {
            spacing: 8px;
            alignment: start;

            HorizontalLayout {
                spacing: 10px;
                alignment: start;

                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: 8px;
                    background: root.accent-color.transparentize(85%);

                    if root.icon == "globe" : Image { source: @image-url("icons/globe.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                    if root.icon == "music" : Image { source: @image-url("icons/grip.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                    if root.icon == "zap" : Image { source: @image-url("icons/zap.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                    if root.icon == "code" : Image { source: @image-url("icons/code.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                    if root.icon == "cube" : Image { source: @image-url("icons/box.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                    if root.icon == "star" : Image { source: @image-url("icons/help-circle.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                    if root.icon == "heart" : Image { source: @image-url("icons/user.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                    if root.icon == "film" : Image { source: @image-url("icons/image.svg"); width: 18px; height: 18px; colorize: root.accent-color; }
                }

                VerticalLayout {
                    alignment: center;
                    Text {
                        text: root.name;
                        color: Palette.foreground;
                        font-size: 16px;
                        font-weight: 700;
                        overflow: elide;
                    }
                }
            }

            Text {
                text: root.description;
                color: Palette.foreground.transparentize(40%);
                font-size: 12px;
                wrap: word-wrap;
                overflow: elide;
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Rectangle {
                    height: 20px;
                    width: pages-text.preferred-width + 12px;
                    border-radius: 4px;
                    background: Palette.foreground.transparentize(92%);
                    pages-text := Text {
                        text: root.page-count == 1 ? "1 page" : "\{root.page-count} pages";
                        color: Palette.foreground.transparentize(50%);
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    card-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// ── Root component ─────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Prism Studio";
    preferred-width: 1280px;
    preferred-height: 800px;

    // Panel navigation (0 = Identity, 1 = Edit, 2 = Code Editor)
    in property <int> active-panel-id: 1;
    callback select-panel(int);

    // Identity panel
    in property <[ButtonSpec]> actions: [];
    callback clicked(int);

    // Viewport / responsive preview
    in property <float> viewport-width: 1280.0;
    in property <string> viewport-preset: "Desktop";
    in-out property <float> canvas-zoom: 1.0;
    callback viewport-preset-changed(string);

    // Builder canvas
    in property <int> builder-node-count: 0;
    in property <[PreviewNode]> preview-nodes: [];
    in property <bool> preview-factory-ready: false;
    in property <component-factory> preview-factory;
    callback builder-node-clicked(string);
    callback builder-text-edited(string, string);
    callback builder-delete-node(string);
    in property <string> builder-source: "";

    // Component palette
    in property <[ComponentPaletteItem]> component-palette: [];
    callback add-component(string);

    // Layer tree
    in property <string> inspector-tree: "";
    in property <[InspectorNode]> inspector-nodes: [];
    callback node-clicked(string);
    callback node-move-up(string);
    callback node-move-down(string);
    callback inspector-delete-track(string /* "row:N" */);


    // Properties
    in property <string> selected-component: "";
    in property <[FieldRow]> field-rows: [];
    callback field-edited(string, string);
    callback field-edited-number(string, float);
    callback file-browse-requested(string);

    // Tabbed MDI
    in property <[TabItem]> tabs: [];
    callback tab-activated(int);
    callback tab-closed(int);

    // Command palette
    in property <bool> command-palette-visible: false;
    in property <[CommandItem]> command-results: [];
    callback toggle-command-palette();
    callback command-palette-input(string);
    callback command-selected(int);

    // Notifications
    in property <[ToastItem]> notifications: [];
    callback dismiss-notification(int);

    // Undo/redo
    in property <bool> can-undo: false;
    in property <bool> can-redo: false;
    in property <string> undo-label: "";
    in property <string> redo-label: "";
    callback undo-clicked;
    callback redo-clicked;

    // Search
    in property <string> search-query: "";
    in property <[SearchResultItem]> search-results: [];
    callback search-input(string);
    callback search-result-clicked(string);

    // Clipboard
    in property <bool> has-selection: false;
    in property <bool> has-clipboard: false;
    callback copy-clicked;
    callback paste-clicked;
    callback cut-clicked;
    callback duplicate-clicked;

    // Input dispatch
    callback dispatch-key(string /* text */, bool /* ctrl */, bool /* shift */, bool /* alt */, bool /* meta */) -> bool;
    callback escape-pressed;
    callback search-focus;
    in property <string> panel-title: "Editor";
    in property <string> panel-hint: "Build your page visually.";

    // Breadcrumbs
    in property <[BreadcrumbItem]> breadcrumbs: [];
    callback breadcrumb-clicked(string);

    // Help tooltip
    in property <HelpTooltipData> help-tooltip: {
        visible: false, title: "", summary: "", has-docs: false,
        tip-x: 0px, tip-y: 0px
    };
    callback help-hover(string, length, length);
    callback help-leave();
    callback help-docs-clicked;
    callback help-entry-clicked;

    // Sidebar section collapse state
    in-out property <bool> components-expanded: true;
    in-out property <bool> layers-expanded: true;
    in-out property <bool> page-layout-expanded: true;
    in-out property <bool> cat-content-expanded: true;
    in-out property <bool> cat-layout-expanded: true;
    in-out property <bool> cat-form-expanded: true;
    in-out property <bool> cat-decoration-expanded: true;
    in-out property <bool> cat-prefabs-expanded: true;

    // Code editor
    in property <[EditorLine]> editor-lines: [];
    in property <int> editor-cursor-line: 0;
    in property <int> editor-cursor-col: 0;
    in property <bool> editor-cursor-visible: true;
    in property <string> editor-cursor-prefix: "";
    in property <string> editor-language: "rust";
    in property <int> editor-line-count: 0;
    in property <int> editor-char-count: 0;
    callback editor-action(string);
    callback editor-char-typed(string);
    callback editor-click(int, int);
    callback editor-drag(int, int);
    callback editor-fold-toggle(int);

    // Page layout
    in property <PageLayoutData> page-layout: {
        page-width: 1280.0, page-height: 800.0,
        margin-top: 0.0, margin-right: 0.0, margin-bottom: 0.0, margin-left: 0.0,
        column-gap: 0.0, row-gap: 0.0,
        cell-count: 1,
        show-grid: false, is-responsive: true,
        page-size-label: "Responsive",
    };
    in property <[GutterRect]> column-gutters: [];
    in property <[GutterRect]> row-gutters: [];
    callback toggle-grid-overlay;
    callback page-layout-edited(string, string);

    // Layout properties for selected node
    in property <[FieldRow]> layout-rows: [];
    callback layout-field-edited(string, string);
    callback layout-field-edited-number(string, float);

    // Composition systems
    in property <[ModifierItem]> modifier-items: [];
    in property <[SignalItem]> signal-items: [];
    in property <[VariantItem]> variant-items: [];
    in property <int> connection-count: 0;
    in property <int> resource-count: 0;
    in property <int> prefab-count: 0;

    // Docs panel (sidebar) and docs view (full)
    in property <DocsPanelData> docs-panel: {
        visible: false, help-id: "", title: "", summary: "", body: ""
    };
    in property <DocsPanelData> docs-view: {
        visible: false, help-id: "", title: "", summary: "", body: ""
    };
    callback docs-open-full;
    callback docs-panel-close;
    callback docs-view-close;

    // Grid cells (interactive page grid)
    in property <[GridCellItem]> grid-cells: [];
    in property <[GridEdgeHandle]> grid-edge-handles: [];
    in property <int> grid-edge-handles-count: 0;
    in property <string> pending-add-path: "";
    in property <float> pending-add-x: 0;
    in property <float> pending-add-y: 0;
    in property <bool> show-component-picker: false;
    in property <string> drag-component-type: "";
    callback grid-cell-clicked(string /* path */);
    callback grid-cell-add-component(string /* component-type */, string /* path */);
    callback picker-show(string /* path */, float /* x */, float /* y */);
    callback picker-dismiss();
    callback palette-drag-toggle(string /* component-type */);
    callback grid-add-at-edge(string /* cell-path */, string /* edge */);

    // User color swatches
    in property <[ColorPreset]> user-color-swatches: [];
    callback save-color-swatch(string /* hex */);
    callback remove-color-swatch(int /* index */);

    // Style cascade (app/page/node)
    in property <[FieldRow]> style-rows: [];
    callback style-field-edited(string /* key */, string /* value */);
    callback style-field-edited-number(string /* key */, float /* value */);

    // Launchpad / App navigation
    in property <bool> is-launchpad: true;
    in property <[AppCardItem]> app-cards: [];
    in property <string> active-app-name: "";
    in property <string> active-page-name: "";
    callback open-app(string);
    callback create-app;
    callback go-home;
    callback add-page;
    callback switch-page(int);

    // Menu bar
    in property <[MenuDef]> menu-defs: [];
    callback menu-command(string);

    // Explorer
    in property <[ExplorerNodeItem]> explorer-nodes: [];
    in-out property <bool> explorer-list-mode: true;
    callback explorer-node-clicked(string);
    callback explorer-toggle-expand(string);

    // Dock system
    in property <[WorkflowPageItem]> workflow-pages: [];
    in property <[DockPanelRect]> dock-panels: [];
    in property <[DockDividerRect]> dock-dividers: [];
    in property <[DockDropIndicator]> dock-drop-indicators: [];
    in property <bool> dock-dragging-panel: false;
    in property <string> dock-drag-panel-id: "";
    out property <float> dock-area-width: dock-area.width / 1px;
    out property <float> dock-area-height: dock-area.height / 1px;
    callback workflow-page-clicked(string);
    callback dock-tab-clicked(string, int);
    callback dock-tab-close(string, string);
    callback dock-divider-dragged(string, float);
    callback dock-panel-drag-start(string);
    callback dock-panel-drag-end(float, float);
    callback dock-panel-drag-move(float, float);

    // Persistent model counts (hidden-excess visibility)
    in property <int> preview-nodes-count: 0;
    in property <int> inspector-nodes-count: 0;
    in property <int> field-rows-count: 0;
    in property <int> layout-rows-count: 0;
    in property <int> style-rows-count: 0;
    in property <int> breadcrumbs-count: 0;
    in property <int> component-palette-count: 0;
    in property <int> tabs-count: 0;
    in property <int> command-results-count: 0;
    in property <int> notifications-count: 0;
    in property <int> search-results-count: 0;
    in property <int> column-gutters-count: 0;
    in property <int> row-gutters-count: 0;
    in property <int> app-cards-count: 0;
    in property <int> explorer-nodes-count: 0;
    in property <int> dock-panels-count: 0;
    in property <int> dock-dividers-count: 0;
    in property <int> workflow-pages-count: 0;
    in property <int> actions-count: 0;
    in property <int> menu-defs-count: 0;
    in property <int> modifier-items-count: 0;
    in property <int> signal-items-count: 0;
    in property <int> variant-items-count: 0;
    in property <int> editor-lines-count: 0;
    in property <int> grid-cells-count: 0;

    // Shell chrome visibility
    in property <bool> show-activity-bar: true;
    in property <bool> show-left-sidebar: true;
    in property <bool> show-right-sidebar: true;

    background: Palette.background;

    fs := FocusScope {
        width: 100%;
        height: 100%;

        key-pressed(event) => {
            if (root.dispatch-key(event.text, event.modifiers.control, event.modifiers.shift, event.modifiers.alt, event.modifiers.meta)) {
                return accept;
            }
            return reject;
        }

        // Menu dropdown state (local to Slint)
        property <int> menu-active-index: -1;

        VerticalLayout {
            // ── Menu bar ─────────────────────────────────────────
            if root.menu-defs-count > 0 : MenuBarRow {
                menus: root.menu-defs;
                menu-count: root.menu-defs-count;
                tabs-count: root.tabs-count;
                active-menu <=> fs.menu-active-index;
                app-name: root.active-app-name;
                page-tabs: root.tabs;
                show-tabs: !root.is-launchpad;
                item-clicked(cmd) => { root.menu-command(cmd); fs.menu-active-index = -1; }
                tab-activated(i) => { root.switch-page(i); }
                tab-closed(id) => { root.tab-closed(id); }
                add-page => { root.add-page(); }
            }

            HorizontalLayout {
                spacing: 0px;
                vertical-stretch: 1;

                // ── Activity bar ──────────────────────────────────
                if root.show-activity-bar : Rectangle {
                    width: 40px;
                    background: Palette.alternate-background;
                    VerticalLayout {
                        padding-top: 6px;
                        spacing: 0px;
                        alignment: start;
                        NavButton {
                            icon: @image-url("icons/home.svg");
                            selected: root.is-launchpad;
                            help-id: "shell.launchpad";
                            clicked => { root.go-home(); }
                            hover-start(id, x, y) => { root.help-hover(id, x, y); }
                            hover-end => { root.help-leave(); }
                        }
                    }
                }

                // ── Main content area ─────────────────────────────
                VerticalLayout {
                    horizontal-stretch: 1;

                    // ── Dock area ─────────────────────────────────
                    dock-area := Rectangle {
                        vertical-stretch: 1;
                        background: Palette.background;

                        // ── Launchpad ─────────────────────────────
                        if root.is-launchpad : ScrollView {
                            VerticalLayout {
                                padding: 48px;
                                padding-top: 40px;
                                spacing: 0px;
                                alignment: start;
                                max-width: 900px;

                                Text { text: "Prism Studio"; color: Palette.foreground; font-size: 28px; font-weight: 800; }
                                Rectangle { height: 6px; }
                                Text { text: "Create, build, and ship rich multi-page apps."; color: Palette.foreground.transparentize(40%); font-size: 14px; }
                                Rectangle { height: 32px; }

                                HorizontalLayout {
                                    spacing: 8px; alignment: start;
                                    Text { text: "Your Apps"; color: Palette.foreground.transparentize(20%); font-size: 13px; font-weight: 600; vertical-alignment: center; }
                                    Rectangle {
                                        height: 20px; width: app-count-text.preferred-width + 12px; border-radius: 4px;
                                        background: Palette.foreground.transparentize(92%);
                                        app-count-text := Text { text: root.app-cards-count; color: Palette.foreground.transparentize(50%); font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                                Rectangle { height: 16px; }

                                VerticalLayout {
                                    spacing: 16px;
                                    HorizontalLayout {
                                        spacing: 16px;
                                        AppCard { horizontal-stretch: 1; is-create: true; accent-color: Palette.foreground.transparentize(70%); clicked => { root.create-app(); } }
                                        for card[i] in root.app-cards : AppCard {
                                            visible: i < root.app-cards-count;
                                            horizontal-stretch: 1; app-id: card.id; name: card.name; description: card.description;
                                            icon: card.icon; accent-color: card.accent-color; page-count: card.page-count;
                                            clicked => { root.open-app(card.id); }
                                        }
                                        if root.app-cards-count == 1 : Rectangle { horizontal-stretch: 1; }
                                    }
                                }

                                Rectangle { height: 32px; }
                                Rectangle { height: 1px; background: Palette.foreground.transparentize(90%); }
                                Rectangle { height: 16px; }
                                Text { text: "Each app is a collection of pages with its own navigation. Open an app to start editing, or create a new one."; color: Palette.foreground.transparentize(60%); font-size: 11px; wrap: word-wrap; }
                            }
                        }

                        // ── Docs full view ────────────────────────
                        if !root.is-launchpad && root.docs-view.visible : ScrollView {
                            VerticalLayout {
                                padding: 48px; padding-top: 32px; spacing: 0px; alignment: start;
                                HorizontalLayout {
                                    spacing: 8px; alignment: start;
                                    Rectangle {
                                        width: 28px; height: 28px; border-radius: 6px;
                                        background: docs-view-back.has-hover ? Palette.control-background : transparent;
                                        Image { source: @image-url("icons/chevron-left.svg"); width: 16px; height: 16px; colorize: docs-view-back.has-hover ? Palette.foreground : Palette.foreground.transparentize(30%); }
                                        docs-view-back := TouchArea { mouse-cursor: pointer; clicked => { root.docs-view-close(); } }
                                    }
                                    VerticalLayout { alignment: center; Text { text: "Back to editor"; color: Palette.foreground.transparentize(40%); font-size: 12px; vertical-alignment: center; } }
                                }
                                Rectangle { height: 24px; }
                                DocsContent { doc-title: root.docs-view.title; doc-summary: root.docs-view.summary; doc-body: root.docs-view.body; compact: false; }
                            }
                        }

                        // ── Dock panels (absolutely positioned) ───
                        if !root.is-launchpad && !root.docs-view.visible : Rectangle {
                            width: 100%; height: 100%;

                            for panel[i] in root.dock-panels : Rectangle {
                                visible: i < root.dock-panels-count;
                                x: panel.x * 1px;
                                y: panel.y * 1px;
                                width: panel.width * 1px;
                                height: panel.height * 1px;
                                clip: true;
                                background: Palette.alternate-background;

                                VerticalLayout {
                                    // ── Dock tab bar ──────────────
                                    Rectangle {
                                        height: 28px;
                                        background: Palette.alternate-background;
                                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                                        HorizontalLayout {
                                            spacing: 0px; alignment: start;
                                            for tab[ti] in panel.tabs : Rectangle {
                                                height: 28px;
                                                min-width: dock-tab-lbl.preferred-width + 20px;
                                                max-width: 150px;
                                                background: tab.active ? Palette.background : Palette.alternate-background;
                                                Rectangle { x: 0px; y: parent.height - 2px; width: parent.width; height: 2px;
                                                    background: tab.active ? Palette.accent-background : transparent; }
                                                dock-tab-lbl := Text {
                                                    text: tab.label;
                                                    color: tab.active ? Palette.foreground : Palette.foreground.transparentize(40%);
                                                    font-size: 11px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                                TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => { root.dock-tab-clicked(panel.addr-key, ti); }
                                                }
                                            }
                                        }
                                    }

                                    // ── Panel content ─────────────
                                    Rectangle {
                                        vertical-stretch: 1;
                                        clip: true;
                                        background: Palette.background;

                                        // ════════════════════════════════════
                                        // BUILDER
                                        // ════════════════════════════════════
                                        if panel.panel-id == "builder" : VerticalLayout {
                                            // Toolbar
                                            Rectangle {
                                                height: 28px;
                                                background: Palette.background;
                                                Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                                                HorizontalLayout {
                                                    padding-left: 8px; padding-right: 8px; spacing: 4px; alignment: start;
                                                    IconButton { icon: @image-url("icons/undo.svg"); enabled: root.can-undo; help-id: "shell.toolbar.undo"; clicked => { root.undo-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    IconButton { icon: @image-url("icons/redo.svg"); enabled: root.can-redo; help-id: "shell.toolbar.redo"; clicked => { root.redo-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    ToolbarSeparator { }
                                                    IconButton { icon: @image-url("icons/copy.svg"); enabled: root.has-selection; help-id: "shell.toolbar.copy"; clicked => { root.copy-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    IconButton { icon: @image-url("icons/scissors.svg"); enabled: root.has-selection; help-id: "shell.toolbar.cut"; clicked => { root.cut-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    IconButton { icon: @image-url("icons/paste.svg"); enabled: root.has-clipboard; help-id: "shell.toolbar.paste"; clicked => { root.paste-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    IconButton { icon: @image-url("icons/duplicate.svg"); enabled: root.has-selection; help-id: "shell.toolbar.duplicate"; clicked => { root.duplicate-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    ToolbarSeparator { }
                                                    IconButton { icon: @image-url("icons/chevron-up.svg"); enabled: root.has-selection; help-id: "shell.toolbar.move-up"; clicked => { root.node-move-up(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    IconButton { icon: @image-url("icons/chevron-down.svg"); enabled: root.has-selection; help-id: "shell.toolbar.move-down"; clicked => { root.node-move-down(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    ToolbarSeparator { }
                                                    IconButton { icon: @image-url("icons/trash.svg"); enabled: root.has-selection; help-id: "shell.toolbar.delete"; clicked => { root.builder-delete-node(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                                                    ToolbarSeparator { }
                                                    Rectangle {
                                                        width: 28px; height: 28px; border-radius: 6px;
                                                        background: root.page-layout.show-grid ? Palette.accent-background.transparentize(85%) : (grid-toggle-touch.has-hover ? Palette.control-background : transparent);
                                                        Image { source: @image-url("icons/columns.svg"); width: 16px; height: 16px; colorize: root.page-layout.show-grid ? Palette.accent-foreground : Palette.foreground.transparentize(20%); }
                                                        grid-toggle-touch := TouchArea { mouse-cursor: pointer; clicked => { root.toggle-grid-overlay(); } }
                                                    }
                                                    // Breadcrumbs (inline)
                                                    if root.breadcrumbs-count > 0 : ToolbarSeparator { }
                                                    for bc[i] in root.breadcrumbs : HorizontalLayout {
                                                        visible: i < root.breadcrumbs-count;
                                                        spacing: 2px; alignment: start;
                                                        if bc.has-separator : Text { text: "\u{203A}"; color: Palette.foreground.transparentize(50%); font-size: 10px; vertical-alignment: center; }
                                                        Text { text: bc.label; color: Palette.foreground.transparentize(30%); font-size: 10px; vertical-alignment: center; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }

                                                    Rectangle {
                                                        height: 24px; border-radius: 4px;
                                                        background: Palette.foreground.transparentize(95%);
                                                        HorizontalLayout {
                                                            spacing: 0px;
                                                            Rectangle {
                                                                width: vp-desk-t.preferred-width + 12px; height: 24px; border-radius: 4px;
                                                                background: root.viewport-preset == "Desktop" ? Palette.accent-background.transparentize(80%) : (vp-desk-ta.has-hover ? Palette.control-background : transparent);
                                                                vp-desk-t := Text { text: "Desktop"; font-size: 10px; vertical-alignment: center; horizontal-alignment: center;
                                                                    color: root.viewport-preset == "Desktop" ? Palette.accent-foreground : Palette.foreground.transparentize(40%); }
                                                                vp-desk-ta := TouchArea { mouse-cursor: pointer; clicked => { root.viewport-preset-changed("Desktop"); } }
                                                            }
                                                            Rectangle {
                                                                width: vp-tab-t.preferred-width + 12px; height: 24px; border-radius: 4px;
                                                                background: root.viewport-preset == "Tablet" ? Palette.accent-background.transparentize(80%) : (vp-tab-ta.has-hover ? Palette.control-background : transparent);
                                                                vp-tab-t := Text { text: "Tablet"; font-size: 10px; vertical-alignment: center; horizontal-alignment: center;
                                                                    color: root.viewport-preset == "Tablet" ? Palette.accent-foreground : Palette.foreground.transparentize(40%); }
                                                                vp-tab-ta := TouchArea { mouse-cursor: pointer; clicked => { root.viewport-preset-changed("Tablet"); } }
                                                            }
                                                            Rectangle {
                                                                width: vp-mob-t.preferred-width + 12px; height: 24px; border-radius: 4px;
                                                                background: root.viewport-preset == "Mobile" ? Palette.accent-background.transparentize(80%) : (vp-mob-ta.has-hover ? Palette.control-background : transparent);
                                                                vp-mob-t := Text { text: "Mobile"; font-size: 10px; vertical-alignment: center; horizontal-alignment: center;
                                                                    color: root.viewport-preset == "Mobile" ? Palette.accent-foreground : Palette.foreground.transparentize(40%); }
                                                                vp-mob-ta := TouchArea { mouse-cursor: pointer; clicked => { root.viewport-preset-changed("Mobile"); } }
                                                            }
                                                        }
                                                    }
                                                    ToolbarSeparator { }
                                                    Rectangle {
                                                        height: 24px;
                                                        HorizontalLayout {
                                                            spacing: 2px;
                                                            Rectangle {
                                                                width: 22px; height: 24px; border-radius: 4px;
                                                                background: zoom-out-ta.has-hover ? Palette.control-background : transparent;
                                                                Text { text: "\u{2212}"; font-size: 14px; color: Palette.foreground.transparentize(30%); vertical-alignment: center; horizontal-alignment: center; }
                                                                zoom-out-ta := TouchArea { mouse-cursor: pointer; clicked => { root.canvas-zoom = max(0.25, root.canvas-zoom - 0.1); } }
                                                            }
                                                            Rectangle {
                                                                width: zoom-pct-t.preferred-width + 8px; height: 24px; border-radius: 4px;
                                                                background: zoom-fit-ta.has-hover ? Palette.control-background : transparent;
                                                                zoom-pct-t := Text { text: round(root.canvas-zoom * 100) + "%"; font-size: 10px; color: Palette.foreground.transparentize(30%); vertical-alignment: center; horizontal-alignment: center; }
                                                                zoom-fit-ta := TouchArea { mouse-cursor: pointer; clicked => { root.canvas-zoom = 1.0; } }
                                                            }
                                                            Rectangle {
                                                                width: 22px; height: 24px; border-radius: 4px;
                                                                background: zoom-in-ta.has-hover ? Palette.control-background : transparent;
                                                                Text { text: "+"; font-size: 14px; color: Palette.foreground.transparentize(30%); vertical-alignment: center; horizontal-alignment: center; }
                                                                zoom-in-ta := TouchArea { mouse-cursor: pointer; clicked => { root.canvas-zoom = min(3.0, root.canvas-zoom + 0.1); } }
                                                            }
                                                        }
                                                    }
                                                    ToolbarSeparator { }
                                                    if root.page-layout.cell-count > 1 : Text { text: root.page-layout.cell-count + " cells"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                                                    if root.page-layout.cell-count > 1 : Text { text: "\u{00B7}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                                                    Text { text: root.builder-node-count + " nodes"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                                                }
                                            }

                                            // Builder canvas
                                            canvas-bounds := Rectangle {
                                                horizontal-stretch: 1; vertical-stretch: 1;
                                                background: Palette.alternate-background.transparentize(40%);

                                                Rectangle {
                                                    clip: true;
                                                    property <length> page-w: root.page-layout.page-width * root.canvas-zoom * 1px + 48px;
                                                    property <length> page-h: root.page-layout.page-height * root.canvas-zoom * 1px + 48px;
                                                    property <length> vp-w: max(self.width, page-w);
                                                    property <length> vp-h: max(self.height, page-h);
                                                    property <length> scroll-x: 0px;
                                                    property <length> scroll-y: 0px;

                                                    // Ctrl/Cmd+scroll zooms, plain scroll pans
                                                    canvas-zoom-area := TouchArea {
                                                        width: parent.vp-w;
                                                        height: parent.vp-h;
                                                        x: parent.scroll-x;
                                                        y: parent.scroll-y;
                                                        scroll-event(e) => {
                                                            if (e.modifiers.control || e.modifiers.meta) {
                                                                root.canvas-zoom = clamp(root.canvas-zoom + (e.delta-y / 1px) / 400.0, 0.25, 3.0);
                                                                return accept;
                                                            }
                                                            parent.scroll-x = clamp(parent.scroll-x + e.delta-x, -(parent.vp-w - parent.width), 0px);
                                                            parent.scroll-y = clamp(parent.scroll-y + e.delta-y, -(parent.vp-h - parent.height), 0px);
                                                            return accept;
                                                        }

                                                    VerticalLayout {
                                                        alignment: center; padding: 24px;
                                                        width: parent.width; height: parent.height;

                                                        Rectangle {
                                                            width: root.page-layout.page-width * root.canvas-zoom * 1px;
                                                            min-height: root.page-layout.page-height * root.canvas-zoom * 1px;
                                                            background: Palette.background;
                                                            border-width: 1px; border-color: Palette.foreground.transparentize(85%);
                                                            border-radius: 2px; drop-shadow-blur: 6px; drop-shadow-color: #00000008;

                                                            // Margin overlays (use visible, not if, to avoid subtree create/destroy during Flickable property eval)
                                                            Rectangle {
                                                                visible: root.page-layout.margin-top > 0.0;
                                                                x: 0px; y: 0px; width: parent.width;
                                                                height: root.page-layout.margin-top * root.canvas-zoom * 1px;
                                                                background: Palette.accent-background.transparentize(95%);
                                                            }
                                                            Rectangle {
                                                                visible: root.page-layout.margin-bottom > 0.0;
                                                                x: 0px; width: parent.width;
                                                                y: parent.height - root.page-layout.margin-bottom * root.canvas-zoom * 1px;
                                                                height: root.page-layout.margin-bottom * root.canvas-zoom * 1px;
                                                                background: Palette.accent-background.transparentize(95%);
                                                            }
                                                            Rectangle {
                                                                visible: root.page-layout.margin-left > 0.0;
                                                                x: 0px; y: root.page-layout.margin-top * root.canvas-zoom * 1px;
                                                                width: root.page-layout.margin-left * root.canvas-zoom * 1px;
                                                                height: parent.height - root.page-layout.margin-top * root.canvas-zoom * 1px - root.page-layout.margin-bottom * root.canvas-zoom * 1px;
                                                                background: Palette.accent-background.transparentize(95%);
                                                            }
                                                            Rectangle {
                                                                visible: root.page-layout.margin-right > 0.0;
                                                                y: root.page-layout.margin-top * root.canvas-zoom * 1px;
                                                                x: parent.width - root.page-layout.margin-right * root.canvas-zoom * 1px;
                                                                width: root.page-layout.margin-right * root.canvas-zoom * 1px;
                                                                height: parent.height - root.page-layout.margin-top * root.canvas-zoom * 1px - root.page-layout.margin-bottom * root.canvas-zoom * 1px;
                                                                background: Palette.accent-background.transparentize(95%);
                                                            }

                                                            // WYSIWYG live preview — ComponentContainer renders the compiled builder preview
                                                            // behind the grid overlay and grid chrome so those stay fully visible.
                                                            if root.builder-node-count > 0 : ComponentContainer {
                                                                x: 0px; y: 0px; width: parent.width; height: parent.height;
                                                                component-factory: root.preview-factory;
                                                            }

                                                            // Grid overlay
                                                            Rectangle {
                                                                visible: root.page-layout.show-grid;
                                                                x: 0px; y: 0px; width: parent.width; height: parent.height;
                                                                Rectangle { visible: root.page-layout.margin-left > 0.0; x: root.page-layout.margin-left * root.canvas-zoom * 1px; y: 0px; width: 1px; height: parent.height; background: Palette.accent-background.transparentize(82%); }
                                                                Rectangle { visible: root.page-layout.margin-right > 0.0; x: parent.width - root.page-layout.margin-right * root.canvas-zoom * 1px; y: 0px; width: 1px; height: parent.height; background: Palette.accent-background.transparentize(82%); }
                                                                Rectangle { visible: root.page-layout.margin-top > 0.0; x: 0px; y: root.page-layout.margin-top * root.canvas-zoom * 1px; width: parent.width; height: 1px; background: Palette.accent-background.transparentize(82%); }
                                                                Rectangle { visible: root.page-layout.margin-bottom > 0.0; x: 0px; y: parent.height - root.page-layout.margin-bottom * root.canvas-zoom * 1px; width: parent.width; height: 1px; background: Palette.accent-background.transparentize(82%); }
                                                                for cg[i] in root.column-gutters : Rectangle {
                                                                    visible: i < root.column-gutters-count;
                                                                    x: cg.offset * root.canvas-zoom * 1px + root.page-layout.margin-left * root.canvas-zoom * 1px;
                                                                    y: root.page-layout.margin-top * root.canvas-zoom * 1px;
                                                                    width: cg.size * root.canvas-zoom * 1px;
                                                                    height: parent.height - root.page-layout.margin-top * root.canvas-zoom * 1px - root.page-layout.margin-bottom * root.canvas-zoom * 1px;
                                                                    background: Palette.accent-background.transparentize(92%);
                                                                    Rectangle { x: 0px; y: 0px; width: 1px; height: parent.height; background: Palette.accent-background.transparentize(78%); }
                                                                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.accent-background.transparentize(78%); }
                                                                }
                                                                for rg[i] in root.row-gutters : Rectangle {
                                                                    visible: i < root.row-gutters-count;
                                                                    x: root.page-layout.margin-left * root.canvas-zoom * 1px;
                                                                    y: rg.offset * root.canvas-zoom * 1px + root.page-layout.margin-top * root.canvas-zoom * 1px;
                                                                    width: parent.width - root.page-layout.margin-left * root.canvas-zoom * 1px - root.page-layout.margin-right * root.canvas-zoom * 1px;
                                                                    height: rg.size * root.canvas-zoom * 1px;
                                                                    background: Palette.accent-background.transparentize(92%);
                                                                    Rectangle { x: 0px; y: 0px; width: parent.width; height: 1px; background: Palette.accent-background.transparentize(78%); }
                                                                    Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.accent-background.transparentize(78%); }
                                                                }
                                                            }

                                                            // Content area
                                                            Rectangle {
                                                                // Grid cells (interactive page grid — inline to avoid component recursion)
                                                                for cell[i] in root.grid-cells : Rectangle {
                                                                    visible: i < root.grid-cells-count;
                                                                    x: (root.page-layout.margin-left + cell.x) * root.canvas-zoom * 1px;
                                                                    y: (root.page-layout.margin-top + cell.y) * root.canvas-zoom * 1px;
                                                                    width: cell.width * root.canvas-zoom * 1px;
                                                                    height: max(cell.height * root.canvas-zoom * 1px, 40px * root.canvas-zoom);
                                                                    border-width: 1px;
                                                                    border-color: cell.selected
                                                                        ? Palette.accent-background.transparentize(40%)
                                                                        : Palette.foreground.transparentize(88%);
                                                                    border-radius: 4px;
                                                                    background: cell.is-empty
                                                                        ? (grid-cell-touch.has-hover && root.drag-component-type != ""
                                                                            ? Palette.accent-background.transparentize(85%)
                                                                            : (grid-cell-touch.has-hover ? Palette.accent-background.transparentize(94%) : transparent))
                                                                        : (cell.selected
                                                                            ? Palette.accent-background.transparentize(92%)
                                                                            : transparent);

                                                                    VerticalLayout {
                                                                        visible: cell.is-empty;
                                                                        alignment: center;
                                                                        HorizontalLayout {
                                                                            alignment: center;
                                                                            Text {
                                                                                text: root.drag-component-type != "" ? "\u{2B07}" : "+";
                                                                                color: grid-cell-touch.has-hover
                                                                                    ? Palette.accent-background.transparentize(20%)
                                                                                    : Palette.foreground.transparentize(70%);
                                                                                font-size: max(10px, (root.drag-component-type != "" ? 18px : 24px) * root.canvas-zoom);
                                                                                font-weight: 300;
                                                                                horizontal-alignment: center;
                                                                                vertical-alignment: center;
                                                                            }
                                                                        }
                                                                        Text {
                                                                            visible: grid-cell-touch.has-hover;
                                                                            text: root.drag-component-type != ""
                                                                                ? ("Place " + root.drag-component-type)
                                                                                : "Click to add component";
                                                                            color: root.drag-component-type != ""
                                                                                ? Palette.accent-background
                                                                                : Palette.foreground.transparentize(50%);
                                                                            font-size: max(8px, 10px * root.canvas-zoom);
                                                                            horizontal-alignment: center;
                                                                        }
                                                                    }

                                                                    VerticalLayout {
                                                                        visible: !cell.is-empty;
                                                                        padding: max(4px, 8px * root.canvas-zoom);
                                                                        spacing: 4px;
                                                                        alignment: center;
                                                                        Text {
                                                                            text: cell.component-type;
                                                                            color: cell.selected
                                                                                ? Palette.foreground
                                                                                : Palette.foreground.transparentize(30%);
                                                                            font-size: max(8px, 11px * root.canvas-zoom);
                                                                            font-weight: 600;
                                                                            horizontal-alignment: center;
                                                                        }
                                                                        Text {
                                                                            visible: cell.preview-text != "" && root.canvas-zoom >= 0.5;
                                                                            text: cell.preview-text;
                                                                            color: Palette.foreground.transparentize(50%);
                                                                            font-size: max(8px, 11px * root.canvas-zoom);
                                                                            horizontal-alignment: center;
                                                                            overflow: elide;
                                                                        }
                                                                    }

                                                                    grid-cell-touch := TouchArea {
                                                                        mouse-cursor: pointer;
                                                                        clicked => {
                                                                            if root.drag-component-type != "" {
                                                                                root.grid-cell-add-component(root.drag-component-type, cell.path);
                                                                            } else if cell.is-empty {
                                                                                root.picker-show(cell.path, parent.absolute-position.x / 1px, parent.absolute-position.y / 1px);
                                                                            } else {
                                                                                root.grid-cell-clicked(cell.path);
                                                                            }
                                                                        }
                                                                    }
                                                                }

                                                                // Contextual edge "+" handles — appear on hover at cell boundaries
                                                                for handle[hi] in root.grid-edge-handles : Rectangle {
                                                                    visible: hi < root.grid-edge-handles-count;
                                                                    x: (root.page-layout.margin-left + handle.x) * root.canvas-zoom * 1px;
                                                                    y: (root.page-layout.margin-top + handle.y) * root.canvas-zoom * 1px;
                                                                    width: max(handle.width * root.canvas-zoom * 1px, 14px);
                                                                    height: max(handle.height * root.canvas-zoom * 1px, 14px);
                                                                    background: transparent;

                                                                    Rectangle {
                                                                        visible: edge-handle-touch.has-hover;
                                                                        width: 20px; height: 20px; border-radius: 10px;
                                                                        background: Palette.accent-background;
                                                                        x: handle.edge == "top" || handle.edge == "bottom"
                                                                            ? min(max(0px, edge-handle-touch.mouse-x - 10px), parent.width - self.width)
                                                                            : (parent.width - self.width) / 2;
                                                                        y: handle.edge == "left" || handle.edge == "right"
                                                                            ? min(max(0px, edge-handle-touch.mouse-y - 10px), parent.height - self.height)
                                                                            : (parent.height - self.height) / 2;
                                                                        Text {
                                                                            text: "+";
                                                                            color: Palette.accent-foreground;
                                                                            font-size: 14px; font-weight: 700;
                                                                            horizontal-alignment: center; vertical-alignment: center;
                                                                        }
                                                                    }

                                                                    edge-handle-touch := TouchArea {
                                                                        mouse-cursor: pointer;
                                                                        clicked => {
                                                                            root.grid-add-at-edge(handle.cell-path, handle.edge);
                                                                        }
                                                                    }
                                                                }

                                                                // Selection overlays on top of the WYSIWYG preview
                                                                if root.preview-factory-ready && root.preview-nodes-count > 0 : Rectangle {
                                                                    vertical-stretch: 1;
                                                                    for pn[i] in root.preview-nodes : Rectangle {
                                                                        visible: i < root.preview-nodes-count && pn.selected;
                                                                        x: pn.x * root.canvas-zoom * 1px;
                                                                        y: pn.y * root.canvas-zoom * 1px;
                                                                        width: pn.w * root.canvas-zoom * 1px;
                                                                        height: pn.h * root.canvas-zoom * 1px;
                                                                        border-width: 2px;
                                                                        border-color: Palette.accent-background;
                                                                        border-radius: pn.border-radius * 1px;
                                                                        background: Palette.accent-background.transparentize(90%);
                                                                        TouchArea {
                                                                            mouse-cursor: pointer;
                                                                            clicked => { root.builder-node-clicked(pn.id); }
                                                                        }
                                                                    }
                                                                }

                                                                VerticalLayout {
                                                                    visible: root.builder-node-count == 0 && root.grid-cells-count == 0;
                                                                    alignment: center; spacing: 8px; padding-top: 80px;
                                                                    Text { text: "Empty document"; color: Palette.foreground.transparentize(50%); font-size: 16px; horizontal-alignment: center; }
                                                                    Text { text: "Add a component from the palette to get started."; color: Palette.foreground.transparentize(60%); font-size: 12px; horizontal-alignment: center; }
                                                                }
                                                            }
                                                        }
                                                    }
                                                    } // canvas-zoom-area TouchArea
                                                } // clip Rectangle (replaces Flickable)
                                            }
                                        }
                                        // COMPONENT PALETTE
                                        // ════════════════════════════════════
                                        if panel.panel-id == "component-palette" : Rectangle {
                                            background: Palette.alternate-background;
                                            ScrollView {
                                                vertical-stretch: 1;
                                                VerticalLayout {
                                                    padding: 12px; spacing: 6px;

                                                    // Components list
                                                    Rectangle {
                                                        height: 20px;
                                                        HorizontalLayout {
                                                            spacing: 6px; alignment: start;
                                                            Image { source: root.components-expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-left.svg"); width: 10px; height: 10px; colorize: Palette.foreground.transparentize(30%); y: 1px; }
                                                            Image { source: @image-url("icons/plus.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                                                            Text { text: "Components"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                                        }
                                                        TouchArea { mouse-cursor: pointer; clicked => { root.components-expanded = !root.components-expanded; } }
                                                    }

                                                    if root.components-expanded : VerticalLayout {
                                                        min-width: 200px; spacing: 1px;
                                                        for comp[i] in root.component-palette : Rectangle {
                                                            property <bool> cat-expanded:
                                                                comp.category == "CONTENT" ? root.cat-content-expanded :
                                                                comp.category == "LAYOUT" ? root.cat-layout-expanded :
                                                                comp.category == "FORM" ? root.cat-form-expanded :
                                                                comp.category == "DECORATION" ? root.cat-decoration-expanded :
                                                                comp.category == "PREFABS" ? root.cat-prefabs-expanded : true;
                                                            visible: i < root.component-palette-count && (comp.is-header || cat-expanded);
                                                            height: comp.is-header ? 28px : (cat-expanded ? 36px : 0px);
                                                            if comp.is-header : Rectangle {
                                                                HorizontalLayout {
                                                                    padding-left: 10px; padding-top: 8px; spacing: 4px; alignment: start;
                                                                    VerticalLayout {
                                                                        alignment: center; padding-top: 1px;
                                                                        Image {
                                                                            source: cat-expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-left.svg");
                                                                            width: 8px; height: 8px;
                                                                            colorize: Palette.foreground.transparentize(50%);
                                                                        }
                                                                    }
                                                                    Text { text: comp.label; color: Palette.foreground.transparentize(40%); font-size: 10px; font-weight: 700; letter-spacing: 0.5px; }
                                                                }
                                                                TouchArea {
                                                                    mouse-cursor: pointer;
                                                                    clicked => {
                                                                        if (comp.category == "CONTENT") { root.cat-content-expanded = !root.cat-content-expanded; }
                                                                        if (comp.category == "LAYOUT") { root.cat-layout-expanded = !root.cat-layout-expanded; }
                                                                        if (comp.category == "FORM") { root.cat-form-expanded = !root.cat-form-expanded; }
                                                                        if (comp.category == "DECORATION") { root.cat-decoration-expanded = !root.cat-decoration-expanded; }
                                                                        if (comp.category == "PREFABS") { root.cat-prefabs-expanded = !root.cat-prefabs-expanded; }
                                                                    }
                                                                }
                                                            }
                                                            if !comp.is-header && cat-expanded : Rectangle {
                                                                background: root.drag-component-type == comp.component-type
                                                                    ? Palette.accent-background.transparentize(80%)
                                                                    : (palette-touch.has-hover ? Palette.control-background : transparent);
                                                                border-radius: 4px;
                                                                border-width: root.drag-component-type == comp.component-type ? 1px : 0px;
                                                                border-color: Palette.accent-background.transparentize(50%);
                                                                HorizontalLayout {
                                                                    padding-left: 10px; padding-right: 10px; spacing: 8px; alignment: start;
                                                                    VerticalLayout {
                                                                        alignment: center;
                                                                        if comp.component-type == "text" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "image" : Image { source: @image-url("icons/image.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "container" || comp.component-type == "form" || comp.component-type == "button" || comp.component-type == "card" : Image { source: @image-url("icons/box.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "columns" : Image { source: @image-url("icons/columns.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "list" : Image { source: @image-url("icons/list.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "table" : Image { source: @image-url("icons/table.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "tabs" : Image { source: @image-url("icons/layout.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "accordion" : Image { source: @image-url("icons/chevron-down.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "divider" : Image { source: @image-url("icons/minus.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "spacer" : Image { source: @image-url("icons/grip.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "code" : Image { source: @image-url("icons/code.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                        if comp.component-type == "input" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                                                    }
                                                                    VerticalLayout { alignment: center; Text { text: comp.label; color: Palette.foreground; font-size: 12px; font-weight: 500; } }
                                                                }
                                                                palette-touch := TouchArea {
                                                                    mouse-cursor: pointer;
                                                                    clicked => {
                                                                        root.add-component(comp.component-type);
                                                                    }
                                                                    changed has-hover => {
                                                                        if (self.has-hover) { root.help-hover("builder.components." + comp.component-type, parent.absolute-position.x + parent.width + 8px, parent.absolute-position.y); }
                                                                        if (!self.has-hover) { root.help-leave(); }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }

                                                    Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }

                                                    // Page Layout section
                                                    Rectangle {
                                                        height: 20px;
                                                        HorizontalLayout {
                                                            spacing: 6px; alignment: start;
                                                            Image { source: root.page-layout-expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-left.svg"); width: 10px; height: 10px; colorize: Palette.foreground.transparentize(30%); y: 1px; }
                                                            Image { source: @image-url("icons/layout.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                                                            Text { text: "Page Layout"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                                        }
                                                        TouchArea { mouse-cursor: pointer; clicked => { root.page-layout-expanded = !root.page-layout-expanded; } }
                                                    }
                                                    if root.page-layout-expanded : HorizontalLayout {
                                                        spacing: 8px; alignment: start; height: 28px;
                                                        Switch { checked: root.page-layout.show-grid; toggled => { root.toggle-grid-overlay(); } }
                                                        Text { text: "Show grid"; color: Palette.foreground; font-size: 12px; vertical-alignment: center; }
                                                    }
                                                    if root.page-layout-expanded : VerticalLayout {
                                                        spacing: 2px;
                                                        Text { text: "Size"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                                        ComboBox { height: 28px; model: ["Responsive", "A4", "A3", "A5", "Letter", "Legal", "Tabloid", "Custom"]; current-value: root.page-layout.page-size-label; selected(val) => { root.page-layout-edited("page_size", val); } }
                                                    }
                                                    if root.page-layout-expanded : VerticalLayout {
                                                        spacing: 2px;
                                                        Text { text: "Cells"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                                        Text { text: root.page-layout.cell-count; color: Palette.foreground; font-size: 12px; }
                                                    }
                                                    if root.page-layout-expanded : VerticalLayout {
                                                        spacing: 2px;
                                                        Text { text: "Gap"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                                        HorizontalLayout { spacing: 4px; height: 24px;
                                                            LineEdit { width: 48px; height: 24px; text: root.page-layout.column-gap; placeholder-text: "0"; accepted(val) => { root.page-layout-edited("column_gap", val); } }
                                                            Slider { horizontal-stretch: 1; height: 20px; minimum: 0; maximum: 128; value: root.page-layout.column-gap; changed(val) => { root.page-layout-edited("column_gap", round(val)); } }
                                                        }
                                                    }

                                                    Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }

                                                    // Search
                                                    HorizontalLayout {
                                                        spacing: 6px;
                                                        Image { source: @image-url("icons/search.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(50%); y: 7px; }
                                                        LineEdit { height: 28px; horizontal-stretch: 1; text: root.search-query; placeholder-text: "Search nodes..."; edited(text) => { root.search-input(text); } }
                                                    }
                                                    if root.search-results-count > 0 : VerticalLayout {
                                                        spacing: 2px;
                                                        for result[i] in root.search-results : Rectangle {
                                                            visible: i < root.search-results-count;
                                                            height: 44px; background: Palette.control-background; border-radius: 4px;
                                                            VerticalLayout { padding: 6px; spacing: 2px;
                                                                Text { text: result.node-id + " \u{00B7} " + result.field; color: Palette.foreground; font-size: 11px; overflow: elide; }
                                                                Text { text: result.snippet; color: Palette.foreground.transparentize(30%); font-size: 10px; overflow: elide; }
                                                            }
                                                            TouchArea { mouse-cursor: pointer; clicked => { root.search-result-clicked(result.node-id); } }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        // ════════════════════════════════════
                                        // INSPECTOR (Layers)
                                        // ════════════════════════════════════
                                        if panel.panel-id == "inspector" : Rectangle {
                                            background: Palette.alternate-background;
                                            ScrollView {
                                                vertical-stretch: 1;
                                                VerticalLayout {
                                                    padding: 12px; spacing: 6px;
                                                    Rectangle {
                                                        height: 20px;
                                                        HorizontalLayout {
                                                            spacing: 6px; alignment: start;
                                                            Image { source: @image-url("icons/tree.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                                                            Text { text: "Layers"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                                        }
                                                    }
                                                    VerticalLayout {
                                                        min-width: 200px; spacing: 1px;
                                                        for node[i] in root.inspector-nodes : InspectorRow {
                                                            visible: i < root.inspector-nodes-count;
                                                            node-id: node.id; component-id: node.component-id; depth: node.depth; selected: node.selected; kind: node.kind;
                                                            clicked => { root.node-clicked(node.id); }
                                                            move-up => { root.node-move-up(node.id); }
                                                            move-down => { root.node-move-down(node.id); }
                                                            delete-track => { root.inspector-delete-track(node.id); }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        // ════════════════════════════════════
                                        // EXPLORER
                                        // ════════════════════════════════════
                                        if panel.panel-id == "explorer" : Rectangle {
                                            background: Palette.alternate-background;
                                            ScrollView {
                                                vertical-stretch: 1;
                                                VerticalLayout {
                                                    padding: 12px; spacing: 4px;
                                                    HorizontalLayout {
                                                        spacing: 6px; alignment: space-between;
                                                        Text { text: "Explorer"; color: Palette.foreground; font-size: 14px; font-weight: 700; }
                                                        HorizontalLayout {
                                                            spacing: 2px; alignment: end;
                                                            IconButton { icon: @image-url("icons/list.svg"); clicked => { root.explorer-list-mode = true; } }
                                                            IconButton { icon: @image-url("icons/columns.svg"); clicked => { root.explorer-list-mode = false; } }
                                                        }
                                                    }
                                                    Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                                    for enode[i] in root.explorer-nodes : Rectangle {
                                                        visible: i < root.explorer-nodes-count;
                                                        height: 30px;
                                                        background: enode.is-active ? Palette.accent-background.transparentize(85%) : (exp-touch.has-hover ? Palette.control-background : transparent);
                                                        border-radius: 4px;
                                                        HorizontalLayout {
                                                            padding-left: enode.depth * 16px + 8px; spacing: 6px; alignment: start;
                                                            if enode.kind == "app" || enode.kind == "page" : Image {
                                                                source: enode.expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-left.svg");
                                                                width: 10px; height: 10px; colorize: Palette.foreground.transparentize(40%); y: 2px;
                                                                TouchArea { mouse-cursor: pointer; clicked => { root.explorer-toggle-expand(enode.id); } }
                                                            }
                                                            if enode.kind == "app" : Image { source: @image-url("icons/box.svg"); width: 14px; height: 14px; colorize: enode.is-active ? Palette.accent-background : Palette.foreground.transparentize(40%); }
                                                            if enode.kind == "page" : Image { source: @image-url("icons/layout.svg"); width: 14px; height: 14px; colorize: enode.is-active ? Palette.accent-background : Palette.foreground.transparentize(40%); }
                                                            if enode.kind == "node" : Image { source: @image-url("icons/grip.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(50%); }
                                                            Text { text: enode.label; color: enode.is-active ? Palette.accent-foreground : Palette.foreground; font-size: 12px; font-weight: enode.is-active ? 600 : 400; vertical-alignment: center; overflow: elide; }
                                                        }
                                                        exp-touch := TouchArea { mouse-cursor: pointer; clicked => { root.explorer-node-clicked(enode.id); } }
                                                    }
                                                }
                                            }
                                        }

                                        // ════════════════════════════════════
                                        // PROPERTIES
                                        // ══════════���═════════════════════════
                                        if panel.panel-id == "properties" : Rectangle {
                                            background: Palette.alternate-background;
                                            VerticalLayout {
                                                width: 100%; height: 100%;
                                                padding: 16px; spacing: 8px;

                                                if root.has-selection && root.selected-component != "" : HorizontalLayout {
                                                    spacing: 6px; alignment: start;
                                                    Image { source: @image-url("icons/sliders.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); y: 1px; }
                                                    Text { text: root.selected-component; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                                }

                                                if root.has-selection && root.selected-component != "" : ScrollView {
                                                    vertical-stretch: 1;
                                                    VerticalLayout {
                                                        min-width: 220px; spacing: 4px;
                                                        for field[i] in root.field-rows : FieldEditor {
                                                            visible: i < root.field-rows-count;
                                                            key: field.key; label: field.label; kind: field.kind; value: field.value; required: field.required;
                                                            min: field.min; max: field.max; has-bounds: field.has-bounds; options: field.options; swatch: field.swatch;
                                                            user-swatches: root.user-color-swatches;
                                                            field-edited(key, val) => { root.field-edited(key, val); }
                                                            field-edited-number(key, val) => { root.field-edited-number(key, val); }
                                                            file-browse-requested(key) => { root.file-browse-requested(key); }
                                                            save-color-swatch(hex) => { root.save-color-swatch(hex); }
                                                        }
                                                        if root.style-rows-count > 0 : Rectangle { height: 8px; }
                                                        if root.style-rows-count > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                                        if root.style-rows-count > 0 : Rectangle { height: 4px; }
                                                        if root.style-rows-count > 0 : HorizontalLayout {
                                                            spacing: 6px; alignment: start;
                                                            Text { text: "Style"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                                            Text { text: "(cascading)"; color: Palette.foreground.transparentize(60%); font-size: 10px; vertical-alignment: center; }
                                                        }
                                                        for sfield[i] in root.style-rows : FieldEditor {
                                                            visible: i < root.style-rows-count;
                                                            key: sfield.key; label: sfield.label; kind: sfield.kind; value: sfield.value; required: sfield.required;
                                                            min: sfield.min; max: sfield.max; has-bounds: sfield.has-bounds; options: sfield.options; swatch: sfield.swatch;
                                                            user-swatches: root.user-color-swatches;
                                                            field-edited(key, val) => { root.style-field-edited(key, val); }
                                                            field-edited-number(key, val) => { root.style-field-edited-number(key, val); }
                                                            save-color-swatch(hex) => { root.save-color-swatch(hex); }
                                                        }
                                                        if root.layout-rows-count > 0 : Rectangle { height: 8px; }
                                                        if root.layout-rows-count > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                                        if root.layout-rows-count > 0 : Rectangle { height: 4px; }
                                                        if root.layout-rows-count > 0 : HorizontalLayout {
                                                            spacing: 6px; alignment: start;
                                                            Image { source: @image-url("icons/layout.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); y: 1px; }
                                                            Text { text: "Layout"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                                        }
                                                        for lfield[i] in root.layout-rows : FieldEditor {
                                                            visible: i < root.layout-rows-count;
                                                            key: lfield.key; label: lfield.label; kind: lfield.kind; value: lfield.value; required: lfield.required;
                                                            min: lfield.min; max: lfield.max; has-bounds: lfield.has-bounds; options: lfield.options; swatch: lfield.swatch;
                                                            user-swatches: root.user-color-swatches;
                                                            field-edited(key, val) => { root.layout-field-edited(key, val); }
                                                            field-edited-number(key, val) => { root.layout-field-edited-number(key, val); }
                                                            save-color-swatch(hex) => { root.save-color-swatch(hex); }
                                                        }
                                                        if root.variant-items-count > 0 : Rectangle { height: 8px; }
                                                        if root.variant-items-count > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                                        if root.variant-items-count > 0 : Rectangle { height: 4px; }
                                                        if root.variant-items-count > 0 : HorizontalLayout { spacing: 6px; alignment: start; Text { text: "Variants"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; } }
                                                        for vitem[i] in root.variant-items : HorizontalLayout {
                                                            visible: i < root.variant-items-count;
                                                            spacing: 8px; height: 28px;
                                                            Text { text: vitem.label; color: Palette.foreground.transparentize(40%); font-size: 11px; width: 80px; vertical-alignment: center; }
                                                            ComboBox { model: vitem.options; current-value: vitem.selected; horizontal-stretch: 1; selected(val) => { root.field-edited(vitem.key, val); } }
                                                        }
                                                        if root.modifier-items-count > 0 : Rectangle { height: 8px; }
                                                        if root.modifier-items-count > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                                        if root.modifier-items-count > 0 : Rectangle { height: 4px; }
                                                        if root.modifier-items-count > 0 : HorizontalLayout { spacing: 6px; alignment: start; Text { text: "Modifiers"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; } }
                                                        for mitem[i] in root.modifier-items : Rectangle {
                                                            visible: i < root.modifier-items-count;
                                                            height: 24px;
                                                            HorizontalLayout { spacing: 6px; alignment: start; padding-left: 4px;
                                                                Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Palette.accent-background; y: 5px; }
                                                                Text { text: mitem.label; color: Palette.foreground.transparentize(20%); font-size: 11px; vertical-alignment: center; }
                                                            }
                                                        }
                                                        if root.signal-items-count > 0 : Rectangle { height: 8px; }
                                                        if root.signal-items-count > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                                        if root.signal-items-count > 0 : Rectangle { height: 4px; }
                                                        if root.signal-items-count > 0 : HorizontalLayout {
                                                            spacing: 6px; alignment: start;
                                                            Text { text: "Signals"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                                            if root.connection-count > 0 : Text {
                                                                text: root.connection-count == 1 ? "1 connection" : "\{root.connection-count} connections";
                                                                color: Palette.accent-background; font-size: 10px; vertical-alignment: center;
                                                            }
                                                        }
                                                        for sitem[i] in root.signal-items : Rectangle {
                                                            visible: i < root.signal-items-count;
                                                            height: 24px;
                                                            HorizontalLayout { spacing: 6px; alignment: start; padding-left: 4px;
                                                                Text { text: "\u{26A1}"; font-size: 10px; vertical-alignment: center; }
                                                                Text { text: sitem.name; color: Palette.foreground.transparentize(20%); font-size: 11px; font-weight: 500; vertical-alignment: center; }
                                                                Text { text: sitem.description; color: Palette.foreground.transparentize(50%); font-size: 10px; vertical-alignment: center; }
                                                            }
                                                        }
                                                        if root.resource-count > 0 || root.prefab-count > 0 : Rectangle { height: 8px; }
                                                        if root.resource-count > 0 || root.prefab-count > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                                        if root.resource-count > 0 || root.prefab-count > 0 : Rectangle { height: 4px; }
                                                        if root.resource-count > 0 : Text { text: root.resource-count == 1 ? "1 resource" : "\{root.resource-count} resources"; color: Palette.foreground.transparentize(50%); font-size: 10px; }
                                                        if root.prefab-count > 0 : Text { text: root.prefab-count == 1 ? "1 prefab" : "\{root.prefab-count} prefabs"; color: Palette.foreground.transparentize(50%); font-size: 10px; }
                                                    }
                                                }

                                                if !root.has-selection : VerticalLayout {
                                                    vertical-stretch: 1;
                                                    spacing: 8px; padding-top: 24px;
                                                    Text { text: "Page styles"; color: Palette.foreground.transparentize(30%); font-size: 13px; font-weight: 600; horizontal-alignment: center; }
                                                    Text { text: "Set global styles that cascade to all components on this page."; color: Palette.foreground.transparentize(50%); font-size: 11px; wrap: word-wrap; horizontal-alignment: center; }
                                                    if root.style-rows-count > 0 : ScrollView {
                                                        vertical-stretch: 1;
                                                        VerticalLayout {
                                                            min-width: 200px; spacing: 4px; padding-top: 8px;
                                                            for sfield[i] in root.style-rows : FieldEditor {
                                                                visible: i < root.style-rows-count;
                                                                key: sfield.key; label: sfield.label; kind: sfield.kind; value: sfield.value; required: sfield.required;
                                                                min: sfield.min; max: sfield.max; has-bounds: sfield.has-bounds; options: sfield.options; swatch: sfield.swatch;
                                                                user-swatches: root.user-color-swatches;
                                                                field-edited(key, val) => { root.style-field-edited(key, val); }
                                                                field-edited-number(key, val) => { root.style-field-edited-number(key, val); }
                                                                save-color-swatch(hex) => { root.save-color-swatch(hex); }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        // ════════════════════════════════════
                                        // CODE EDITOR
                                        // ════════════════════════════════════
                                        if panel.panel-id == "code-editor" : Rectangle {
                                            horizontal-stretch: 1; vertical-stretch: 1;
                                            background: #1e222a;

                                            property <length> line-h: 18px;
                                            property <length> gutter-w: 56px;
                                            property <length> content-pad: 8px;
                                            property <string> ed-font: "Menlo";
                                            property <length> ed-font-size: 13px;

                                            cursor-measure := Text { text: root.editor-cursor-prefix; font-size: ed-font-size; font-family: ed-font; opacity: 0; }
                                            measure-char := Text { text: "0000000000"; font-size: ed-font-size; font-family: ed-font; opacity: 0; }
                                            property <length> char-w: max(1px, measure-char.preferred-width / 10);
                                            property <length> tab-indent: 4 * char-w;

                                            editor-focus := FocusScope {
                                                width: 100%; height: 100%;

                                                key-pressed(event) => {
                                                    if (event.text == Key.Return) { root.editor-action("enter"); return accept; }
                                                    if (event.text == Key.Backspace) {
                                                        if (event.modifiers.control) { root.editor-action("ctrl-backspace"); }
                                                        else { root.editor-action("backspace"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.Delete) {
                                                        if (event.modifiers.control) { root.editor-action("ctrl-delete"); }
                                                        else { root.editor-action("delete"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.Tab) {
                                                        if (event.modifiers.shift) { root.editor-action("shift-tab"); }
                                                        else { root.editor-action("tab"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.UpArrow) {
                                                        if (event.modifiers.shift) { root.editor-action("shift-up"); }
                                                        else { root.editor-action("up"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.DownArrow) {
                                                        if (event.modifiers.shift) { root.editor-action("shift-down"); }
                                                        else { root.editor-action("down"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.LeftArrow) {
                                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-left"); }
                                                        else if (event.modifiers.control) { root.editor-action("ctrl-left"); }
                                                        else if (event.modifiers.shift) { root.editor-action("shift-left"); }
                                                        else { root.editor-action("left"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.RightArrow) {
                                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-right"); }
                                                        else if (event.modifiers.control) { root.editor-action("ctrl-right"); }
                                                        else if (event.modifiers.shift) { root.editor-action("shift-right"); }
                                                        else { root.editor-action("right"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.Home) {
                                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-home"); }
                                                        else if (event.modifiers.control) { root.editor-action("ctrl-home"); }
                                                        else if (event.modifiers.shift) { root.editor-action("shift-home"); }
                                                        else { root.editor-action("home"); }
                                                        return accept;
                                                    }
                                                    if (event.text == Key.End) {
                                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-end"); }
                                                        else if (event.modifiers.control) { root.editor-action("ctrl-end"); }
                                                        else if (event.modifiers.shift) { root.editor-action("shift-end"); }
                                                        else { root.editor-action("end"); }
                                                        return accept;
                                                    }
                                                    if (event.modifiers.control) {
                                                        if (event.text == "\u{0001}") { root.editor-action("select-all"); return accept; }
                                                        if (event.text == "\u{0004}") { root.editor-action("duplicate-line"); return accept; }
                                                        if (event.text == "\u{000b}") { root.editor-action("delete-line"); return accept; }
                                                        return reject;
                                                    }
                                                    if (event.text == Key.Escape) { root.escape-pressed(); return accept; }
                                                    root.editor-char-typed(event.text);
                                                    return accept;
                                                }

                                                editor-sv := ScrollView {
                                                    width: 100%; height: 100%;
                                                    VerticalLayout {
                                                        spacing: 0px; alignment: start;
                                                        for line[idx] in root.editor-lines : Rectangle {
                                                            visible: idx < root.editor-lines-count;
                                                            height: line-h;
                                                            background: line.is-current ? #ffffff06 : transparent;
                                                            if line.sel-from >= 0 : Rectangle {
                                                                x: gutter-w + content-pad + line.sel-from * char-w; y: 0px;
                                                                width: line.sel-to > line.sel-from ? (line.sel-to - line.sel-from) * char-w : parent.width - gutter-w - content-pad - line.sel-from * char-w;
                                                                height: line-h; background: #264f7880;
                                                            }
                                                            for guide in line.indent-guides : Rectangle {
                                                                x: gutter-w + content-pad + (guide.depth - 1) * tab-indent; y: 0px; width: 1px; height: line-h;
                                                                background: guide.active ? #528bff40 : #ffffff12;
                                                            }
                                                            Rectangle {
                                                                x: 0px; y: 0px; width: gutter-w; height: line-h; background: #161a22;
                                                                Text { x: 0px; width: 36px; text: line.number; color: line.is-current ? #ffffff60 : #ffffff22; font-size: ed-font-size; font-family: ed-font; horizontal-alignment: right; vertical-alignment: center; }
                                                                if line.is-foldable || line.is-folded : Text {
                                                                    x: 38px; width: 14px; height: line-h;
                                                                    text: line.is-folded ? "\u{25B6}" : "\u{25BC}";
                                                                    color: line.is-folded ? #528bff60 : #ffffff20; font-size: 8px; horizontal-alignment: center; vertical-alignment: center;
                                                                }
                                                            }
                                                            Rectangle { x: gutter-w - 1px; y: 0px; width: 1px; height: line-h; background: #ffffff08; }
                                                            HorizontalLayout {
                                                                x: gutter-w + content-pad; y: 0px; height: line-h; spacing: 0px; alignment: start;
                                                                for token in line.tokens : Text { text: token.text; color: token.token-color; font-size: ed-font-size; font-family: ed-font; vertical-alignment: center; horizontal-stretch: 0; }
                                                                if line.is-folded : Text { text: line.fold-preview; color: #ffffff30; font-size: ed-font-size; font-family: ed-font; vertical-alignment: center; horizontal-stretch: 0; }
                                                            }
                                                            if line.is-current && root.editor-cursor-visible : Rectangle {
                                                                x: gutter-w + content-pad + (root.editor-cursor-col > 0 ? cursor-measure.preferred-width : 0px);
                                                                y: 1px; width: 2px; height: line-h - 2px; background: #528bff;
                                                            }
                                                        }
                                                        Rectangle { vertical-stretch: 1; min-height: 200px; background: transparent; }
                                                    }
                                                }
                                            }

                                            editor-overlay := TouchArea {
                                                width: parent.width; height: parent.height; mouse-cursor: text;
                                                pointer-event(event) => {
                                                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                                                        editor-focus.focus();
                                                        if self.mouse-x < gutter-w {
                                                            root.editor-fold-toggle(clamp(floor((self.mouse-y - editor-sv.viewport-y) / line-h), 0, root.editor-lines-count - 1));
                                                        } else {
                                                            root.editor-click(
                                                                clamp(floor((self.mouse-y - editor-sv.viewport-y) / line-h), 0, root.editor-lines-count - 1),
                                                                max(0, floor((self.mouse-x - gutter-w - content-pad) / char-w))
                                                            );
                                                        }
                                                    }
                                                }
                                                moved => {
                                                    if self.pressed {
                                                        root.editor-drag(
                                                            clamp(floor((self.mouse-y - editor-sv.viewport-y) / line-h), 0, root.editor-lines-count - 1),
                                                            max(0, floor((self.mouse-x - gutter-w - content-pad) / char-w))
                                                        );
                                                    }
                                                }
                                                scroll-event(event) => {
                                                    editor-sv.viewport-y = clamp(editor-sv.viewport-y + event.delta-y, min(0px, editor-sv.height - editor-sv.viewport-height), 0px);
                                                    return accept;
                                                }
                                            }
                                        }

                                        // ════════════════════════════════════
                                        // IDENTITY
                                        // ════════════════════════════════════
                                        if panel.panel-id == "identity" : Rectangle {
                                            background: Palette.alternate-background;
                                            ScrollView {
                                                VerticalLayout {
                                                    min-width: 180px; padding: 16px; spacing: 8px; alignment: start;
                                                    Text { text: root.panel-title; color: Palette.foreground; font-size: 14px; font-weight: 700; letter-spacing: 0.3px; }
                                                    Text { text: root.panel-hint; color: Palette.foreground.transparentize(40%); font-size: 11px; wrap: word-wrap; }
                                                    if root.actions-count > 0 : VerticalLayout {
                                                        spacing: 4px; padding-top: 8px;
                                                        for action[i] in root.actions : Button { visible: i < root.actions-count; text: action.label; clicked => { root.clicked(i); } }
                                                    }
                                                }
                                            }
                                        }

                                        // ════════════════════════════════════
                                        // CONSOLE (placeholder)
                                        // ════════════════════════════════════
                                        if panel.panel-id == "console" : Rectangle {
                                            background: #1e222a;
                                            VerticalLayout {
                                                padding: 16px; spacing: 8px; alignment: start;
                                                Text { text: "Console"; color: #ffffff60; font-size: 12px; font-weight: 600; }
                                                Text { text: "No output"; color: #ffffff30; font-size: 11px; }
                                            }
                                        }

                                        // ���═══════════════════════════════════
                                        // TIMELINE (placeholder)
                                        // ════════════════════════════════════
                                        if panel.panel-id == "timeline" : Rectangle {
                                            background: Palette.alternate-background;
                                            VerticalLayout {
                                                padding: 16px; spacing: 8px; alignment: center;
                                                Text { text: "Timeline"; color: Palette.foreground.transparentize(40%); font-size: 14px; font-weight: 600; horizontal-alignment: center; }
                                                Text { text: "Animation timeline (coming soon)"; color: Palette.foreground.transparentize(60%); font-size: 11px; horizontal-alignment: center; }
                                            }
                                        }

                                        // ═════════��══════════════════════════
                                        // NODE GRAPH (placeholder)
                                        // ═��══════════════════════════���═══════
                                        if panel.panel-id == "node-graph" : Rectangle {
                                            background: Palette.alternate-background;
                                            VerticalLayout {
                                                padding: 16px; spacing: 8px; alignment: center;
                                                Text { text: "Node Graph"; color: Palette.foreground.transparentize(40%); font-size: 14px; font-weight: 600; horizontal-alignment: center; }
                                                Text { text: "Visual node editor (coming soon)"; color: Palette.foreground.transparentize(60%); font-size: 11px; horizontal-alignment: center; }
                                            }
                                        }

                                        // ════════════════════════════════════
                                        // ASSET BROWSER (placeholder)
                                        // ══════════════════════════════���═════
                                        if panel.panel-id == "asset-browser" : Rectangle {
                                            background: Palette.alternate-background;
                                            VerticalLayout {
                                                padding: 16px; spacing: 8px; alignment: center;
                                                Text { text: "Asset Browser"; color: Palette.foreground.transparentize(40%); font-size: 14px; font-weight: 600; horizontal-alignment: center; }
                                                Text { text: "Media and asset management (coming soon)"; color: Palette.foreground.transparentize(60%); font-size: 11px; horizontal-alignment: center; }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Dock dividers ─────────────────────
                            for div[i] in root.dock-dividers : Rectangle {
                                visible: i < root.dock-dividers-count;
                                x: div.x * 1px;
                                y: div.y * 1px;
                                width: div.width * 1px;
                                height: div.height * 1px;
                                background: div-touch.has-hover || div-touch.pressed
                                    ? Palette.accent-background.transparentize(60%)
                                    : Palette.foreground.transparentize(92%);

                                div-touch := TouchArea {
                                    mouse-cursor: div.is-horizontal ? col-resize : row-resize;
                                    moved => {
                                        if (self.pressed && div.parent-size > 0.0) {
                                            root.dock-divider-dragged(div.addr-key,
                                                div.is-horizontal
                                                    ? (div.x + self.mouse-x / 1px - div.parent-origin) / div.parent-size
                                                    : (div.y + self.mouse-y / 1px - div.parent-origin) / div.parent-size);
                                        }
                                    }
                                }
                            }

                            // ── Docs sidebar overlay ──────────────
                            if root.docs-panel.visible : Rectangle {
                                width: 280px;
                                background: Palette.alternate-background;
                                Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }
                                VerticalLayout {
                                    padding: 16px; spacing: 0px;
                                    HorizontalLayout {
                                        spacing: 8px; alignment: start;
                                        Rectangle {
                                            width: 28px; height: 28px; border-radius: 6px;
                                            background: docs-back-touch.has-hover ? Palette.control-background : transparent;
                                            Image { source: @image-url("icons/chevron-left.svg"); width: 16px; height: 16px; colorize: docs-back-touch.has-hover ? Palette.foreground : Palette.foreground.transparentize(30%); }
                                            docs-back-touch := TouchArea { mouse-cursor: pointer; clicked => { root.docs-panel-close(); } }
                                        }
                                        VerticalLayout { alignment: center; Text { text: "Documentation"; color: Palette.foreground; font-size: 14px; font-weight: 700; } }
                                    }
                                    Rectangle { height: 12px; }
                                    Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                    Rectangle { height: 12px; }
                                    ScrollView {
                                        vertical-stretch: 1;
                                        VerticalLayout {
                                            spacing: 0px; alignment: start;
                                            DocsContent { doc-title: root.docs-panel.title; doc-summary: root.docs-panel.summary; doc-body: root.docs-panel.body; compact: true; }
                                            Rectangle { height: 16px; }
                                            Rectangle {
                                                height: 36px; border-radius: 6px;
                                                background: docs-open-touch.has-hover ? Palette.accent-background.transparentize(85%) : transparent;
                                                border-width: 1px; border-color: Palette.accent-background.transparentize(50%);
                                                HorizontalLayout {
                                                    padding-left: 12px; spacing: 6px; alignment: start;
                                                    Image { source: @image-url("icons/book.svg"); width: 14px; height: 14px; colorize: Palette.accent-background; }
                                                    Text { text: "Open in Docs"; color: Palette.accent-background; font-size: 12px; font-weight: 500; vertical-alignment: center; }
                                                }
                                                docs-open-touch := TouchArea { mouse-cursor: pointer; clicked => { root.docs-open-full(); } }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ── Workflow page bar (DaVinci-style bottom modes) ──
                    if !root.is-launchpad : Rectangle {
                        height: 32px;
                        background: Palette.alternate-background;
                        Rectangle { x: 0px; y: 0px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            alignment: center;
                            spacing: 0px;
                            for wp[i] in root.workflow-pages : Rectangle {
                                visible: i < root.workflow-pages-count;
                                height: 32px;
                                width: wp-bottom-label.preferred-width + 32px;
                                background: wp.active ? Palette.accent-background.transparentize(90%) : (wp-bottom-touch.has-hover ? Palette.control-background.transparentize(50%) : transparent);
                                Rectangle { x: 0px; y: parent.height - 2px; width: parent.width; height: 2px; background: wp.active ? Palette.accent-background : transparent; }
                                wp-bottom-label := Text {
                                    text: wp.label;
                                    color: wp.active ? Palette.foreground : Palette.foreground.transparentize(40%);
                                    font-size: 12px;
                                    font-weight: wp.active ? 600 : 400;
                                    letter-spacing: 0.5px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                wp-bottom-touch := TouchArea { mouse-cursor: pointer; clicked => { root.workflow-page-clicked(wp.id); } }
                            }
                        }
                    }

                    // ── Status bar ─────────────────────────────────
                    Rectangle {
                        height: 26px;
                        background: root.active-panel-id == 2 ? #1b1f27 : Palette.alternate-background;
                        Rectangle { x: 0px; y: 0px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; spacing: 8px; alignment: start;
                            Text { text: root.panel-title; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                            if !root.is-launchpad && root.active-app-name != "" : Text { text: "\u{203A}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if !root.is-launchpad && root.active-app-name != "" : Text { text: root.active-app-name; color: Palette.foreground.transparentize(30%); font-size: 11px; vertical-alignment: center; }
                            if !root.is-launchpad && root.active-page-name != "" : Text { text: "\u{203A}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if !root.is-launchpad && root.active-page-name != "" : Text { text: root.active-page-name; color: Palette.foreground.transparentize(30%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id != 2 && root.has-selection : Text { text: "\u{00B7}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id != 2 && root.has-selection : Text { text: "Selected"; color: Palette.accent-foreground; font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "\u{00B7}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "Ln " + (root.editor-cursor-line + 1) + ", Col " + (root.editor-cursor-col + 1); color: Palette.foreground.transparentize(30%); font-size: 11px; vertical-alignment: center; }
                            Rectangle { horizontal-stretch: 1; }
                            if !root.is-launchpad && root.active-panel-id == 1 : Text { text: root.builder-node-count + " nodes"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                            if !root.is-launchpad && root.active-panel-id == 1 : Text { text: "\u{00B7}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: root.editor-line-count + " lines"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "\u{00B7}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: root.editor-language; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "\u{00B7}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            Text { text: "\u{00B7}"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            Text { text: "Prism Studio"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                        }
                    }
                }
            }
        }
    }

    // ── Command palette ───────────────────────────────────────────
    if root.command-palette-visible : Rectangle { width: 100%; height: 100%; background: #00000060; TouchArea { clicked => { root.toggle-command-palette(); } } }
    if root.command-palette-visible : Rectangle {
        x: (root.width - 500px) / 2; y: 64px; width: 500px;
        height: min(root.command-results-count * 36px + 48px, 420px);
        background: Palette.alternate-background; border-radius: 8px; border-width: 1px; border-color: Palette.accent-background; clip: true;
        VerticalLayout {
            padding: 8px; spacing: 4px;
            HorizontalLayout {
                spacing: 8px;
                Image { source: @image-url("icons/search.svg"); width: 16px; height: 16px; colorize: Palette.foreground.transparentize(40%); y: 8px; }
                LineEdit { height: 32px; horizontal-stretch: 1; placeholder-text: "Type a command..."; edited(text) => { root.command-palette-input(text); } accepted(text) => { if (root.command-results-count > 0) { root.command-selected(0); } } }
            }
            ScrollView {
                VerticalLayout {
                    spacing: 1px;
                    for cmd[i] in root.command-results : Rectangle {
                        visible: i < root.command-results-count;
                        height: 32px; background: cmd-touch.has-hover ? Palette.control-background : transparent; border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; alignment: space-between;
                            HorizontalLayout {
                                spacing: 8px;
                                if cmd.category != "" : Text { text: cmd.category; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                                Text { text: cmd.label; color: Palette.foreground; font-size: 13px; vertical-alignment: center; }
                            }
                            if cmd.shortcut != "" : Rectangle {
                                background: Palette.control-background; border-radius: 3px; height: 20px; width: shortcut-text.preferred-width + 12px; y: 6px;
                                shortcut-text := Text { text: cmd.shortcut; color: Palette.foreground.transparentize(30%); font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                        cmd-touch := TouchArea { mouse-cursor: pointer; clicked => { root.command-selected(i); } }
                    }
                }
            }
        }
    }

    // ── Toasts ────────────────────────────────────────────────────
    if root.notifications-count > 0 : VerticalLayout {
        x: root.width - 340px; y: root.height - root.notifications-count * 100px - 20px; width: 320px; spacing: 8px;
        for notif[i] in root.notifications : Toast { visible: i < root.notifications-count; title: notif.title; body: notif.body; kind: notif.kind; dismissed => { root.dismiss-notification(notif.id); } }
    }

    // ── Menu dropdown ──────────────────────────────────────────────
    if fs.menu-active-index >= 0 : Rectangle {
        width: 100%; height: 100%; background: transparent;
        TouchArea { clicked => { fs.menu-active-index = -1; } }
    }
    if fs.menu-active-index >= 0 && fs.menu-active-index < root.menu-defs-count : Rectangle {
        property <int> mi: fs.menu-active-index;

        x: {
            // Approximate menu label position: 8px padding + index * 70px
            8px + mi * 70px
        }
        y: 28px;
        width: 220px;
        height: menu-drop-layout.preferred-height;
        background: Palette.alternate-background;
        border-radius: 8px;
        border-width: 1px;
        border-color: Palette.foreground.transparentize(85%);
        drop-shadow-blur: 12px;
        drop-shadow-color: #00000020;
        clip: true;

        menu-drop-layout := VerticalLayout {
            padding: 4px;
            spacing: 0px;

            for item[ii] in root.menu-defs[mi].items : Rectangle {
                height: item.is-separator ? 9px : 28px;

                if item.is-separator : Rectangle {
                    height: 1px;
                    y: 4px;
                    background: Palette.foreground.transparentize(85%);
                }

                if !item.is-separator : Rectangle {
                    background: menu-item-touch.has-hover ? Palette.accent-background.transparentize(85%) : transparent;
                    border-radius: 4px;
                    height: 28px;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        alignment: space-between;

                        Text {
                            text: item.label;
                            color: Palette.foreground;
                            font-size: 12px;
                            vertical-alignment: center;
                        }

                        if item.shortcut != "" : Rectangle {
                            background: Palette.control-background;
                            border-radius: 3px;
                            height: 18px;
                            width: shortcut-label.preferred-width + 10px;
                            y: 5px;
                            shortcut-label := Text {
                                text: item.shortcut;
                                color: Palette.foreground.transparentize(40%);
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    menu-item-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.menu-command(item.command-id);
                            fs.menu-active-index = -1;
                        }
                    }
                }
            }
        }
    }

    // ── Help tooltip ──────────────────────────────────────────────
    if root.help-tooltip.visible : Rectangle {
        x: min(root.help-tooltip.tip-x, root.width - 284px);
        y: min(root.help-tooltip.tip-y, root.height - tooltip-layout.preferred-height - 8px);
        width: 276px;
        height: tooltip-layout.preferred-height;
        border-radius: 10px; border-width: 1px;
        border-color: Palette.foreground.transparentize(85%);
        background: Palette.alternate-background; clip: true;

        // Behind everything: keeps tooltip alive on hover
        help-tip-touch := TouchArea {
            changed has-hover => {
                if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                if (!self.has-hover) { root.help-leave(); }
            }
        }

        tooltip-layout := VerticalLayout {
            Rectangle {
                height: 32px;
                HorizontalLayout {
                    padding: 8px; padding-left: 12px; spacing: 8px; alignment: start;
                    Image { source: @image-url("icons/help-circle.svg"); width: 12px; height: 12px; colorize: tooltip-header-touch.has-hover ? Palette.accent-foreground : Palette.accent-background; y: 2px; }
                    Text { text: root.help-tooltip.title; color: tooltip-header-touch.has-hover ? Palette.accent-foreground : Palette.foreground; font-size: 12px; font-weight: 600; vertical-alignment: center; overflow: elide; }
                }
                tooltip-header-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.help-entry-clicked(); }
                    changed has-hover => {
                        if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                        if (!self.has-hover) { root.help-leave(); }
                    }
                }
            }
            Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
            Rectangle {
                VerticalLayout {
                    padding: 10px; padding-left: 12px; padding-right: 12px;
                    Text { text: root.help-tooltip.summary; color: Palette.foreground.transparentize(30%); font-size: 12px; wrap: word-wrap; }
                }
            }
            if root.help-tooltip.has-docs && !root.docs-panel.visible && !root.docs-view.visible : Rectangle {
                height: 32px;
                Rectangle { y: 0px; height: 1px; width: parent.width; background: Palette.foreground.transparentize(85%); }
                HorizontalLayout {
                    padding: 8px; padding-left: 12px; spacing: 6px; alignment: start;
                    Image { source: @image-url("icons/book.svg"); width: 11px; height: 11px; colorize: Palette.accent-background; }
                    Text { text: "Open in Docs"; color: Palette.accent-background; font-size: 12px; }
                }
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.help-docs-clicked(); }
                    changed has-hover => {
                        if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                        if (!self.has-hover) { root.help-leave(); }
                    }
                }
            }
        }
    }

    // ── Component picker overlay (shown on empty grid cell click) ────
    // Uses visibility instead of `if` conditional to avoid destroying
    // elements mid-event (which triggers property recursion in Slint).
    // All property writes happen in Rust's deferred sync timer — the
    // clicked handler only fires a callback, never sets Slint properties.
    Rectangle {
        width: 100%; height: 100%;
        visible: root.show-component-picker;
        TouchArea {
            width: 100%; height: 100%;
            clicked => { root.picker-dismiss(); }
        }

        Rectangle {
            x: root.pending-add-x * 1px;
            y: root.pending-add-y * 1px;
            width: 200px;
            height: picker-layout.preferred-height;
            background: Palette.alternate-background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.foreground.transparentize(75%);
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000030;
            clip: true;

            picker-layout := VerticalLayout {
                padding: 4px;
                spacing: 0px;

                Rectangle {
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 10px;
                        alignment: start;
                        Text {
                            text: "Add component";
                            color: Palette.foreground.transparentize(40%);
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }

                for comp in root.component-palette : Rectangle {
                    height: comp.is-header ? 24px : 30px;
                    if comp.is-header : HorizontalLayout {
                        padding-left: 10px; padding-top: 6px;
                        Text { text: comp.label; color: Palette.foreground.transparentize(40%); font-size: 10px; font-weight: 700; letter-spacing: 0.5px; }
                    }
                    if !comp.is-header : Rectangle {
                        border-radius: 4px;
                        background: picker-item-touch.has-hover ? Palette.control-background : transparent;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;
                            alignment: start;

                            VerticalLayout {
                                alignment: center;
                                if comp.component-type == "text" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "image" : Image { source: @image-url("icons/image.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "container" || comp.component-type == "form" || comp.component-type == "button" || comp.component-type == "card" : Image { source: @image-url("icons/box.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "columns" : Image { source: @image-url("icons/columns.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "list" : Image { source: @image-url("icons/list.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "table" : Image { source: @image-url("icons/table.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "tabs" : Image { source: @image-url("icons/layout.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "accordion" : Image { source: @image-url("icons/chevron-down.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "divider" : Image { source: @image-url("icons/minus.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "spacer" : Image { source: @image-url("icons/grip.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "code" : Image { source: @image-url("icons/code.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                if comp.component-type == "input" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                            }
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: comp.label;
                                    color: Palette.foreground;
                                    font-size: 12px;
                                }
                            }
                        }
                        picker-item-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.grid-cell-add-component(comp.component-type, root.pending-add-path);
                            }
                        }
                    }
                }
            }
        }
    }
}
