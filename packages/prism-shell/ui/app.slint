import { Button, LineEdit, TextEdit, Switch, ComboBox, Slider, ListView, ScrollView,
         VerticalBox, HorizontalBox, GroupBox, Palette, TabWidget } from "std-widgets.slint";

// ── Data structs ───────────────────────────────────────────────────

struct ButtonSpec {
    label: string,
}

struct FieldRow {
    key: string,
    label: string,
    kind: string,
    value: string,
    required: bool,
    min: float,
    max: float,
    has-bounds: bool,
    options: [string],
    swatch: color,
}

struct TabItem {
    id: int,
    title: string,
    active: bool,
}

struct CommandItem {
    label: string,
    shortcut: string,
    category: string,
}

struct ToastItem {
    id: int,
    title: string,
    body: string,
    kind: string,
}

struct InspectorNode {
    id: string,
    component-id: string,
    depth: int,
    selected: bool,
}

struct SearchResultItem {
    node-id: string,
    component-type: string,
    field: string,
    snippet: string,
}

struct ComponentPaletteItem {
    component-type: string,
    label: string,
    description: string,
}

struct BuilderNode {
    id: string,
    component-type: string,
    selected: bool,
    depth: int,
    text: string,
    level: int,
    href: string,
    alt: string,
    placeholder: string,
    label: string,
    disabled: bool,
    display-mode: string,
    has-children: bool,
}

struct HelpTooltipData {
    visible: bool,
    title: string,
    summary: string,
    has-docs: bool,
    tip-x: length,
    tip-y: length,
}

struct BreadcrumbItem {
    id: string,
    label: string,
    has-separator: bool,
}

struct DocsPanelData {
    visible: bool,
    help-id: string,
    title: string,
    summary: string,
    body: string,
}

struct PageLayoutData {
    page-width: float,
    page-height: float,
    margin-top: float,
    margin-right: float,
    margin-bottom: float,
    margin-left: float,
    column-gap: float,
    row-gap: float,
    column-count: int,
    row-count: int,
    show-grid: bool,
    is-responsive: bool,
    page-size-label: string,
}

struct GutterRect {
    offset: float,
    size: float,
}

struct ModifierItem {
    kind: string,
    label: string,
}

struct SignalItem {
    name: string,
    description: string,
}

struct VariantItem {
    key: string,
    label: string,
    selected: string,
    options: [string],
}

struct EditorToken {
    text: string,
    token-color: color,
    col-offset: int,
}

struct EditorLine {
    number: int,
    tokens: [EditorToken],
    is-current: bool,
    sel-from: int,
    sel-to: int,
}

// ── Icon button ───────────────────────────────────────────────────

component IconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    in property <string> tooltip-text: "";
    in property <string> help-id: "";
    callback clicked;
    callback hover-start(string, length, length);
    callback hover-end();

    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: touch.has-hover && root.enabled ? Palette.control-background : transparent;

    Image {
        source: root.icon;
        width: 16px;
        height: 16px;
        colorize: root.enabled
            ? (touch.has-hover ? Palette.foreground : Palette.foreground.transparentize(20%))
            : Palette.foreground.transparentize(70%);
    }

    touch := TouchArea {
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if root.enabled { root.clicked(); }
        }
        changed has-hover => {
            if (self.has-hover && root.help-id != "") {
                root.hover-start(root.help-id,
                    root.absolute-position.x + root.width + 8px,
                    root.absolute-position.y);
            }
            if (!self.has-hover && root.help-id != "") {
                root.hover-end();
            }
        }
    }
}

component ToolbarSeparator inherits Rectangle {
    width: 1px;
    height: 20px;
    background: Palette.foreground.transparentize(80%);
}

component SplitHandle inherits Rectangle {
    width: 6px;
    background: split-touch.has-hover || split-touch.pressed
        ? Palette.accent-background.transparentize(60%)
        : transparent;

    callback dragged(length);

    split-touch := TouchArea {
        mouse-cursor: col-resize;
        moved => {
            if (self.pressed) {
                root.dragged(self.mouse-x - self.pressed-x);
            }
        }
    }

    Rectangle {
        x: 2px;
        width: 2px;
        height: parent.height;
        border-radius: 1px;
        background: split-touch.has-hover || split-touch.pressed
            ? Palette.accent-background.transparentize(30%)
            : transparent;
    }
}

// ── Builder block components ──────────────────────────────────────

component BuilderBlock inherits Rectangle {
    in property <string> node-id;
    in property <string> component-type;
    in property <bool> selected;
    in property <int> depth;
    in property <string> text;
    in property <int> level;
    in property <string> href;
    in property <string> alt;
    in property <string> placeholder;
    in property <string> label;
    in property <bool> disabled;
    in property <string> display-mode: "block";
    in property <bool> has-children: false;
    callback clicked(string);
    callback text-edited(string, string);
    callback delete-clicked(string);

    border-radius: 6px;
    border-width: root.selected ? 2px : 0px;
    border-color: Palette.accent-background;
    background: root.selected ? Palette.accent-background.transparentize(90%) : transparent;

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 1;
            padding-left: root.depth * 16px + 12px;
            padding-right: 8px;
            padding-top: 6px;
            padding-bottom: 6px;

            if root.component-type == "heading" && !root.selected : Text {
                text: root.text;
                color: Palette.foreground;
                font-size: root.level <= 1 ? 32px :
                           root.level == 2 ? 26px :
                           root.level == 3 ? 22px :
                           root.level == 4 ? 18px :
                           root.level == 5 ? 16px : 14px;
                font-weight: 700;
                wrap: word-wrap;
            }
            if root.component-type == "heading" && root.selected : LineEdit {
                height: root.level <= 1 ? 40px :
                        root.level == 2 ? 34px :
                        root.level == 3 ? 30px : 28px;
                text: root.text;
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            if root.component-type == "text" && !root.selected : Text {
                text: root.text;
                color: Palette.foreground;
                font-size: 14px;
                wrap: word-wrap;
            }
            if root.component-type == "text" && root.selected : LineEdit {
                height: 28px;
                text: root.text;
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            if root.component-type == "link" && !root.selected : HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Image {
                    source: @image-url("icons/link.svg");
                    width: 14px; height: 14px;
                    colorize: Palette.accent-background;
                    y: 2px;
                }
                Text {
                    text: root.text != "" ? root.text : root.href;
                    color: Palette.accent-foreground;
                    font-size: 14px;
                }
            }
            if root.component-type == "link" && root.selected : VerticalLayout {
                spacing: 4px;
                LineEdit {
                    height: 28px;
                    text: root.text;
                    placeholder-text: "Link text";
                    accepted(val) => { root.text-edited(root.node-id, val); }
                }
            }

            if root.component-type == "image" : Rectangle {
                min-height: 80px;
                background: Palette.control-background;
                border-radius: 6px;
                HorizontalLayout {
                    alignment: center;
                    spacing: 6px;
                    Image {
                        source: @image-url("icons/image.svg");
                        width: 16px; height: 16px;
                        colorize: Palette.foreground.transparentize(40%);
                    }
                    Text {
                        text: root.alt != "" ? root.alt : "Image";
                        color: Palette.foreground.transparentize(40%);
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }

            if root.component-type == "container" : HorizontalLayout {
                spacing: 6px; alignment: start; height: 24px;
                Image { source: @image-url("icons/box.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); }
                Text { text: "Container"; color: Palette.foreground.transparentize(40%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                if root.display-mode == "flex" : Rectangle {
                    width: 42px; height: 16px; border-radius: 3px; background: Palette.accent-background.transparentize(85%);
                    Text { text: "Flex"; color: Palette.accent-background; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }
                if root.display-mode == "grid" : Rectangle {
                    width: 42px; height: 16px; border-radius: 3px; background: Palette.accent-background.transparentize(85%);
                    Text { text: "Grid"; color: Palette.accent-background; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }
                if root.display-mode == "block" : Rectangle {
                    width: 42px; height: 16px; border-radius: 3px; background: Palette.foreground.transparentize(90%);
                    Text { text: "Block"; color: Palette.foreground.transparentize(40%); font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }
                if root.has-children : Text { text: "▸ nested"; color: Palette.foreground.transparentize(60%); font-size: 10px; vertical-alignment: center; }
            }

            if root.component-type == "form" : HorizontalLayout {
                spacing: 4px; alignment: start;
                Image { source: @image-url("icons/box.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); }
                Text { text: "Form"; color: Palette.foreground.transparentize(40%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
            }

            if root.component-type == "input" : VerticalLayout {
                spacing: 4px;
                if root.label != "" : Text { text: root.label; color: Palette.foreground; font-size: 12px; }
                LineEdit { height: 28px; placeholder-text: root.placeholder != "" ? root.placeholder : root.text; enabled: false; }
            }

            if root.component-type == "button" && !root.selected : HorizontalLayout {
                alignment: start;
                Button { text: root.text != "" ? root.text : "Button"; enabled: !root.disabled; }
            }
            if root.component-type == "button" && root.selected : LineEdit {
                height: 28px;
                text: root.text != "" ? root.text : "Button";
                placeholder-text: "Button text";
                accepted(val) => { root.text-edited(root.node-id, val); }
            }

            if root.component-type == "card" : Rectangle {
                border-width: 1px; border-color: Palette.control-background; border-radius: 8px;
                background: Palette.alternate-background; min-height: 48px;
                VerticalLayout {
                    padding: 12px; spacing: 4px;
                    if !root.selected : Text { text: root.text != "" ? root.text : "Card"; color: Palette.foreground; font-size: 16px; font-weight: 600; }
                    if root.selected : LineEdit { height: 28px; text: root.text != "" ? root.text : "Card"; placeholder-text: "Card title"; accepted(val) => { root.text-edited(root.node-id, val); } }
                    if root.label != "" : Text { text: root.label; color: Palette.foreground.transparentize(30%); font-size: 13px; wrap: word-wrap; }
                }
            }

            if root.component-type == "code" : Rectangle {
                background: Palette.control-background; border-radius: 6px; min-height: 36px;
                VerticalLayout {
                    padding: 10px;
                    if !root.selected : Text { text: root.text != "" ? root.text : "// code"; color: Palette.foreground.transparentize(20%); font-size: 13px; font-family: "monospace"; wrap: word-wrap; }
                    if root.selected : LineEdit { height: 28px; text: root.text != "" ? root.text : "// code"; accepted(val) => { root.text-edited(root.node-id, val); } }
                }
            }

            if root.component-type == "divider" : Rectangle { height: 1px; background: Palette.foreground.transparentize(70%); }

            if root.component-type == "spacer" : Rectangle {
                height: root.level > 0 ? root.level * 1px : 24px;
                border-width: 1px; border-color: Palette.foreground.transparentize(85%); border-radius: 2px;
            }

            if root.component-type == "columns" : HorizontalLayout {
                spacing: 6px; alignment: start;
                Image { source: @image-url("icons/columns.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); }
                Text { text: "Columns"; color: Palette.foreground.transparentize(40%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                Rectangle {
                    width: 42px; height: 16px; border-radius: 3px; background: Palette.accent-background.transparentize(85%);
                    Text { text: "Flex →"; color: Palette.accent-background; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }
                Text { text: "gap: " + (root.level > 0 ? root.level : 16) + "px"; color: Palette.foreground.transparentize(60%); font-size: 10px; vertical-alignment: center; }
            }

            if root.component-type == "list" : HorizontalLayout {
                spacing: 6px; alignment: start;
                Image { source: @image-url("icons/list.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); }
                Text { text: root.disabled ? "Ordered List (ol)" : "Unordered List (ul)"; color: Palette.foreground.transparentize(40%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
            }

            if root.component-type == "table" : Rectangle {
                border-width: 1px; border-color: Palette.control-background; border-radius: 4px; min-height: 32px;
                VerticalLayout {
                    padding: 8px; spacing: 4px;
                    if root.label != "" : Text { text: root.label; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                    HorizontalLayout {
                        spacing: 6px; alignment: start;
                        Image { source: @image-url("icons/table.svg"); width: 14px; height: 14px; colorize: Palette.foreground; }
                        Text { text: root.text != "" ? root.text : "Table"; color: Palette.foreground; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                    }
                }
            }

            if root.component-type == "tabs" : HorizontalLayout {
                spacing: 6px; alignment: start;
                Image { source: @image-url("icons/layout.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                Text { text: root.text != "" ? root.text : "Tabs"; color: Palette.foreground.transparentize(30%); font-size: 12px; font-weight: 500; vertical-alignment: center; }
            }

            if root.component-type == "accordion" : Rectangle {
                background: Palette.alternate-background; border-radius: 4px; min-height: 32px;
                HorizontalLayout {
                    padding-left: 8px; padding-right: 8px; spacing: 6px; alignment: start;
                    Image { source: @image-url("icons/chevron-down.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); vertical-alignment: center; }
                    if !root.selected : Text { text: root.text != "" ? root.text : "Accordion"; color: Palette.foreground; font-size: 13px; font-weight: 600; vertical-alignment: center; }
                    if root.selected : LineEdit { height: 28px; text: root.text != "" ? root.text : "Accordion"; placeholder-text: "Section title"; horizontal-stretch: 1; accepted(val) => { root.text-edited(root.node-id, val); } }
                }
            }
        }

        if root.selected : VerticalLayout {
            alignment: start;
            padding-top: 6px;
            padding-right: 4px;
            IconButton {
                icon: @image-url("icons/x.svg");
                clicked => { root.delete-clicked(root.node-id); }
            }
        }
    }

    TouchArea {
        clicked => { root.clicked(root.node-id); }
    }
}

// ── Reusable components ────────────────────────────────────────────

component NavButton inherits Rectangle {
    in property <image> icon;
    in property <bool> selected;
    in property <string> help-id: "";
    callback clicked;
    callback hover-start(string, length, length);
    callback hover-end();

    width: 48px;
    height: 48px;
    background: selected ? Palette.accent-background.transparentize(85%) : transparent;

    Rectangle {
        x: 0px; y: 0px; width: 3px; height: parent.height;
        background: root.selected ? Palette.accent-background : transparent;
        border-radius: 1px;
    }

    Image {
        source: root.icon; width: 20px; height: 20px;
        colorize: root.selected ? Palette.accent-foreground : Palette.foreground.transparentize(30%);
    }

    nav-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
        changed has-hover => {
            if (self.has-hover && root.help-id != "") {
                root.hover-start(root.help-id,
                    root.absolute-position.x + root.width + 8px,
                    root.absolute-position.y);
            }
            if (!self.has-hover && root.help-id != "") {
                root.hover-end();
            }
        }
    }
}

component FieldEditor inherits Rectangle {
    in property <string> key;
    in property <string> label;
    in property <string> kind;
    in property <string> value;
    in property <bool> required;
    in property <float> min;
    in property <float> max;
    in property <bool> has-bounds;
    in property <[string]> options;
    in property <color> swatch;
    callback field-edited(string, string);
    callback field-edited-number(string, float);

    property <bool> is-numeric: root.kind == "number" || root.kind == "integer";

    background: transparent;

    VerticalLayout {
        spacing: 2px;
        padding-top: 4px;
        padding-bottom: 4px;

        Text {
            text: root.required ? root.label + " *" : root.label;
            color: Palette.foreground;
            font-size: 12px;
        }

        // Boolean → Switch
        if root.kind == "boolean" : HorizontalLayout {
            alignment: start; height: 24px;
            Switch {
                checked: root.value == "true";
                toggled => { root.field-edited(root.key, self.checked ? "true" : "false"); }
            }
        }

        // Select → ComboBox
        if root.kind == "select" : ComboBox {
            height: 28px;
            model: root.options;
            current-value: root.value;
            selected(val) => { root.field-edited(root.key, val); }
        }

        // Color → swatch + hex input
        if root.kind == "color" : HorizontalLayout {
            spacing: 6px; height: 28px;
            Rectangle {
                width: 28px; height: 28px;
                border-radius: 4px;
                border-width: 1px;
                border-color: Palette.foreground.transparentize(80%);
                background: root.swatch;
            }
            LineEdit {
                horizontal-stretch: 1;
                text: root.value;
                placeholder-text: "#000000";
                accepted(text) => { root.field-edited(root.key, text); }
            }
        }

        // Number/Integer with bounds → LineEdit + Slider (inline)
        if root.is-numeric && root.has-bounds : HorizontalLayout {
            spacing: 4px;
            height: 28px;
            LineEdit {
                width: 56px;
                height: 28px;
                text: root.value;
                placeholder-text: root.label;
                accepted(text) => { root.field-edited(root.key, text); }
            }
            Slider {
                horizontal-stretch: 1;
                height: 20px;
                minimum: root.min;
                maximum: root.max;
                value: root.value.to-float();
                changed(val) => { root.field-edited-number(root.key, val); }
            }
        }

        // Number/Integer without bounds → plain LineEdit
        if root.is-numeric && !root.has-bounds : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => { root.field-edited(root.key, text); }
        }

        // Textarea → LineEdit (multi-line editing happens inline on canvas)
        if root.kind == "textarea" : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => { root.field-edited(root.key, text); }
        }

        // Text → standard LineEdit
        if root.kind == "text" : LineEdit {
            height: 28px;
            text: root.value;
            placeholder-text: root.label;
            accepted(text) => { root.field-edited(root.key, text); }
        }

        // Kind hint
        Text {
            text: root.kind + " · " + root.key;
            color: Palette.foreground.transparentize(50%);
            font-size: 10px;
        }
    }
}

component InspectorRow inherits Rectangle {
    in property <string> node-id;
    in property <string> component-id;
    in property <int> depth;
    in property <bool> selected;
    callback clicked;
    callback move-up;
    callback move-down;

    height: 30px;
    background: selected ? Palette.accent-background.transparentize(85%) : transparent;
    border-radius: 4px;

    HorizontalLayout {
        padding-left: root.depth * 16px + 12px;
        padding-right: 8px;
        alignment: space-between;

        HorizontalLayout {
            spacing: 6px; alignment: start;
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: root.selected ? Palette.accent-background : Palette.foreground.transparentize(60%); y: 12px; }
            Text { text: root.component-id; color: root.selected ? Palette.accent-foreground : Palette.foreground; font-size: 12px; font-weight: root.selected ? 600 : 400; vertical-alignment: center; }
            Text { text: root.node-id; color: Palette.foreground.transparentize(50%); font-size: 10px; font-family: "monospace"; vertical-alignment: center; }
        }

        if root.selected : HorizontalLayout {
            spacing: 2px; width: 60px; alignment: end;
            IconButton { icon: @image-url("icons/chevron-up.svg"); clicked => { root.move-up(); } }
            IconButton { icon: @image-url("icons/chevron-down.svg"); clicked => { root.move-down(); } }
        }
    }

    TouchArea { clicked => { root.clicked(); } }
}

component Toast inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> kind;
    callback dismissed;

    property <color> kind-color: root.kind == "error" ? #dc3c3c :
                                  root.kind == "warning" ? #dcaa3c :
                                  root.kind == "success" ? #3cdc6e :
                                  Palette.accent-background;

    width: 320px;
    background: Palette.alternate-background;
    border-radius: 8px;
    border-width: 1px;
    border-color: kind-color;
    clip: true;

    VerticalLayout {
        padding: 12px; spacing: 4px;
        HorizontalLayout {
            spacing: 8px;
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: root.kind-color; y: 6px; }
            Text { text: root.title; color: Palette.foreground; font-size: 13px; font-weight: 600; overflow: elide; }
            Rectangle { horizontal-stretch: 1; }
            IconButton { icon: @image-url("icons/x.svg"); clicked => { root.dismissed(); } }
        }
        if root.body != "" : Text { text: root.body; color: Palette.foreground.transparentize(30%); font-size: 12px; wrap: word-wrap; }
    }
}

// ── Docs content (shared between sidebar and full view) ───────────

component DocsContent inherits Rectangle {
    in property <string> doc-title;
    in property <string> doc-summary;
    in property <string> doc-body;
    in property <bool> compact: false;

    VerticalLayout {
        spacing: 0px;

        Text {
            text: root.doc-title;
            color: Palette.foreground;
            font-size: root.compact ? 14px : 22px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Rectangle { height: root.compact ? 8px : 12px; }

        Text {
            text: root.doc-summary;
            color: Palette.foreground.transparentize(20%);
            font-size: root.compact ? 12px : 14px;
            font-weight: 500;
            wrap: word-wrap;
        }

        if root.doc-body != "" : Rectangle { height: root.compact ? 10px : 16px; }

        if root.doc-body != "" : Rectangle {
            height: 1px;
            background: Palette.foreground.transparentize(85%);
        }

        if root.doc-body != "" : Rectangle { height: root.compact ? 10px : 16px; }

        if root.doc-body != "" : Text {
            text: root.doc-body;
            color: Palette.foreground.transparentize(30%);
            font-size: root.compact ? 12px : 13px;
            wrap: word-wrap;
        }
    }
}

// ── Root component ─────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Prism Studio";
    preferred-width: 1280px;
    preferred-height: 800px;

    // Panel navigation (0 = Identity, 1 = Edit, 2 = Code Editor)
    in property <int> active-panel-id: 1;
    callback select-panel(int);

    // Identity panel
    in property <[ButtonSpec]> actions: [];
    callback clicked(int);

    // Builder canvas
    in property <[BuilderNode]> builder-nodes: [];
    in property <int> builder-node-count: 0;
    callback builder-node-clicked(string);
    callback builder-text-edited(string, string);
    callback builder-delete-node(string);
    in property <string> builder-source: "";

    // Component palette
    in property <[ComponentPaletteItem]> component-palette: [];
    callback add-component(string);

    // Layer tree
    in property <string> inspector-tree: "";
    in property <[InspectorNode]> inspector-nodes: [];
    callback node-clicked(string);
    callback node-move-up(string);
    callback node-move-down(string);

    // Properties
    in property <string> selected-component: "";
    in property <[FieldRow]> field-rows: [];
    callback field-edited(string, string);
    callback field-edited-number(string, float);

    // Tabbed MDI
    in property <[TabItem]> tabs: [];
    callback tab-activated(int);
    callback tab-closed(int);

    // Command palette
    in property <bool> command-palette-visible: false;
    in property <[CommandItem]> command-results: [];
    callback toggle-command-palette();
    callback command-palette-input(string);
    callback command-selected(int);

    // Notifications
    in property <[ToastItem]> notifications: [];
    callback dismiss-notification(int);

    // Undo/redo
    in property <bool> can-undo: false;
    in property <bool> can-redo: false;
    in property <string> undo-label: "";
    in property <string> redo-label: "";
    callback undo-clicked;
    callback redo-clicked;

    // Search
    in property <string> search-query: "";
    in property <[SearchResultItem]> search-results: [];
    callback search-input(string);
    callback search-result-clicked(string);

    // Clipboard
    in property <bool> has-selection: false;
    in property <bool> has-clipboard: false;
    callback copy-clicked;
    callback paste-clicked;
    callback cut-clicked;
    callback duplicate-clicked;

    // Keyboard
    callback escape-pressed;
    callback search-focus;
    in property <string> panel-title: "Editor";
    in property <string> panel-hint: "Build your page visually.";

    // Breadcrumbs
    in property <[BreadcrumbItem]> breadcrumbs: [];
    callback breadcrumb-clicked(string);

    // Help tooltip
    in property <HelpTooltipData> help-tooltip: {
        visible: false, title: "", summary: "", has-docs: false,
        tip-x: 0px, tip-y: 0px
    };
    callback help-hover(string, length, length);
    callback help-leave();
    callback help-docs-clicked;
    callback help-entry-clicked;

    // Sidebar section collapse state
    in-out property <bool> components-expanded: true;
    in-out property <bool> layers-expanded: true;
    in-out property <bool> page-layout-expanded: true;

    // Code editor
    in property <[EditorLine]> editor-lines: [];
    in property <int> editor-cursor-line: 0;
    in property <int> editor-cursor-col: 0;
    in property <bool> editor-cursor-visible: true;
    in property <string> editor-cursor-prefix: "";
    in property <string> editor-language: "rust";
    in property <int> editor-line-count: 0;
    in property <int> editor-char-count: 0;
    callback editor-action(string);
    callback editor-char-typed(string);
    callback editor-click(int, int);
    callback editor-drag(int, int);

    // Page layout
    in property <PageLayoutData> page-layout: {
        page-width: 1280.0, page-height: 800.0,
        margin-top: 0.0, margin-right: 0.0, margin-bottom: 0.0, margin-left: 0.0,
        column-gap: 0.0, row-gap: 0.0,
        column-count: 1, row-count: 0,
        show-grid: false, is-responsive: true,
        page-size-label: "Responsive",
    };
    in property <[GutterRect]> column-gutters: [];
    in property <[GutterRect]> row-gutters: [];
    callback toggle-grid-overlay;
    callback page-layout-edited(string, string);

    // Layout properties for selected node
    in property <[FieldRow]> layout-rows: [];
    callback layout-field-edited(string, string);
    callback layout-field-edited-number(string, float);

    // Game engine systems
    in property <[ModifierItem]> modifier-items: [];
    in property <[SignalItem]> signal-items: [];
    in property <[VariantItem]> variant-items: [];
    in property <int> connection-count: 0;
    in property <int> resource-count: 0;
    in property <int> prefab-count: 0;

    // Docs panel (sidebar) and docs view (full)
    in property <DocsPanelData> docs-panel: {
        visible: false, help-id: "", title: "", summary: "", body: ""
    };
    in property <DocsPanelData> docs-view: {
        visible: false, help-id: "", title: "", summary: "", body: ""
    };
    callback docs-open-full;
    callback docs-panel-close;
    callback docs-view-close;

    // Panel resize
    property <length> identity-sidebar-width: 220px;
    property <length> left-sidebar-width: 240px;
    property <length> right-sidebar-width: 280px;

    background: Palette.background;

    fs := FocusScope {
        width: 100%;
        height: 100%;

        key-pressed(event) => {
            if (event.modifiers.control && event.modifiers.shift && event.text == "P") { root.toggle-command-palette(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{001a}") { root.undo-clicked(); return accept; }
            if (event.modifiers.control && event.modifiers.shift && event.text == "\u{001a}") { root.redo-clicked(); return accept; }
            if (event.modifiers.control && event.text == "\u{0006}") { root.search-focus(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{0003}") { root.copy-clicked(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{0016}") { root.paste-clicked(); return accept; }
            if (event.modifiers.control && !event.modifiers.shift && event.text == "\u{0018}") { root.cut-clicked(); return accept; }
            if (event.modifiers.control && event.text == "\u{0004}") { root.duplicate-clicked(); return accept; }
            if (event.text == Key.Escape) { root.escape-pressed(); return accept; }
            if (event.text == Key.Delete) { root.builder-delete-node(""); return accept; }
            return reject;
        }

        VerticalLayout {
            HorizontalLayout {
                spacing: 0px;
                vertical-stretch: 1;

                // ── Activity bar ──────────────────────────────────
                Rectangle {
                    width: 48px;
                    background: Palette.alternate-background;
                    VerticalLayout {
                        padding-top: 8px;
                        spacing: 0px;
                        alignment: start;
                        NavButton {
                            icon: @image-url("icons/user.svg");
                            selected: root.active-panel-id == 0;
                            help-id: "shell.panels.identity";
                            clicked => { root.select-panel(0); }
                            hover-start(id, x, y) => { root.help-hover(id, x, y); }
                            hover-end => { root.help-leave(); }
                        }
                        NavButton {
                            icon: @image-url("icons/layout.svg");
                            selected: root.active-panel-id == 1;
                            help-id: "shell.panels.editor";
                            clicked => { root.select-panel(1); }
                            hover-start(id, x, y) => { root.help-hover(id, x, y); }
                            hover-end => { root.help-leave(); }
                        }
                        NavButton {
                            icon: @image-url("icons/code.svg");
                            selected: root.active-panel-id == 2;
                            help-id: "shell.panels.code-editor";
                            clicked => { root.select-panel(2); }
                            hover-start(id, x, y) => { root.help-hover(id, x, y); }
                            hover-end => { root.help-leave(); }
                        }
                    }
                }

                // ── Identity sidebar ─────────────────────────────
                if root.active-panel-id == 0 : Rectangle {
                    width: root.identity-sidebar-width;
                    background: Palette.alternate-background;
                    clip: true;
                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }
                    ScrollView {
                        VerticalLayout {
                            min-width: 180px;
                            padding: 16px; spacing: 8px; alignment: start;
                            Text { text: root.panel-title; color: Palette.foreground; font-size: 14px; font-weight: 700; letter-spacing: 0.3px; }
                            Text { text: root.panel-hint; color: Palette.foreground.transparentize(40%); font-size: 11px; wrap: word-wrap; }
                            if root.actions.length > 0 : VerticalLayout {
                                spacing: 4px; padding-top: 8px;
                                for action[i] in root.actions : Button { text: action.label; clicked => { root.clicked(i); } }
                            }
                        }
                    }
                }
                if root.active-panel-id == 0 : SplitHandle {
                    dragged(delta) => { root.identity-sidebar-width = clamp(root.identity-sidebar-width + delta, 120px, 500px); }
                }

                // ── Edit mode: left sidebar ──────────────────────
                if root.active-panel-id == 1 : Rectangle {
                    width: root.left-sidebar-width;
                    background: Palette.alternate-background;
                    clip: true;
                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;

                            // Components (collapsible)
                            Rectangle {
                                height: 20px;
                                HorizontalLayout {
                                    spacing: 6px; alignment: start;
                                    Image {
                                        source: root.components-expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-left.svg");
                                        width: 10px; height: 10px;
                                        colorize: Palette.foreground.transparentize(30%);
                                        y: 1px;
                                    }
                                    Image { source: @image-url("icons/plus.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                                    Text { text: "Components"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                }
                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.components-expanded = !root.components-expanded; }
                                }
                            }

                            if root.components-expanded : VerticalLayout {
                                min-width: 200px;
                                spacing: 1px;
                                for comp[i] in root.component-palette : Rectangle {
                                    height: 36px;
                                    background: palette-touch.has-hover ? Palette.control-background : transparent;
                                    border-radius: 4px;
                                    HorizontalLayout {
                                        padding-left: 10px; padding-right: 10px; spacing: 8px; alignment: start;
                                        VerticalLayout {
                                            alignment: center;
                                            if comp.component-type == "heading" || comp.component-type == "text" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "link" : Image { source: @image-url("icons/link.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "image" : Image { source: @image-url("icons/image.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "container" || comp.component-type == "form" || comp.component-type == "button" : Image { source: @image-url("icons/box.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "card" : Image { source: @image-url("icons/box.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "columns" : Image { source: @image-url("icons/columns.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "list" : Image { source: @image-url("icons/list.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "table" : Image { source: @image-url("icons/table.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "tabs" : Image { source: @image-url("icons/layout.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "accordion" : Image { source: @image-url("icons/chevron-down.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "divider" : Image { source: @image-url("icons/minus.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "spacer" : Image { source: @image-url("icons/grip.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "code" : Image { source: @image-url("icons/code.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                            if comp.component-type == "input" : Image { source: @image-url("icons/type.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(40%); }
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Text { text: comp.label; color: Palette.foreground; font-size: 12px; font-weight: 500; }
                                        }
                                    }
                                    palette-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.add-component(comp.component-type); }
                                        changed has-hover => {
                                            if (self.has-hover) {
                                                root.help-hover("builder.components." + comp.component-type, parent.absolute-position.x + parent.width + 8px, parent.absolute-position.y);
                                            }
                                            if (!self.has-hover) { root.help-leave(); }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }

                            // Layers (collapsible)
                            Rectangle {
                                height: 20px;
                                HorizontalLayout {
                                    spacing: 6px; alignment: start;
                                    Image {
                                        source: root.layers-expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-left.svg");
                                        width: 10px; height: 10px;
                                        colorize: Palette.foreground.transparentize(30%);
                                        y: 1px;
                                    }
                                    Image { source: @image-url("icons/tree.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                                    Text { text: "Layers"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                }
                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.layers-expanded = !root.layers-expanded; }
                                }
                            }

                            if root.layers-expanded : VerticalLayout {
                                min-width: 200px;
                                spacing: 1px;
                                for node[i] in root.inspector-nodes : InspectorRow {
                                    node-id: node.id;
                                    component-id: node.component-id;
                                    depth: node.depth;
                                    selected: node.selected;
                                    clicked => { root.node-clicked(node.id); }
                                    move-up => { root.node-move-up(node.id); }
                                    move-down => { root.node-move-down(node.id); }
                                }
                            }

                            Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }

                            // Page Layout (collapsible)
                            Rectangle {
                                height: 20px;
                                HorizontalLayout {
                                    spacing: 6px; alignment: start;
                                    Image {
                                        source: root.page-layout-expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-left.svg");
                                        width: 10px; height: 10px;
                                        colorize: Palette.foreground.transparentize(30%);
                                        y: 1px;
                                    }
                                    Image { source: @image-url("icons/layout.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(30%); }
                                    Text { text: "Page Layout"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                }
                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.page-layout-expanded = !root.page-layout-expanded; }
                                }
                            }

                            // Grid overlay toggle
                            if root.page-layout-expanded : HorizontalLayout {
                                spacing: 8px; alignment: start; height: 28px;
                                Switch { checked: root.page-layout.show-grid; toggled => { root.toggle-grid-overlay(); } }
                                Text { text: "Show grid"; color: Palette.foreground; font-size: 12px; vertical-alignment: center; }
                            }

                            // Page size — ComboBox
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Size"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                ComboBox {
                                    height: 28px;
                                    model: ["Responsive", "A4", "A3", "A5", "Letter", "Legal", "Tabloid", "Custom"];
                                    current-value: root.page-layout.page-size-label;
                                    selected(val) => { root.page-layout-edited("page_size", val); }
                                }
                            }

                            // Columns — inline slider + text
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Columns"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.column-count;
                                        placeholder-text: "1";
                                        accepted(val) => { root.page-layout-edited("columns", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 1; maximum: 24;
                                        value: root.page-layout.column-count;
                                        changed(val) => { root.page-layout-edited("columns", round(val)); }
                                    }
                                }
                            }

                            // Column gap — inline slider + text
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Column Gap"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.column-gap;
                                        placeholder-text: "0";
                                        accepted(val) => { root.page-layout-edited("column_gap", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 0; maximum: 128;
                                        value: root.page-layout.column-gap;
                                        changed(val) => { root.page-layout-edited("column_gap", round(val)); }
                                    }
                                }
                            }

                            // Rows — inline slider + text
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Rows"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.row-count;
                                        placeholder-text: "0";
                                        accepted(val) => { root.page-layout-edited("rows", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 0; maximum: 24;
                                        value: root.page-layout.row-count;
                                        changed(val) => { root.page-layout-edited("rows", round(val)); }
                                    }
                                }
                            }

                            // Row gap — inline slider + text
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Row Gap"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.row-gap;
                                        placeholder-text: "0";
                                        accepted(val) => { root.page-layout-edited("row_gap", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 0; maximum: 128;
                                        value: root.page-layout.row-gap;
                                        changed(val) => { root.page-layout-edited("row_gap", round(val)); }
                                    }
                                }
                            }

                            // Margins — inline sliders
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Margin Top"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.margin-top;
                                        placeholder-text: "0";
                                        accepted(val) => { root.page-layout-edited("margin_top", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 0; maximum: 256;
                                        value: root.page-layout.margin-top;
                                        changed(val) => { root.page-layout-edited("margin_top", round(val)); }
                                    }
                                }
                            }
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Margin Right"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.margin-right;
                                        placeholder-text: "0";
                                        accepted(val) => { root.page-layout-edited("margin_right", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 0; maximum: 256;
                                        value: root.page-layout.margin-right;
                                        changed(val) => { root.page-layout-edited("margin_right", round(val)); }
                                    }
                                }
                            }
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Margin Bottom"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.margin-bottom;
                                        placeholder-text: "0";
                                        accepted(val) => { root.page-layout-edited("margin_bottom", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 0; maximum: 256;
                                        value: root.page-layout.margin-bottom;
                                        changed(val) => { root.page-layout-edited("margin_bottom", round(val)); }
                                    }
                                }
                            }
                            if root.page-layout-expanded : VerticalLayout {
                                spacing: 2px;
                                Text { text: "Margin Left"; color: Palette.foreground.transparentize(40%); font-size: 11px; }
                                HorizontalLayout {
                                    spacing: 4px; height: 24px;
                                    LineEdit {
                                        width: 48px; height: 24px;
                                        text: root.page-layout.margin-left;
                                        placeholder-text: "0";
                                        accepted(val) => { root.page-layout-edited("margin_left", val); }
                                    }
                                    Slider {
                                        horizontal-stretch: 1; height: 20px;
                                        minimum: 0; maximum: 256;
                                        value: root.page-layout.margin-left;
                                        changed(val) => { root.page-layout-edited("margin_left", round(val)); }
                                    }
                                }
                            }

                            Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }

                            // Search
                            HorizontalLayout {
                                spacing: 6px;
                                Image { source: @image-url("icons/search.svg"); width: 14px; height: 14px; colorize: Palette.foreground.transparentize(50%); y: 7px; }
                                LineEdit { height: 28px; horizontal-stretch: 1; text: root.search-query; placeholder-text: "Search nodes..."; edited(text) => { root.search-input(text); } }
                            }

                            if root.search-results.length > 0 : VerticalLayout {
                                spacing: 2px;
                                for result[i] in root.search-results : Rectangle {
                                    height: 44px; background: Palette.control-background; border-radius: 4px;
                                    VerticalLayout {
                                        padding: 6px; spacing: 2px;
                                        Text { text: result.node-id + " · " + result.field; color: Palette.foreground; font-size: 11px; overflow: elide; }
                                        Text { text: result.snippet; color: Palette.foreground.transparentize(30%); font-size: 10px; overflow: elide; }
                                    }
                                    TouchArea { mouse-cursor: pointer; clicked => { root.search-result-clicked(result.node-id); } }
                                }
                            }
                        }
                    }
                }
                if root.active-panel-id == 1 : SplitHandle {
                    dragged(delta) => { root.left-sidebar-width = clamp(root.left-sidebar-width + delta, 160px, 500px); }
                }

                // ── Docs sidebar (overlays panel sidebar) ──────
                if root.docs-panel.visible : Rectangle {
                    width: 280px;
                    background: Palette.alternate-background;
                    Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }

                    VerticalLayout {
                        padding: 16px;
                        spacing: 0px;

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;

                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                background: docs-back-touch.has-hover ? Palette.control-background : transparent;
                                Image {
                                    source: @image-url("icons/chevron-left.svg");
                                    width: 16px;
                                    height: 16px;
                                    colorize: docs-back-touch.has-hover ? Palette.foreground : Palette.foreground.transparentize(30%);
                                }
                                docs-back-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.docs-panel-close(); }
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "Documentation";
                                    color: Palette.foreground;
                                    font-size: 14px;
                                    font-weight: 700;
                                }
                            }
                        }

                        Rectangle { height: 12px; }
                        Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                        Rectangle { height: 12px; }

                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 0px;
                                alignment: start;

                                DocsContent {
                                    doc-title: root.docs-panel.title;
                                    doc-summary: root.docs-panel.summary;
                                    doc-body: root.docs-panel.body;
                                    compact: true;
                                }

                                Rectangle { height: 16px; }

                                Rectangle {
                                    height: 36px;
                                    border-radius: 6px;
                                    background: docs-open-touch.has-hover ? Palette.accent-background.transparentize(85%) : transparent;
                                    border-width: 1px;
                                    border-color: Palette.accent-background.transparentize(50%);

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        spacing: 6px;
                                        alignment: start;

                                        Image {
                                            source: @image-url("icons/book.svg");
                                            width: 14px;
                                            height: 14px;
                                            colorize: Palette.accent-background;
                                        }

                                        Text {
                                            text: "Open in Docs";
                                            color: Palette.accent-background;
                                            font-size: 12px;
                                            font-weight: 500;
                                            vertical-alignment: center;
                                        }
                                    }

                                    docs-open-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.docs-open-full(); }
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Main content area ────────────────────────────
                VerticalLayout {
                    horizontal-stretch: 1;

                    // Tab bar
                    if root.tabs.length > 0 : Rectangle {
                        height: 36px;
                        background: Palette.alternate-background;
                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            spacing: 0px; padding-left: 0px; alignment: start;
                            for tab[i] in root.tabs : Rectangle {
                                height: 35px; min-width: 120px; max-width: 200px;
                                background: tab.active ? Palette.background : Palette.alternate-background;
                                Rectangle { x: 0px; y: parent.height - 2px; width: parent.width; height: 2px; background: tab.active ? Palette.accent-background : transparent; }
                                HorizontalLayout {
                                    padding-left: 14px; padding-right: 8px; spacing: 8px; alignment: start;
                                    Text { text: tab.title; color: tab.active ? Palette.foreground : Palette.foreground.transparentize(40%); font-size: 12px; vertical-alignment: center; overflow: elide; }
                                    IconButton { icon: @image-url("icons/x.svg"); clicked => { root.tab-closed(tab.id); } }
                                }
                                tab-touch := TouchArea {
                                    clicked => { root.tab-activated(tab.id); }
                                    changed has-hover => {
                                        if (self.has-hover) {
                                            root.help-hover("shell.tabs", parent.absolute-position.x + parent.width / 2, parent.absolute-position.y + parent.height + 4px);
                                        }
                                        if (!self.has-hover) { root.help-leave(); }
                                    }
                                }
                            }
                        }
                    }

                    // Toolbar (Edit mode)
                    if root.active-panel-id == 1 : Rectangle {
                        height: 40px;
                        background: Palette.background;
                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; spacing: 4px; alignment: start;
                            IconButton { icon: @image-url("icons/undo.svg"); enabled: root.can-undo; help-id: "shell.toolbar.undo"; clicked => { root.undo-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/redo.svg"); enabled: root.can-redo; help-id: "shell.toolbar.redo"; clicked => { root.redo-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            ToolbarSeparator { }
                            IconButton { icon: @image-url("icons/copy.svg"); enabled: root.has-selection; help-id: "shell.toolbar.copy"; clicked => { root.copy-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/scissors.svg"); enabled: root.has-selection; help-id: "shell.toolbar.cut"; clicked => { root.cut-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/paste.svg"); enabled: root.has-clipboard; help-id: "shell.toolbar.paste"; clicked => { root.paste-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/duplicate.svg"); enabled: root.has-selection; help-id: "shell.toolbar.duplicate"; clicked => { root.duplicate-clicked(); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            ToolbarSeparator { }
                            IconButton { icon: @image-url("icons/chevron-up.svg"); enabled: root.has-selection; help-id: "shell.toolbar.move-up"; clicked => { root.node-move-up(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            IconButton { icon: @image-url("icons/chevron-down.svg"); enabled: root.has-selection; help-id: "shell.toolbar.move-down"; clicked => { root.node-move-down(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            ToolbarSeparator { }
                            IconButton { icon: @image-url("icons/trash.svg"); enabled: root.has-selection; help-id: "shell.toolbar.delete"; clicked => { root.builder-delete-node(""); } hover-start(id, x, y) => { root.help-hover(id, x, y); } hover-end => { root.help-leave(); } }
                            ToolbarSeparator { }
                            Rectangle {
                                width: 28px; height: 28px; border-radius: 6px;
                                background: root.page-layout.show-grid ? Palette.accent-background.transparentize(85%) : (grid-toggle-touch.has-hover ? Palette.control-background : transparent);
                                Image { source: @image-url("icons/columns.svg"); width: 16px; height: 16px; colorize: root.page-layout.show-grid ? Palette.accent-foreground : Palette.foreground.transparentize(20%); }
                                grid-toggle-touch := TouchArea { mouse-cursor: pointer; clicked => { root.toggle-grid-overlay(); } }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            if root.page-layout.column-count > 1 : Text { text: root.page-layout.column-count + " cols"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                            if root.page-layout.column-count > 1 : Text { text: "·"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            Text { text: root.builder-node-count + " nodes"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                        }
                    }

                    // Breadcrumbs (Edit mode + selection)
                    if root.active-panel-id == 1 && root.breadcrumbs.length > 0 : Rectangle {
                        height: 28px;
                        background: Palette.background;
                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            padding-left: 16px; padding-right: 16px; spacing: 0px; alignment: start;
                            for bc in root.breadcrumbs : Rectangle {
                                height: 28px;
                                background: transparent;
                                HorizontalLayout {
                                    spacing: 4px; alignment: start;
                                    if bc.has-separator : Text { text: " › "; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                                    Text { text: bc.label; color: bc-touch.has-hover ? Palette.accent-foreground : Palette.foreground.transparentize(30%); font-size: 11px; vertical-alignment: center; }
                                }
                                bc-touch := TouchArea { mouse-cursor: pointer; clicked => { root.breadcrumb-clicked(bc.id); } }
                            }
                        }
                    }

                    // Canvas / content
                    Rectangle {
                        background: Palette.background;
                        vertical-stretch: 1;

                        // ── Docs full view ───────────────────────
                        if root.docs-view.visible : ScrollView {
                            VerticalLayout {
                                padding: 48px;
                                padding-top: 32px;
                                spacing: 0px;
                                alignment: start;

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;

                                    Rectangle {
                                        width: 28px;
                                        height: 28px;
                                        border-radius: 6px;
                                        background: docs-view-back.has-hover ? Palette.control-background : transparent;
                                        Image {
                                            source: @image-url("icons/chevron-left.svg");
                                            width: 16px;
                                            height: 16px;
                                            colorize: docs-view-back.has-hover ? Palette.foreground : Palette.foreground.transparentize(30%);
                                        }
                                        docs-view-back := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.docs-view-close(); }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "Back to editor";
                                            color: Palette.foreground.transparentize(40%);
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Rectangle { height: 24px; }

                                DocsContent {
                                    doc-title: root.docs-view.title;
                                    doc-summary: root.docs-view.summary;
                                    doc-body: root.docs-view.body;
                                    compact: false;
                                }
                            }
                        }

                        // ── Builder canvas ───────────────────────
                        if !root.docs-view.visible && root.active-panel-id == 1 : Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            background: Palette.alternate-background.transparentize(40%);

                            ScrollView {
                                VerticalLayout {
                                    alignment: start;
                                    padding: root.page-layout.is-responsive ? 0px : 24px;

                                    // Page surface
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        min-height: root.page-layout.is-responsive ? 400px : root.page-layout.page-height * 1px;
                                        background: Palette.background;
                                        border-width: root.page-layout.is-responsive ? 0px : 1px;
                                        border-color: Palette.foreground.transparentize(85%);
                                        border-radius: root.page-layout.is-responsive ? 0px : 2px;
                                        drop-shadow-blur: root.page-layout.is-responsive ? 0px : 6px;
                                        drop-shadow-color: #00000008;

                                        // Margin tint overlays
                                        if root.page-layout.margin-top > 0.0 : Rectangle {
                                            x: 0px; y: 0px; width: parent.width;
                                            height: root.page-layout.margin-top * 1px;
                                            background: Palette.accent-background.transparentize(95%);
                                        }
                                        if root.page-layout.margin-bottom > 0.0 : Rectangle {
                                            x: 0px; width: parent.width;
                                            y: parent.height - root.page-layout.margin-bottom * 1px;
                                            height: root.page-layout.margin-bottom * 1px;
                                            background: Palette.accent-background.transparentize(95%);
                                        }
                                        if root.page-layout.margin-left > 0.0 : Rectangle {
                                            x: 0px; y: root.page-layout.margin-top * 1px;
                                            width: root.page-layout.margin-left * 1px;
                                            height: parent.height - root.page-layout.margin-top * 1px - root.page-layout.margin-bottom * 1px;
                                            background: Palette.accent-background.transparentize(95%);
                                        }
                                        if root.page-layout.margin-right > 0.0 : Rectangle {
                                            y: root.page-layout.margin-top * 1px;
                                            x: parent.width - root.page-layout.margin-right * 1px;
                                            width: root.page-layout.margin-right * 1px;
                                            height: parent.height - root.page-layout.margin-top * 1px - root.page-layout.margin-bottom * 1px;
                                            background: Palette.accent-background.transparentize(95%);
                                        }

                                        // Grid overlay
                                        if root.page-layout.show-grid : Rectangle {
                                            x: 0px; y: 0px; width: parent.width; height: parent.height;

                                            // Margin boundary lines
                                            if root.page-layout.margin-left > 0.0 : Rectangle {
                                                x: root.page-layout.margin-left * 1px; y: 0px; width: 1px; height: parent.height;
                                                background: Palette.accent-background.transparentize(82%);
                                            }
                                            if root.page-layout.margin-right > 0.0 : Rectangle {
                                                x: parent.width - root.page-layout.margin-right * 1px; y: 0px; width: 1px; height: parent.height;
                                                background: Palette.accent-background.transparentize(82%);
                                            }
                                            if root.page-layout.margin-top > 0.0 : Rectangle {
                                                x: 0px; y: root.page-layout.margin-top * 1px; width: parent.width; height: 1px;
                                                background: Palette.accent-background.transparentize(82%);
                                            }
                                            if root.page-layout.margin-bottom > 0.0 : Rectangle {
                                                x: 0px; y: parent.height - root.page-layout.margin-bottom * 1px; width: parent.width; height: 1px;
                                                background: Palette.accent-background.transparentize(82%);
                                            }

                                            // Column gutters
                                            for cg[i] in root.column-gutters : Rectangle {
                                                x: cg.offset * 1px + root.page-layout.margin-left * 1px;
                                                y: root.page-layout.margin-top * 1px;
                                                width: cg.size * 1px;
                                                height: parent.height - root.page-layout.margin-top * 1px - root.page-layout.margin-bottom * 1px;
                                                background: Palette.accent-background.transparentize(92%);
                                                Rectangle { x: 0px; y: 0px; width: 1px; height: parent.height; background: Palette.accent-background.transparentize(78%); }
                                                Rectangle { x: parent.width - 1px; y: 0px; width: 1px; height: parent.height; background: Palette.accent-background.transparentize(78%); }
                                            }

                                            // Row gutters
                                            for rg[i] in root.row-gutters : Rectangle {
                                                x: root.page-layout.margin-left * 1px;
                                                y: rg.offset * 1px + root.page-layout.margin-top * 1px;
                                                width: parent.width - root.page-layout.margin-left * 1px - root.page-layout.margin-right * 1px;
                                                height: rg.size * 1px;
                                                background: Palette.accent-background.transparentize(92%);
                                                Rectangle { x: 0px; y: 0px; width: parent.width; height: 1px; background: Palette.accent-background.transparentize(78%); }
                                                Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Palette.accent-background.transparentize(78%); }
                                            }
                                        }

                                        // Content area (inside margins)
                                        VerticalLayout {
                                            padding-left: root.page-layout.margin-left * 1px;
                                            padding-right: root.page-layout.margin-right * 1px;
                                            padding-top: root.page-layout.margin-top * 1px;
                                            padding-bottom: root.page-layout.margin-bottom * 1px;
                                            spacing: 4px;
                                            alignment: start;

                                            if root.builder-nodes.length > 0 : VerticalLayout {
                                                spacing: 2px;
                                                for bnode[i] in root.builder-nodes : BuilderBlock {
                                                    node-id: bnode.id; component-type: bnode.component-type; selected: bnode.selected; depth: bnode.depth;
                                                    text: bnode.text; level: bnode.level; href: bnode.href; alt: bnode.alt;
                                                    placeholder: bnode.placeholder; label: bnode.label; disabled: bnode.disabled;
                                                    display-mode: bnode.display-mode; has-children: bnode.has-children;
                                                    clicked(id) => { root.builder-node-clicked(id); }
                                                    text-edited(id, val) => { root.builder-text-edited(id, val); }
                                                    delete-clicked(id) => { root.builder-delete-node(id); }
                                                }
                                            }

                                            if root.builder-nodes.length == 0 : VerticalLayout {
                                                alignment: center; spacing: 8px; padding-top: 80px;
                                                Text { text: "Empty document"; color: Palette.foreground.transparentize(50%); font-size: 16px; horizontal-alignment: center; }
                                                Text { text: "Add a component from the palette to get started."; color: Palette.foreground.transparentize(60%); font-size: 12px; horizontal-alignment: center; }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // ── Non-builder panels ──────────────────────
                        if !root.docs-view.visible && root.active-panel-id != 1 && root.active-panel-id != 2 : ScrollView {
                            VerticalLayout {
                                padding: 24px; spacing: 4px; alignment: start;

                                if root.active-panel-id == 0 : VerticalLayout {
                                    spacing: 12px;
                                    Text { text: "Welcome to Prism Studio"; color: Palette.foreground; font-size: 20px; font-weight: 600; }
                                    Text { text: "Select an action from the sidebar to get started."; color: Palette.foreground.transparentize(40%); font-size: 14px; wrap: word-wrap; }
                                }
                            }
                        }

                        // ── Code editor ─────────────────────────────
                        if root.active-panel-id == 2 && !root.docs-view.visible : Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            background: #1e222a;

                            property <length> line-h: 18px;
                            property <length> gutter-w: 44px;
                            property <length> content-pad: 8px;

                            // Cursor position measurement — uses actual font rendering width
                            cursor-measure := Text {
                                text: root.editor-cursor-prefix;
                                font-size: 13px;
                                font-family: "monospace";
                                opacity: 0;
                            }

                            // Approximate char-w for click mapping and selection
                            measure-char := Text {
                                text: "0000000000";
                                font-size: 13px;
                                font-family: "monospace";
                                opacity: 0;
                            }
                            property <length> char-w: max(1px, measure-char.preferred-width / 10);

                            editor-focus := FocusScope {
                                width: 100%;
                                height: 100%;
                                enabled: root.active-panel-id == 2;

                                key-pressed(event) => {
                                    if (event.text == Key.Return) { root.editor-action("enter"); return accept; }
                                    if (event.text == Key.Backspace) {
                                        if (event.modifiers.control) { root.editor-action("ctrl-backspace"); }
                                        else { root.editor-action("backspace"); }
                                        return accept;
                                    }
                                    if (event.text == Key.Delete) {
                                        if (event.modifiers.control) { root.editor-action("ctrl-delete"); }
                                        else { root.editor-action("delete"); }
                                        return accept;
                                    }
                                    if (event.text == Key.Tab) {
                                        if (event.modifiers.shift) { root.editor-action("shift-tab"); }
                                        else { root.editor-action("tab"); }
                                        return accept;
                                    }
                                    if (event.text == Key.UpArrow) {
                                        if (event.modifiers.shift) { root.editor-action("shift-up"); }
                                        else { root.editor-action("up"); }
                                        return accept;
                                    }
                                    if (event.text == Key.DownArrow) {
                                        if (event.modifiers.shift) { root.editor-action("shift-down"); }
                                        else { root.editor-action("down"); }
                                        return accept;
                                    }
                                    if (event.text == Key.LeftArrow) {
                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-left"); }
                                        else if (event.modifiers.control) { root.editor-action("ctrl-left"); }
                                        else if (event.modifiers.shift) { root.editor-action("shift-left"); }
                                        else { root.editor-action("left"); }
                                        return accept;
                                    }
                                    if (event.text == Key.RightArrow) {
                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-right"); }
                                        else if (event.modifiers.control) { root.editor-action("ctrl-right"); }
                                        else if (event.modifiers.shift) { root.editor-action("shift-right"); }
                                        else { root.editor-action("right"); }
                                        return accept;
                                    }
                                    if (event.text == Key.Home) {
                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-home"); }
                                        else if (event.modifiers.control) { root.editor-action("ctrl-home"); }
                                        else if (event.modifiers.shift) { root.editor-action("shift-home"); }
                                        else { root.editor-action("home"); }
                                        return accept;
                                    }
                                    if (event.text == Key.End) {
                                        if (event.modifiers.control && event.modifiers.shift) { root.editor-action("ctrl-shift-end"); }
                                        else if (event.modifiers.control) { root.editor-action("ctrl-end"); }
                                        else if (event.modifiers.shift) { root.editor-action("shift-end"); }
                                        else { root.editor-action("end"); }
                                        return accept;
                                    }
                                    if (event.modifiers.control) {
                                        if (event.text == "\u{0001}") { root.editor-action("select-all"); return accept; }
                                        if (event.text == "\u{0004}") { root.editor-action("duplicate-line"); return accept; }
                                        if (event.text == "\u{000b}") { root.editor-action("delete-line"); return accept; }
                                        return reject;
                                    }
                                    if (event.text == Key.Escape) { root.escape-pressed(); return accept; }
                                    root.editor-char-typed(event.text);
                                    return accept;
                                }

                                editor-sv := ScrollView {
                                    width: 100%;
                                    height: 100%;

                                    VerticalLayout {
                                        spacing: 0px;
                                        alignment: start;

                                        for line[idx] in root.editor-lines : Rectangle {
                                            height: line-h;
                                            background: line.is-current ? #ffffff06 : transparent;

                                            // Selection highlight
                                            if line.sel-from >= 0 : Rectangle {
                                                x: gutter-w + content-pad + line.sel-from * char-w;
                                                y: 0px;
                                                width: line.sel-to > line.sel-from
                                                    ? (line.sel-to - line.sel-from) * char-w
                                                    : parent.width - gutter-w - content-pad - line.sel-from * char-w;
                                                height: line-h;
                                                background: #264f7880;
                                            }

                                            // Gutter
                                            Rectangle {
                                                x: 0px;
                                                y: 0px;
                                                width: gutter-w;
                                                height: line-h;
                                                background: #161a22;

                                                Text {
                                                    x: 0px;
                                                    width: gutter-w - 8px;
                                                    text: line.number;
                                                    color: line.is-current ? #ffffff60 : #ffffff22;
                                                    font-size: 13px;
                                                    font-family: "monospace";
                                                    horizontal-alignment: right;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            // Gutter border
                                            Rectangle {
                                                x: gutter-w - 1px;
                                                y: 0px;
                                                width: 1px;
                                                height: line-h;
                                                background: #ffffff08;
                                            }

                                            // Tokens — flow layout for correct font-native spacing
                                            HorizontalLayout {
                                                x: gutter-w + content-pad;
                                                y: 0px;
                                                height: line-h;
                                                spacing: 0px;
                                                alignment: start;

                                                for token in line.tokens : Text {
                                                    text: token.text;
                                                    color: token.token-color;
                                                    font-size: 13px;
                                                    font-family: "monospace";
                                                    vertical-alignment: center;
                                                    horizontal-stretch: 0;
                                                }
                                            }

                                            // Cursor — positioned via actual text measurement
                                            if line.is-current && root.editor-cursor-visible : Rectangle {
                                                x: gutter-w + content-pad + cursor-measure.preferred-width;
                                                y: 1px;
                                                width: 2px;
                                                height: line-h - 2px;
                                                background: #528bff;
                                            }

                                        }

                                        Rectangle {
                                            vertical-stretch: 1;
                                            min-height: 200px;
                                            background: transparent;
                                        }
                                    }
                                }
                            }

                            editor-overlay := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: text;

                                pointer-event(event) => {
                                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                                        editor-focus.focus();
                                        root.editor-click(
                                            clamp(floor((self.mouse-y - editor-sv.viewport-y) / line-h), 0, root.editor-lines.length - 1),
                                            max(0, floor((self.mouse-x - gutter-w - content-pad + char-w / 2) / char-w))
                                        );
                                    }
                                }
                                moved => {
                                    if self.pressed {
                                        root.editor-drag(
                                            clamp(floor((self.mouse-y - editor-sv.viewport-y) / line-h), 0, root.editor-lines.length - 1),
                                            max(0, floor((self.mouse-x - gutter-w - content-pad + char-w / 2) / char-w))
                                        );
                                    }
                                }
                                scroll-event(event) => {
                                    editor-sv.viewport-y = clamp(
                                        editor-sv.viewport-y + event.delta-y,
                                        min(0px, editor-sv.height - editor-sv.viewport-height),
                                        0px
                                    );
                                    return accept;
                                }
                            }
                        }
                    }

                    // Status bar
                    Rectangle {
                        height: 26px;
                        background: root.active-panel-id == 2 ? #1b1f27 : Palette.alternate-background;
                        Rectangle { x: 0px; y: 0px; width: parent.width; height: 1px; background: Palette.foreground.transparentize(90%); }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; spacing: 12px; alignment: start;
                            Text { text: root.panel-title; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id != 2 && root.has-selection : Text { text: "·"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id != 2 && root.has-selection : Text { text: "Selected"; color: Palette.accent-foreground; font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "·"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "Ln " + (root.editor-cursor-line + 1) + ", Col " + (root.editor-cursor-col + 1); color: Palette.foreground.transparentize(30%); font-size: 11px; vertical-alignment: center; }
                            Rectangle { horizontal-stretch: 1; }
                            if root.active-panel-id == 2 : Text { text: root.editor-line-count + " lines"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "·"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: root.editor-language; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                            if root.active-panel-id == 2 : Text { text: "·"; color: Palette.foreground.transparentize(60%); font-size: 11px; vertical-alignment: center; }
                            Text { text: "Prism Studio"; color: Palette.foreground.transparentize(50%); font-size: 11px; vertical-alignment: center; }
                        }
                    }
                }

                // ── Edit mode: right sidebar (properties) ────────
                if root.active-panel-id == 1 : SplitHandle {
                    dragged(delta) => { root.right-sidebar-width = clamp(root.right-sidebar-width - delta, 180px, 500px); }
                }
                if root.active-panel-id == 1 : Rectangle {
                    width: root.right-sidebar-width;
                    background: Palette.alternate-background;
                    clip: true;
                    Rectangle { x: 0px; y: 0px; width: 1px; height: parent.height; background: Palette.foreground.transparentize(90%); }

                    VerticalLayout {
                        padding: 16px; spacing: 8px;

                        Text { text: "Properties"; color: Palette.foreground; font-size: 14px; font-weight: 700; }

                        if root.has-selection && root.selected-component != "" : HorizontalLayout {
                            spacing: 6px; alignment: start;
                            Image { source: @image-url("icons/sliders.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); y: 1px; }
                            Text { text: root.selected-component; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            visible: root.has-selection && root.selected-component != "";
                            VerticalLayout {
                                min-width: 220px;
                                spacing: 4px;

                                // Component properties
                                for field[i] in root.field-rows : FieldEditor {
                                    key: field.key; label: field.label; kind: field.kind; value: field.value; required: field.required;
                                    min: field.min; max: field.max; has-bounds: field.has-bounds; options: field.options; swatch: field.swatch;
                                    field-edited(key, val) => { root.field-edited(key, val); }
                                    field-edited-number(key, val) => { root.field-edited-number(key, val); }
                                }

                                // Layout section separator
                                if root.layout-rows.length > 0 : Rectangle { height: 8px; }
                                if root.layout-rows.length > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                if root.layout-rows.length > 0 : Rectangle { height: 4px; }

                                if root.layout-rows.length > 0 : HorizontalLayout {
                                    spacing: 6px; alignment: start;
                                    Image { source: @image-url("icons/layout.svg"); width: 12px; height: 12px; colorize: Palette.foreground.transparentize(40%); y: 1px; }
                                    Text { text: "Layout"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                }

                                // Layout properties
                                for lfield[i] in root.layout-rows : FieldEditor {
                                    key: lfield.key; label: lfield.label; kind: lfield.kind; value: lfield.value; required: lfield.required;
                                    min: lfield.min; max: lfield.max; has-bounds: lfield.has-bounds; options: lfield.options; swatch: lfield.swatch;
                                    field-edited(key, val) => { root.layout-field-edited(key, val); }
                                    field-edited-number(key, val) => { root.layout-field-edited-number(key, val); }
                                }

                                // ── Variants ──────────────────
                                if root.variant-items.length > 0 : Rectangle { height: 8px; }
                                if root.variant-items.length > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                if root.variant-items.length > 0 : Rectangle { height: 4px; }
                                if root.variant-items.length > 0 : HorizontalLayout {
                                    spacing: 6px; alignment: start;
                                    Text { text: "Variants"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                }
                                for vitem[i] in root.variant-items : HorizontalLayout {
                                    spacing: 8px; height: 28px;
                                    Text { text: vitem.label; color: Palette.foreground.transparentize(40%); font-size: 11px; width: 80px; vertical-alignment: center; }
                                    ComboBox {
                                        model: vitem.options;
                                        current-value: vitem.selected;
                                        horizontal-stretch: 1;
                                    }
                                }

                                // ── Modifiers ─────────────────
                                if root.modifier-items.length > 0 : Rectangle { height: 8px; }
                                if root.modifier-items.length > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                if root.modifier-items.length > 0 : Rectangle { height: 4px; }
                                if root.modifier-items.length > 0 : HorizontalLayout {
                                    spacing: 6px; alignment: start;
                                    Text { text: "Modifiers"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                }
                                for mitem[i] in root.modifier-items : Rectangle {
                                    height: 24px;
                                    HorizontalLayout {
                                        spacing: 6px; alignment: start; padding-left: 4px;
                                        Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Palette.accent-background; y: 5px; }
                                        Text { text: mitem.label; color: Palette.foreground.transparentize(20%); font-size: 11px; vertical-alignment: center; }
                                    }
                                }

                                // ── Signals ───────────────────
                                if root.signal-items.length > 0 : Rectangle { height: 8px; }
                                if root.signal-items.length > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                if root.signal-items.length > 0 : Rectangle { height: 4px; }
                                if root.signal-items.length > 0 : HorizontalLayout {
                                    spacing: 6px; alignment: start;
                                    Text { text: "Signals"; color: Palette.foreground.transparentize(30%); font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                    if root.connection-count > 0 : Text {
                                        text: root.connection-count == 1 ? "1 connection" : "\{root.connection-count} connections";
                                        color: Palette.accent-background; font-size: 10px; vertical-alignment: center;
                                    }
                                }
                                for sitem[i] in root.signal-items : Rectangle {
                                    height: 24px;
                                    HorizontalLayout {
                                        spacing: 6px; alignment: start; padding-left: 4px;
                                        Text { text: "⚡"; font-size: 10px; vertical-alignment: center; }
                                        Text { text: sitem.name; color: Palette.foreground.transparentize(20%); font-size: 11px; font-weight: 500; vertical-alignment: center; }
                                        Text { text: sitem.description; color: Palette.foreground.transparentize(50%); font-size: 10px; vertical-alignment: center; }
                                    }
                                }

                                // ── Document summary ──────────
                                if root.resource-count > 0 || root.prefab-count > 0 : Rectangle { height: 8px; }
                                if root.resource-count > 0 || root.prefab-count > 0 : Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
                                if root.resource-count > 0 || root.prefab-count > 0 : Rectangle { height: 4px; }
                                if root.resource-count > 0 : Text {
                                    text: root.resource-count == 1 ? "1 resource" : "\{root.resource-count} resources";
                                    color: Palette.foreground.transparentize(50%); font-size: 10px;
                                }
                                if root.prefab-count > 0 : Text {
                                    text: root.prefab-count == 1 ? "1 prefab" : "\{root.prefab-count} prefabs";
                                    color: Palette.foreground.transparentize(50%); font-size: 10px;
                                }
                            }
                        }

                        if !root.has-selection : VerticalLayout {
                            spacing: 8px; padding-top: 24px;
                            Text { text: "No selection"; color: Palette.foreground.transparentize(40%); font-size: 13px; font-weight: 500; horizontal-alignment: center; }
                            Text { text: "Select an element on the canvas or in the layers panel to edit its properties."; color: Palette.foreground.transparentize(60%); font-size: 11px; wrap: word-wrap; horizontal-alignment: center; }
                        }
                    }
                }
            }
        }
    }

    // ── Command palette ───────────────────────────────────────────
    if root.command-palette-visible : Rectangle { width: 100%; height: 100%; background: #00000060; TouchArea { clicked => { root.toggle-command-palette(); } } }
    if root.command-palette-visible : Rectangle {
        x: (root.width - 500px) / 2; y: 64px; width: 500px;
        height: min(root.command-results.length * 36px + 48px, 420px);
        background: Palette.alternate-background; border-radius: 8px; border-width: 1px; border-color: Palette.accent-background; clip: true;
        VerticalLayout {
            padding: 8px; spacing: 4px;
            HorizontalLayout {
                spacing: 8px;
                Image { source: @image-url("icons/search.svg"); width: 16px; height: 16px; colorize: Palette.foreground.transparentize(40%); y: 8px; }
                LineEdit { height: 32px; horizontal-stretch: 1; placeholder-text: "Type a command..."; edited(text) => { root.command-palette-input(text); } accepted(text) => { if (root.command-results.length > 0) { root.command-selected(0); } } }
            }
            ScrollView {
                VerticalLayout {
                    spacing: 1px;
                    for cmd[i] in root.command-results : Rectangle {
                        height: 32px; background: cmd-touch.has-hover ? Palette.control-background : transparent; border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px; alignment: space-between;
                            HorizontalLayout {
                                spacing: 8px;
                                if cmd.category != "" : Text { text: cmd.category; color: Palette.foreground.transparentize(40%); font-size: 11px; vertical-alignment: center; }
                                Text { text: cmd.label; color: Palette.foreground; font-size: 13px; vertical-alignment: center; }
                            }
                            if cmd.shortcut != "" : Rectangle {
                                background: Palette.control-background; border-radius: 3px; height: 20px; width: shortcut-text.preferred-width + 12px; y: 6px;
                                shortcut-text := Text { text: cmd.shortcut; color: Palette.foreground.transparentize(30%); font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                        cmd-touch := TouchArea { mouse-cursor: pointer; clicked => { root.command-selected(i); } }
                    }
                }
            }
        }
    }

    // ── Toasts ────────────────────────────────────────────────────
    if root.notifications.length > 0 : VerticalLayout {
        x: root.width - 340px; y: root.height - root.notifications.length * 100px - 20px; width: 320px; spacing: 8px;
        for notif[i] in root.notifications : Toast { title: notif.title; body: notif.body; kind: notif.kind; dismissed => { root.dismiss-notification(notif.id); } }
    }

    // ── Help tooltip ──────────────────────────────────────────────
    if root.help-tooltip.visible : Rectangle {
        x: min(root.help-tooltip.tip-x, root.width - 284px);
        y: min(root.help-tooltip.tip-y, root.height - tooltip-layout.preferred-height - 8px);
        width: 276px;
        height: tooltip-layout.preferred-height;
        border-radius: 10px; border-width: 1px;
        border-color: Palette.foreground.transparentize(85%);
        background: Palette.alternate-background; clip: true;

        // Behind everything: keeps tooltip alive on hover
        help-tip-touch := TouchArea {
            changed has-hover => {
                if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                if (!self.has-hover) { root.help-leave(); }
            }
        }

        tooltip-layout := VerticalLayout {
            Rectangle {
                height: 32px;
                HorizontalLayout {
                    padding: 8px; padding-left: 12px; spacing: 8px; alignment: start;
                    Image { source: @image-url("icons/help-circle.svg"); width: 12px; height: 12px; colorize: tooltip-header-touch.has-hover ? Palette.accent-foreground : Palette.accent-background; y: 2px; }
                    Text { text: root.help-tooltip.title; color: tooltip-header-touch.has-hover ? Palette.accent-foreground : Palette.foreground; font-size: 12px; font-weight: 600; vertical-alignment: center; overflow: elide; }
                }
                tooltip-header-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.help-entry-clicked(); }
                    changed has-hover => {
                        if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                        if (!self.has-hover) { root.help-leave(); }
                    }
                }
            }
            Rectangle { height: 1px; background: Palette.foreground.transparentize(85%); }
            Rectangle {
                VerticalLayout {
                    padding: 10px; padding-left: 12px; padding-right: 12px;
                    Text { text: root.help-tooltip.summary; color: Palette.foreground.transparentize(30%); font-size: 12px; wrap: word-wrap; }
                }
            }
            if root.help-tooltip.has-docs && !root.docs-panel.visible && !root.docs-view.visible : Rectangle {
                height: 32px;
                Rectangle { y: 0px; height: 1px; width: parent.width; background: Palette.foreground.transparentize(85%); }
                HorizontalLayout {
                    padding: 8px; padding-left: 12px; spacing: 6px; alignment: start;
                    Image { source: @image-url("icons/book.svg"); width: 11px; height: 11px; colorize: Palette.accent-background; }
                    Text { text: "Open in Docs"; color: Palette.accent-background; font-size: 12px; }
                }
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.help-docs-clicked(); }
                    changed has-hover => {
                        if (self.has-hover) { root.help-hover("__tooltip__", 0px, 0px); }
                        if (!self.has-hover) { root.help-leave(); }
                    }
                }
            }
        }
    }
}
