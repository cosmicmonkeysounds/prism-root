{
  "name": "@prism/capacitor-daemon",
  "version": "0.1.0",
  "description": "Capacitor plugin that exposes prism-daemon (Rust kernel) to iOS + Android native shells via the C ABI exported from libprism_daemon.a.",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "ios/Tests/",
    "Package.swift",
    "PrismCapacitorDaemon.podspec"
  ],
  "author": "Prism",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
