// Prism Shell — root Slint component.
//
// Phase 0 parity with the old Clay sidebar: background canvas, a
// 240px sidebar, a title row, and three action buttons. Labels and
// colours come from Rust-side `DesignTokens` via the properties
// exposed at the top of `AppWindow`.
//
// Phase 1 grows this into the full panel set via a `HorizontalBox`
// splitter + one `Rectangle` per registered panel. For now the one
// panel is hard-coded; `active_panel` is a bindable string property
// so the host can switch between future panels without touching
// Slint.

struct ButtonSpec {
    label: string,
}

component SidebarButton inherits Rectangle {
    in property <string> label;
    in property <color> background-color;
    in property <color> text-color;
    callback clicked;

    height: 36px;
    background: background-color;
    border-radius: 4px;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: start;
        Text {
            text: label;
            color: text-color;
            font-size: 14px;
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: "Prism Shell";
    preferred-width: 1280px;
    preferred-height: 800px;

    // Design-token-backed colours. Bound from Rust on boot.
    in property <color> background-color: #12131a;
    in property <color> sidebar-color: #1e202c;
    in property <color> button-color: #3c78dc;
    in property <color> text-color: #f0f0f5;

    in property <string> panel-title: "Identity";
    in property <string> panel-hint: "Select an action from the sidebar.";

    // Sidebar actions. The host populates this model; clicks are
    // routed back via `clicked(index)`.
    in property <[ButtonSpec]> actions: [
        { label: "Create Identity" },
        { label: "Load Vault" },
        { label: "Sign Document" },
    ];
    callback clicked(int);

    background: background-color;

    HorizontalLayout {
        spacing: 0px;

        // Sidebar column.
        Rectangle {
            width: 240px;
            background: sidebar-color;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                alignment: start;

                Text {
                    text: panel-title;
                    color: text-color;
                    font-size: 18px;
                }

                for action[i] in actions : SidebarButton {
                    label: action.label;
                    background-color: button-color;
                    text-color: text-color;
                    clicked => { root.clicked(i); }
                }
            }
        }

        // Main content placeholder.
        Rectangle {
            background: background-color;

            VerticalLayout {
                padding: 24px;
                alignment: start;
                Text {
                    text: panel-hint;
                    color: text-color;
                    font-size: 16px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
